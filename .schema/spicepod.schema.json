{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spicepod Definition",
  "description": "A Spicepod definition is a YAML file that describes a Spicepod.",
  "type": "object",
  "properties": {
    "catalogs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentOrReference_for_Catalog"
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentOrReference_for_Dataset"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "embeddings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentOrReference_for_Embeddings"
      }
    },
    "evals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentOrReference_for_Eval"
      }
    },
    "extensions": {
      "description": "Optional extensions configuration",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/Extension"
      }
    },
    "kind": {
      "description": "The kind of Spicepod",
      "$ref": "#/$defs/SpicepodKind"
    },
    "management": {
      "description": "Optional management configuration",
      "anyOf": [
        {
          "$ref": "#/$defs/Management"
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentOrReference_for_Model"
      }
    },
    "name": {
      "description": "The name of the Spicepod",
      "type": "string"
    },
    "runtime": {
      "description": "Optional runtime configuration",
      "$ref": "#/$defs/Runtime"
    },
    "secrets": {
      "description": "Optional spicepod secrets configuration\n Default value is:\n ```yaml\n secrets:\n   - from: env\n     name: env\n ```",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Secret"
      }
    },
    "snapshots": {
      "description": "Optional acceleration snapshot configuration",
      "anyOf": [
        {
          "$ref": "#/$defs/Snapshots"
        },
        {
          "type": "null"
        }
      ]
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentOrReference_for_Tool"
      }
    },
    "version": {
      "description": "The version of the Spicepod",
      "$ref": "#/$defs/SpicepodVersion"
    },
    "views": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentOrReference_for_View"
      }
    },
    "workers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentOrReference_for_Worker"
      }
    }
  },
  "required": [
    "name",
    "version",
    "kind"
  ],
  "$defs": {
    "Acceleration": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "engine": {
          "type": [
            "string",
            "null"
          ]
        },
        "indexes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/IndexType"
          }
        },
        "metrics": {
          "anyOf": [
            {
              "$ref": "#/$defs/Metrics"
            },
            {
              "type": "null"
            }
          ]
        },
        "mode": {
          "$ref": "#/$defs/Mode",
          "default": "memory"
        },
        "on_conflict": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/OnConflictBehavior"
          }
        },
        "on_zero_results": {
          "$ref": "#/$defs/ZeroResultsAction",
          "default": "return_empty"
        },
        "params": {
          "anyOf": [
            {
              "$ref": "#/$defs/Params"
            },
            {
              "type": "null"
            }
          ]
        },
        "partition_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primary_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "ready_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReadyState"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "deprecated": true
        },
        "refresh_append_overlap": {
          "type": [
            "string",
            "null"
          ]
        },
        "refresh_check_interval": {
          "type": [
            "string",
            "null"
          ]
        },
        "refresh_cron": {
          "type": [
            "string",
            "null"
          ]
        },
        "refresh_data_window": {
          "type": [
            "string",
            "null"
          ]
        },
        "refresh_jitter_enabled": {
          "type": "boolean",
          "default": false
        },
        "refresh_jitter_max": {
          "type": [
            "string",
            "null"
          ]
        },
        "refresh_mode": {
          "anyOf": [
            {
              "$ref": "#/$defs/RefreshMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "refresh_on_startup": {
          "$ref": "#/$defs/RefreshOnStartup",
          "default": "auto"
        },
        "refresh_retry_enabled": {
          "type": "boolean",
          "default": true
        },
        "refresh_retry_max_attempts": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "refresh_sql": {
          "type": [
            "string",
            "null"
          ]
        },
        "retention_check_enabled": {
          "type": "boolean"
        },
        "retention_check_interval": {
          "type": [
            "string",
            "null"
          ]
        },
        "retention_period": {
          "type": [
            "string",
            "null"
          ]
        },
        "retention_sql": {
          "type": [
            "string",
            "null"
          ]
        },
        "snapshots": {
          "description": "Enables snapshots for this dataset, requires the top-level config `snapshots` to be defined.\n\n Options: `enabled` / `disabled` / `bootstrap_only` / `create_only`.\n\n `disabled` (default) will turn off snapshots for this dataset.\n `enabled` will enable both creating and bootstrapping from snapshots.\n `bootstrap_only` will only bootstrap on startup, it won't attempt to write new snapshots.\n `create_only` will only create snapshots, it won't attempt to bootstrap from one.",
          "$ref": "#/$defs/SnapshotBehavior"
        }
      },
      "additionalProperties": false
    },
    "AccessMode": {
      "type": "string",
      "enum": [
        "read",
        "read_write"
      ]
    },
    "ApiKey": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "ReadOnly": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                }
              },
              "required": [
                "key"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "ReadOnly"
          ]
        },
        {
          "type": "object",
          "properties": {
            "ReadWrite": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                }
              },
              "required": [
                "key"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "ReadWrite"
          ]
        }
      ]
    },
    "ApiKeyAuth": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "keys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ApiKey"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "keys"
      ]
    },
    "Auth": {
      "type": "object",
      "properties": {
        "api_key": {
          "anyOf": [
            {
              "$ref": "#/$defs/ApiKeyAuth"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "BootstrapOnFailureBehavior": {
      "type": "string",
      "enum": [
        "warn",
        "retry",
        "fallback"
      ]
    },
    "CacheConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "eviction_policy": {
          "type": [
            "string",
            "null"
          ]
        },
        "hashing_algorithm": {
          "$ref": "#/$defs/HashingAlgorithm",
          "default": "siphash"
        },
        "item_ttl": {
          "type": [
            "string",
            "null"
          ]
        },
        "max_size": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "CacheKeyType": {
      "type": "string",
      "enum": [
        "plan",
        "sql"
      ]
    },
    "Caching": {
      "type": "object",
      "properties": {
        "embeddings": {
          "anyOf": [
            {
              "$ref": "#/$defs/CacheConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "search_results": {
          "anyOf": [
            {
              "$ref": "#/$defs/CacheConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "sql_results": {
          "anyOf": [
            {
              "$ref": "#/$defs/SQLResultsCacheConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "Catalog": {
      "type": "object",
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "access": {
          "$ref": "#/$defs/AccessMode"
        },
        "dataset_params": {
          "anyOf": [
            {
              "$ref": "#/$defs/Params"
            },
            {
              "type": "null"
            }
          ]
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "from": {
          "type": "string"
        },
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "metrics": {
          "anyOf": [
            {
              "$ref": "#/$defs/Metrics"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "params": {
          "anyOf": [
            {
              "$ref": "#/$defs/Params"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "from",
        "name"
      ]
    },
    "CheckAvailability": {
      "description": "Controls whether the federated table periodically has its availability checked.",
      "oneOf": [
        {
          "description": "The dataset is checked for availability if it isn't accelerated.",
          "type": "string",
          "const": "auto"
        },
        {
          "description": "The dataset is not checked for availability.",
          "type": "string",
          "const": "disabled"
        }
      ]
    },
    "Column": {
      "type": "object",
      "properties": {
        "description": {
          "description": "Optional semantic details about the column",
          "type": [
            "string",
            "null"
          ]
        },
        "embeddings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ColumnLevelEmbeddingConfig"
          }
        },
        "full_text_search": {
          "anyOf": [
            {
              "$ref": "#/$defs/FullTextSearchConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "ColumnEmbeddingConfig": {
      "description": "Configuration for if and how a dataset's column should be embedded.\n\n Prefer to use [`super::dataset::column::ColumnLevelEmbeddingConfig`] going\n forward. Support for [`ColumnEmbeddingConfig`] will be removed in future.",
      "type": "object",
      "properties": {
        "chunking": {
          "anyOf": [
            {
              "$ref": "#/$defs/EmbeddingChunkConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "column": {
          "type": "string"
        },
        "column_pk": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "use": {
          "type": "string",
          "default": ""
        },
        "vector_size": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "column"
      ]
    },
    "ColumnLevelEmbeddingConfig": {
      "description": "Configuration for if and how a dataset's column should be embedded.\n Different to [`crate::component::embeddings::ColumnEmbeddingConfig`],\n as [`ColumnLevelEmbeddingConfig`] should be a property of [`Column`],\n not [`super::Dataset`].\n\n [`crate::component::embeddings::ColumnEmbeddingConfig`] will be\n deprecated long term in favour of [`ColumnLevelEmbeddingConfig`].",
      "type": "object",
      "properties": {
        "chunking": {
          "anyOf": [
            {
              "$ref": "#/$defs/EmbeddingChunkConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "from": {
          "type": "string",
          "default": ""
        },
        "row_id": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "vector_size": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        }
      }
    },
    "ComponentOrReference_for_Catalog": {
      "anyOf": [
        {
          "$ref": "#/$defs/Catalog"
        },
        {
          "$ref": "#/$defs/ComponentReference"
        }
      ]
    },
    "ComponentOrReference_for_Dataset": {
      "anyOf": [
        {
          "$ref": "#/$defs/Dataset"
        },
        {
          "$ref": "#/$defs/ComponentReference"
        }
      ]
    },
    "ComponentOrReference_for_Embeddings": {
      "anyOf": [
        {
          "$ref": "#/$defs/Embeddings"
        },
        {
          "$ref": "#/$defs/ComponentReference"
        }
      ]
    },
    "ComponentOrReference_for_Eval": {
      "anyOf": [
        {
          "$ref": "#/$defs/Eval"
        },
        {
          "$ref": "#/$defs/ComponentReference"
        }
      ]
    },
    "ComponentOrReference_for_Model": {
      "anyOf": [
        {
          "$ref": "#/$defs/Model"
        },
        {
          "$ref": "#/$defs/ComponentReference"
        }
      ]
    },
    "ComponentOrReference_for_Tool": {
      "anyOf": [
        {
          "$ref": "#/$defs/Tool"
        },
        {
          "$ref": "#/$defs/ComponentReference"
        }
      ]
    },
    "ComponentOrReference_for_View": {
      "anyOf": [
        {
          "$ref": "#/$defs/View"
        },
        {
          "$ref": "#/$defs/ComponentReference"
        }
      ]
    },
    "ComponentOrReference_for_Worker": {
      "anyOf": [
        {
          "$ref": "#/$defs/Worker"
        },
        {
          "$ref": "#/$defs/ComponentReference"
        }
      ]
    },
    "ComponentReference": {
      "type": "object",
      "properties": {
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ref": {
          "type": "string"
        }
      },
      "required": [
        "ref"
      ]
    },
    "CorsConfig": {
      "type": "object",
      "properties": {
        "allowed_origins": {
          "type": "array",
          "default": [
            "*"
          ],
          "items": {
            "type": "string"
          }
        },
        "enabled": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "Dataset": {
      "type": "object",
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "acceleration": {
          "anyOf": [
            {
              "$ref": "#/$defs/Acceleration"
            },
            {
              "type": "null"
            }
          ]
        },
        "access": {
          "$ref": "#/$defs/AccessMode"
        },
        "check_availability": {
          "description": "Configures whether the dataset availability monitor is enabled for this dataset.\n When enabled, the runtime will periodically check dataset availability\n and report metrics. Dataset availability is only checked if the dataset is not accelerated.",
          "$ref": "#/$defs/CheckAvailability"
        },
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Column"
          }
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "embeddings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ColumnEmbeddingConfig"
          }
        },
        "from": {
          "type": "string"
        },
        "has_metadata_table": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "metrics": {
          "anyOf": [
            {
              "$ref": "#/$defs/Metrics"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "params": {
          "anyOf": [
            {
              "$ref": "#/$defs/Params"
            },
            {
              "type": "null"
            }
          ]
        },
        "ready_state": {
          "$ref": "#/$defs/ReadyState"
        },
        "replication": {
          "anyOf": [
            {
              "$ref": "#/$defs/Replication"
            },
            {
              "type": "null"
            }
          ]
        },
        "time_column": {
          "type": [
            "string",
            "null"
          ]
        },
        "time_format": {
          "anyOf": [
            {
              "$ref": "#/$defs/TimeFormat"
            },
            {
              "type": "null"
            }
          ]
        },
        "time_partition_column": {
          "type": [
            "string",
            "null"
          ]
        },
        "time_partition_format": {
          "anyOf": [
            {
              "$ref": "#/$defs/TimeFormat"
            },
            {
              "type": "null"
            }
          ]
        },
        "unsupported_type_action": {
          "anyOf": [
            {
              "$ref": "#/$defs/UnsupportedTypeAction"
            },
            {
              "type": "null"
            }
          ]
        },
        "vectors": {
          "anyOf": [
            {
              "$ref": "#/$defs/VectorStore"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "EmbeddingChunkConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "overlap_size": {
          "type": "integer",
          "format": "uint",
          "default": 0,
          "minimum": 0
        },
        "target_chunk_size": {
          "type": "integer",
          "format": "uint",
          "default": 0,
          "minimum": 0
        },
        "trim_whitespace": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "Embeddings": {
      "type": "object",
      "properties": {
        "datasets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ModelFile"
          }
        },
        "from": {
          "type": "string"
        },
        "metrics": {
          "anyOf": [
            {
              "$ref": "#/$defs/Metrics"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "from",
        "name"
      ]
    },
    "Eval": {
      "type": "object",
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "dataset": {
          "type": "string"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metrics": {
          "anyOf": [
            {
              "$ref": "#/$defs/Metrics"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "scorers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "dataset",
        "scorers"
      ]
    },
    "Extension": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "Flight": {
      "type": "object",
      "properties": {
        "max_message_size": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "FullTextSearchConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "index_directory": {
          "type": [
            "string",
            "null"
          ]
        },
        "index_store": {
          "anyOf": [
            {
              "$ref": "#/$defs/IndexStore"
            },
            {
              "type": "null"
            }
          ]
        },
        "row_id": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "enabled"
      ]
    },
    "HashingAlgorithm": {
      "type": "string",
      "enum": [
        "siphash",
        "ahash",
        "xxh3",
        "xxh32",
        "xxh64",
        "xxh128"
      ]
    },
    "IndexStore": {
      "type": "string",
      "enum": [
        "memory",
        "file"
      ]
    },
