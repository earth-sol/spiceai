|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=benchmarks-tpcds sql=SELECT count(*) FROM (SELECT DISTINCT customer.c_last_name, customer.c_first_name, date_dim.d_date FROM store_sales JOIN date_dim ON ((store_sales.ss_sold_date_sk = date_dim.d_date_sk) AND (date_dim.d_month_seq BETWEEN 1189 AND (1189 + 11))) JOIN customer ON (store_sales.ss_customer_sk = customer.c_customer_sk) LEFT ANTI JOIN (SELECT DISTINCT customer.c_last_name, customer.c_first_name, date_dim.d_date FROM catalog_sales JOIN date_dim ON ((catalog_sales.cs_sold_date_sk = date_dim.d_date_sk) AND (date_dim.d_month_seq BETWEEN 1189 AND (1189 + 11))) JOIN customer ON (catalog_sales.cs_bill_customer_sk = customer.c_customer_sk)) ON customer.c_last_name = customer.c_last_name AND customer.c_first_name = customer.c_first_name AND date_dim.d_date = date_dim.d_date) AS cool_cust LEFT ANTI JOIN (SELECT DISTINCT customer.c_last_name, customer.c_first_name, date_dim.d_date FROM web_sales JOIN date_dim ON ((web_sales.ws_sold_date_sk = date_dim.d_date_sk) AND (date_dim.d_month_seq BETWEEN 1189 AND (1189 + 11))) JOIN customer ON (web_sales.ws_bill_customer_sk = customer.c_customer_sk)) ON customer.c_last_name = customer.c_last_name AND customer.c_first_name = customer.c_first_name AND date_dim.d_date = date_dim.d_date rewritten_sql=SELECT count(*) FROM (SELECT DISTINCT "tpcds"."customer"."c_last_name", "tpcds"."customer"."c_first_name", "tpcds"."date_dim"."d_date" FROM "tpcds"."store_sales" JOIN "tpcds"."date_dim" ON (("tpcds"."store_sales"."ss_sold_date_sk" = "tpcds"."date_dim"."d_date_sk") AND ("tpcds"."date_dim"."d_month_seq" BETWEEN 1189 AND (1189 + 11))) JOIN "tpcds"."customer" ON ("tpcds"."store_sales"."ss_customer_sk" = "tpcds"."customer"."c_customer_sk") LEFT ANTI JOIN (SELECT DISTINCT "tpcds"."customer"."c_last_name", "tpcds"."customer"."c_first_name", "tpcds"."date_dim"."d_date" FROM "tpcds"."catalog_sales" JOIN "tpcds"."date_dim" ON (("tpcds"."catalog_sales"."cs_sold_date_sk" = "tpcds"."date_dim"."d_date_sk") AND ("tpcds"."date_dim"."d_month_seq" BETWEEN 1189 AND (1189 + 11))) JOIN "tpcds"."customer" ON ("tpcds"."catalog_sales"."cs_bill_customer_sk" = "tpcds"."customer"."c_customer_sk")) ON "tpcds"."customer"."c_last_name" = "tpcds"."customer"."c_last_name" AND "tpcds"."customer"."c_first_name" = "tpcds"."customer"."c_first_name" AND "tpcds"."date_dim"."d_date" = "tpcds"."date_dim"."d_date") AS "cool_cust" LEFT ANTI JOIN (SELECT DISTINCT "tpcds"."customer"."c_last_name", "tpcds"."customer"."c_first_name", "tpcds"."date_dim"."d_date" FROM "tpcds"."web_sales" JOIN "tpcds"."date_dim" ON (("tpcds"."web_sales"."ws_sold_date_sk" = "tpcds"."date_dim"."d_date_sk") AND ("tpcds"."date_dim"."d_month_seq" BETWEEN 1189 AND (1189 + 11))) JOIN "tpcds"."customer" ON ("tpcds"."web_sales"."ws_bill_customer_sk" = "tpcds"."customer"."c_customer_sk")) ON "tpcds"."customer"."c_last_name" = "tpcds"."customer"."c_last_name" AND "tpcds"."customer"."c_first_name" = "tpcds"."customer"."c_first_name" AND "tpcds"."date_dim"."d_date" = "tpcds"."date_dim"."d_date" |
