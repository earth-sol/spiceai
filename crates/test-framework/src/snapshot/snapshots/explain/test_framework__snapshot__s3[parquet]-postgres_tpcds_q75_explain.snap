|               |                                 TableScan: item projection=[i_item_sk, i_brand_id, i_class_id, i_category_id, i_manufact_id], full_filters=[item.i_category = Utf8("Shoes")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  