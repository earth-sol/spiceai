|               |                             Filter: date_dim.d_month_seq BETWEEN Int64(1180) AND Int64(1180) + Int64(11) AND date_dim.d_date_sk = store_sales.ss_sold_date_sk AND store.s_store_sk = store_sales.ss_store_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  