|               |     CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |       VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=benchmarks-clickbench initial_sql=SELECT "hits"."URL", count(1) AS "PageViews" FROM "hits" WHERE (((((("hits"."CounterID" = 62) AND (to_timestamp(("hits"."EventDate" * 86400)) >= '2013-07-01')) AND (to_timestamp(("hits"."EventDate" * 86400)) <= '2013-07-31')) AND ("hits"."IsRefresh" = 0)) AND ("hits"."IsLink" <> 0)) AND ("hits"."IsDownload" = 0)) GROUP BY "hits"."URL" ORDER BY "PageViews" DESC NULLS FIRST LIMIT 10 OFFSET 1000 rewritten_sql=SELECT "URL", count(1) AS "PageViews" FROM "clickbench"."hits" WHERE (((((("hits"."CounterID" = 62) AND (to_timestamp(("hits"."EventDate" * 86400)) >= '2013-07-01')) AND (to_timestamp(("hits"."EventDate" * 86400)) <= '2013-07-31')) AND ("hits"."IsRefresh" = 0)) AND ("hits"."IsLink" <> 0)) AND ("hits"."IsDownload" = 0)) GROUP BY "hits"."URL" ORDER BY "PageViews" DESC NULLS FIRST LIMIT 10 OFFSET 1000 |
