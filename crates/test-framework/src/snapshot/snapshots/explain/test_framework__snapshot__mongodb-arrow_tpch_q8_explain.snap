|               |                           Inner Join: lineitem.l_orderkey = orders.o_orderkey                                                                                                                                                                                                                  |
|               |                             Projection: lineitem.l_extendedprice, lineitem.l_orderkey, lineitem.l_discount, supplier.s_nationkey                                                                                                                                                               |
|               |                               Inner Join: lineitem.l_suppkey = supplier.s_suppkey                                                                                                                                                                                                              |
