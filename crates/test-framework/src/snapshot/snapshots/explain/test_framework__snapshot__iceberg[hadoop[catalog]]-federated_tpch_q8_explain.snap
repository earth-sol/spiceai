|               |                               Inner Join: hadoop.tpch.lineitem.l_suppkey = hadoop.tpch.supplier.s_suppkey                                                                                                                                                                       |
|               |                                 Projection: hadoop.tpch.lineitem.l_orderkey, hadoop.tpch.lineitem.l_suppkey, hadoop.tpch.lineitem.l_extendedprice, hadoop.tpch.lineitem.l_discount                                                                                              |
|               |                                   Inner Join: hadoop.tpch.part.p_partkey = hadoop.tpch.lineitem.l_partkey                                                                                                                                                                       |
