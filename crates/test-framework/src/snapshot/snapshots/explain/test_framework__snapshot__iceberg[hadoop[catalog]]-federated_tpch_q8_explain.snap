|               |                       Inner Join: hadoop.tpch.orders.o_custkey = hadoop.tpch.customer.c_custkey                                                                                                                                                                                 |
|               |                         Projection: hadoop.tpch.lineitem.l_extendedprice, hadoop.tpch.lineitem.l_discount, hadoop.tpch.supplier.s_nationkey, hadoop.tpch.orders.o_custkey, hadoop.tpch.orders.o_orderdate                                                                       |
