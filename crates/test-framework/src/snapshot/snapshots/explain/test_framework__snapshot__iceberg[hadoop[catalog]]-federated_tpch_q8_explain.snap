| logical_plan  | Sort: all_nations.o_year ASC NULLS LAST                                                                                                                                                                                                                                         |
|               |   Projection: all_nations.o_year, sum(CASE WHEN all_nations.nation = Utf8("BRAZIL") THEN all_nations.volume ELSE Int64(0) END) / sum(all_nations.volume) AS mkt_share                                                                                                           |
|               |     Aggregate: groupBy=[[all_nations.o_year]], aggr=[[sum(CASE WHEN all_nations.nation = Utf8("BRAZIL") THEN all_nations.volume ELSE Float64(0) END) AS sum(CASE WHEN all_nations.nation = Utf8("BRAZIL") THEN all_nations.volume ELSE Int64(0) END), sum(all_nations.volume)]] |
|               |       SubqueryAlias: all_nations                                                                                                                                                                                                                                                |
|               |         Projection: date_part(Utf8("YEAR"), hadoop.tpch.orders.o_orderdate) AS o_year, hadoop.tpch.lineitem.l_extendedprice * (Float64(1) - hadoop.tpch.lineitem.l_discount) AS volume, n2.n_name AS nation                                                                     |
|               |           Inner Join: n1.n_regionkey = hadoop.tpch.region.r_regionkey                                                                                                                                                                                                           |
|               |             Projection: hadoop.tpch.lineitem.l_extendedprice, hadoop.tpch.lineitem.l_discount, hadoop.tpch.orders.o_orderdate, n1.n_regionkey, n2.n_name                                                                                                                        |
|               |               Inner Join: hadoop.tpch.supplier.s_nationkey = n2.n_nationkey                                                                                                                                                                                                     |
|               |                 Projection: hadoop.tpch.lineitem.l_extendedprice, hadoop.tpch.lineitem.l_discount, hadoop.tpch.supplier.s_nationkey, hadoop.tpch.orders.o_orderdate, n1.n_regionkey                                                                                             |
|               |                   Inner Join: hadoop.tpch.customer.c_nationkey = n1.n_nationkey                                                                                                                                                                                                 |
