| logical_plan        | Projection: Float64(100) * CAST(sum(CASE WHEN part.p_type LIKE $1 THEN lineitem.l_extendedprice * $2 - lineitem.l_discount ELSE $3 END) AS Float64) / CAST(sum(lineitem.l_extendedprice * $4 - lineitem.l_discount) AS Float64) AS promo_revenue |
|                     |   Aggregate: groupBy=[[]], aggr=[[sum(CASE WHEN part.p_type LIKE $1 THEN lineitem.l_extendedprice * ($2 - lineitem.l_discount) ELSE CAST($3 AS Decimal128(32, 4)) END), sum(lineitem.l_extendedprice * ($4 - lineitem.l_discount))]]             |
|                     |     Projection: lineitem.l_extendedprice, lineitem.l_discount, part.p_type                                                                                                                                                                       |
|                     |       Inner Join: lineitem.l_partkey = part.p_partkey                                                                                                                                                                                            |
|                     |         BytesProcessedNode                                                                                                                                                                                                                       |
|                     |           TableScan: lineitem projection=[l_partkey, l_extendedprice, l_discount], full_filters=[lineitem.l_shipdate >= Date32("1995-09-01"), lineitem.l_shipdate < Date32("1995-10-01")]                                                        |
|                     |         BytesProcessedNode                                                                                                                                                                                                                       |
|                     |           TableScan: part projection=[p_partkey, p_type]                                                                                                                                                                                         |
