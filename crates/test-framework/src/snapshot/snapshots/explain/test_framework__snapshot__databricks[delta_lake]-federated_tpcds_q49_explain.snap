| logical_plan  | Sort: channel ASC NULLS LAST, return_rank ASC NULLS LAST, currency_rank ASC NULLS LAST, item ASC NULLS LAST, fetch=100                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
