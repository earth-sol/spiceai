                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |           HashJoinExec: mode=Partitioned, join_type=Inner, accumulator=MinMaxLeftAccumulator, on=[(l_partkey@2, p_partkey@2)], filter=p_brand@1 = Brand#12 AND Use p_container@2 IN (SET) ([Literal { value: Utf8("SM CASE"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("SM BOX"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("SM PACK"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("SM PKG"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND l_quantity@0 >= Some(100),38,2 AND l_quantity@0 <= Some(1100),38,2 AND p_size@3 <= 5 OR p_brand@1 = Brand#23 AND Use p_container@2 IN (SET) ([Literal { value: Utf8("MED BAG"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("MED BOX"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("MED PKG"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("MED PACK"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND l_quantity@0 >= Some(1000),38,2 AND l_quantity@0 <= Some(2000),38,2 AND p_size@3 <= 10 OR p_brand@1 = Brand#34 AND Use p_container@2 IN (SET) ([Literal { value: Utf8("LG CASE"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("LG BOX"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, 