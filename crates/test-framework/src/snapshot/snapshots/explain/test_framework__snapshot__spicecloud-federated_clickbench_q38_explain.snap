|               |         TableScan: hits projection=[Title], full_filters=[hits.CounterID = Int64(62), to_timestamp(hits.EventDate * Int64(86400)) >= Utf8("2013-07-01"), to_timestamp(hits.EventDate * Int64(86400)) <= Utf8("2013-07-31"), hits.DontCountHits = Int64(0), hits.IsRefresh = Int64(0), hits.Title != Utf8("")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
