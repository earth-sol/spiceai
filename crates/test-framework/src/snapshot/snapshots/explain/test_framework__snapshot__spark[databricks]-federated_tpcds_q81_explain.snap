|               |     VirtualExecutionPlan name=SparkConnect compute_context=sc://dbc-f34ee0b7-90f2.cloud.databricks.com:443/;user_id=spice.ai;x-databricks-cluster-id=0711-151224-1rh2uz8m;use_ssl=true sql=SELECT customer.c_customer_id, customer.c_salutation, customer.c_first_name, customer.c_last_name, customer_address.ca_street_number, customer_address.ca_street_name, customer_address.ca_street_type, customer_address.ca_suite_number, customer_address.ca_city, customer_address.ca_county, customer_address.ca_state, customer_address.ca_zip, customer_address.ca_country, customer_address.ca_gmt_offset, customer_address.ca_location_type, ctr1.ctr_total_return FROM (SELECT catalog_returns.cr_returning_customer_sk AS ctr_customer_sk, customer_address.ca_state AS ctr_state, sum(catalog_returns.cr_return_amt_inc_tax) AS ctr_total_return FROM catalog_returns JOIN date_dim ON ((catalog_returns.cr_returned_date_sk = date_dim.d_date_sk) AND (date_dim.d_year = 1998)) JOIN customer_address ON (catalog_returns.cr_returning_addr_sk = customer_address.ca_address_sk) GROUP BY catalog_returns.cr_returning_customer_sk, customer_address.ca_state) AS ctr1 JOIN customer_address ON (customer_address.ca_state = 'TX') JOIN customer ON ((customer_address.ca_address_sk = customer.c_current_addr_sk) AND (ctr1.ctr_customer_sk = customer.c_customer_sk)) WHERE (ctr1.ctr_total_return > (SELECT (avg(ctr2.ctr_total_return) * 1.2) FROM (SELECT catalog_returns.cr_returning_customer_sk AS ctr_customer_sk, customer_address.ca_state AS ctr_state, sum(catalog_returns.cr_return_amt_inc_tax) AS ctr_total_return FROM catalog_returns JOIN date_dim ON true JOIN customer_address ON true WHERE (((catalog_returns.cr_returned_date_sk = date_dim.d_date_sk) AND (date_dim.d_year = 1998)) AND (catalog_returns.cr_returning_addr_sk = customer_address.ca_address_sk)) GROUP BY catalog_returns.cr_returning_customer_sk, customer_address.ca_state) AS ctr2 WHERE (ctr1.ctr_state = ctr2.ctr_state))) ORDER BY customer.c_customer_id ASC NULLS LAST, customer.c_salutation ASC NULLS LAST, customer.c_first_name ASC NULLS LAST, customer.c_last_name ASC NULLS LAST, customer_address.ca_street_number ASC NULLS LAST, customer_address.ca_street_name ASC NULLS LAST, customer_address.ca_street_type ASC NULLS LAST, customer_address.ca_suite_number ASC NULLS LAST, customer_address.ca_city ASC NULLS LAST, customer_address.ca_county ASC NULLS LAST, customer_address.ca_state ASC NULLS LAST, customer_address.ca_zip ASC NULLS LAST, customer_address.ca_country ASC NULLS LAST, customer_address.ca_gmt_offset ASC NULLS LAST, customer_address.ca_location_type ASC NULLS LAST, ctr1.ctr_total_return ASC NULLS LAST LIMIT 100 rewritten_sql=SELECT `spiceai_sandbox`.`tpcds`.`customer`.`c_customer_id`, `spiceai_sandbox`.`tpcds`.`customer`.`c_salutation`, `spiceai_sandbox`.`tpcds`.`customer`.`c_first_name`, `spiceai_sandbox`.`tpcds`.`customer`.`c_last_name`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_street_number`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_street_name`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_street_type`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_suite_number`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_city`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_county`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_state`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_zip`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_country`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_gmt_offset`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_location_type`, `ctr1`.`ctr_total_return` FROM (SELECT `spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_returning_customer_sk` AS `ctr_customer_sk`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_state` AS `ctr_state`, sum(`spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_return_amt_inc_tax`) AS `ctr_total_return` FROM `spiceai_sandbox`.`tpcds`.`catalog_returns` JOIN `spiceai_sandbox`.`tpcds`.`date_dim` ON ((`spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_returned_date_sk` = `spiceai_sandbox`.`tpcds`.`date_dim`.`d_date_sk`) AND (`spiceai_sandbox`.`tpcds`.`date_dim`.`d_year` = 1998)) JOIN `spiceai_sandbox`.`tpcds`.`customer_address` ON (`spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_returning_addr_sk` = `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_address_sk`) GROUP BY `spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_returning_customer_sk`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_state`) AS `ctr1` JOIN `spiceai_sandbox`.`tpcds`.`customer_address` ON (`spiceai_sandbox`.`tpcds`.`customer_address`.`ca_state` = 'TX') JOIN `spiceai_sandbox`.`tpcds`.`customer` ON ((`spiceai_sandbox`.`tpcds`.`customer_address`.`ca_address_sk` = `spiceai_sandbox`.`tpcds`.`customer`.`c_current_addr_sk`) AND (`ctr1`.`ctr_customer_sk` = `spiceai_sandbox`.`tpcds`.`customer`.`c_customer_sk`)) WHERE (`ctr1`.`ctr_total_return` > (SELECT (avg(`ctr2`.`ctr_total_return`) * 1.2) FROM (SELECT `spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_returning_customer_sk` AS `ctr_customer_sk`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_state` AS `ctr_state`, sum(`spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_return_amt_inc_tax`) AS `ctr_total_return` FROM `spiceai_sandbox`.`tpcds`.`catalog_returns` JOIN `spiceai_sandbox`.`tpcds`.`date_dim` ON true JOIN `spiceai_sandbox`.`tpcds`.`customer_address` ON true WHERE (((`spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_returned_date_sk` = `spiceai_sandbox`.`tpcds`.`date_dim`.`d_date_sk`) AND (`spiceai_sandbox`.`tpcds`.`date_dim`.`d_year` = 1998)) AND (`spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_returning_addr_sk` = `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_address_sk`)) GROUP BY `spiceai_sandbox`.`tpcds`.`catalog_returns`.`cr_returning_customer_sk`, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_state`) AS `ctr2` WHERE (`ctr1`.`ctr_state` = `ctr2`.`ctr_state`))) ORDER BY `spiceai_sandbox`.`tpcds`.`customer`.`c_customer_id` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer`.`c_salutation` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer`.`c_first_name` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer`.`c_last_name` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_street_number` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_street_name` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_street_type` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_suite_number` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_city` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_county` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_state` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_zip` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_country` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_gmt_offset` ASC NULLS LAST, `spiceai_sandbox`.`tpcds`.`customer_address`.`ca_location_type` ASC NULLS LAST, `ctr1`.`ctr_total_return` ASC NULLS LAST LIMIT 100 |
