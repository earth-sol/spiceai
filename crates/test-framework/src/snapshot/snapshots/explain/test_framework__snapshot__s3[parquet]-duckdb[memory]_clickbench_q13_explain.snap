| logical_plan  | Federated                                                                                                                                                                                                                                                        |
|               |  Limit: skip=0, fetch=10                                                                                                                                                                                                                                         |
|               |   Sort: c DESC NULLS FIRST                                                                                                                                                                                                                                       |
|               |     Projection: hits.SearchPhrase, count(Int64(1)) AS c                                                                                                                                                                                                          |
|               |       Aggregate: groupBy=[[hits.SearchPhrase]], aggr=[[count(Int64(1))]]                                                                                                                                                                                         |
|               |         Filter: CAST(hits.SearchPhrase AS Utf8View) != Utf8("")                                                                                                                                                                                                  |
|               |           TableScan: hits projection=[SearchPhrase]                                                                                                                                                                                                              |
| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                               |
|               |   CooperativeExec                                                                                                                                                                                                                                                |
|               |     BytesProcessedExec                                                                                                                                                                                                                                           |
|               |       VirtualExecutionPlan name=duckdb compute_context=:memory: initial_sql=SELECT "hits"."SearchPhrase", count(1) AS "c" FROM "hits" WHERE (CAST("hits"."SearchPhrase" AS VARCHAR) <> '') GROUP BY "hits"."SearchPhrase" ORDER BY "c" DESC NULLS FIRST LIMIT 10 |
