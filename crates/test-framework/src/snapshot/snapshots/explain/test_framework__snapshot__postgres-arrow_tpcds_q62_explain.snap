|               |                 Projection: web_sales.ws_sold_date_sk, web_sales.ws_ship_date_sk, web_sales.ws_web_site_sk, warehouse.w_warehouse_name, ship_mode.sm_type                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
