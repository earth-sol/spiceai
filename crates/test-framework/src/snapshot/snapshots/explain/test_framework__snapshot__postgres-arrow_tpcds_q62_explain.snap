| physical_plan | ProjectionExec: expr=[CAST(substr(warehouse.w_warehouse_name,Int64(1),Int64(20))@0 AS LargeUtf8) as substr(warehouse.w_warehouse_name,Int64(1),Int64(20)), sm_type@1 as sm_type, web_name@2 as web_name, 30 days@3 as 30 days, 31-60 days@4 as 31-60 days, 61-90 days@5 as 61-90 days, 91-120 days@6 as 91-120 days, >120 days@7 as >120 days]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
