|               |   Sort: c DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                      |
|               |     Projection: hits.WatchID, hits.ClientIP, count(Int64(1)) AS c, sum(hits.IsRefresh), avg(hits.ResolutionWidth)                                                                                                                                                                                                                                                                                               |
|               |       Aggregate: groupBy=[[hits.WatchID, hits.ClientIP]], aggr=[[count(Int64(1)), sum(hits.IsRefresh), avg(hits.ResolutionWidth)]]                                                                                                                                                                                                                                                                              |
|               |         TableScan: hits projection=[WatchID, ClientIP, IsRefresh, ResolutionWidth]                                                                                                                                                                                                                                                                                                                              |
| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                              |
|               |   CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                          |
|               |       VirtualExecutionPlan name=postgres compute_context=host=Tcp("benchmarking-postgres-rw.dataplatform.svc.cluster.local"),port=5432,db=clickbench_accelerated,user=postgres, initial_sql=SELECT "hits"."WatchID", "hits"."ClientIP", count(1) AS "c", sum("hits"."IsRefresh"), avg("hits"."ResolutionWidth") FROM "hits" GROUP BY "hits"."WatchID", "hits"."ClientIP" ORDER BY "c" DESC NULLS FIRST LIMIT 10 |
