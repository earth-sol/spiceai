                                                                                                                                                                                                          |
+---------------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |  Sort: tpch.tpch.supplier.s_name ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |   Projection: tpch.tpch.supplier.s_name, tpch.tpch.supplier.s_address                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |     Inner Join:  Filter: tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |       Filter: tpch.tpch.supplier.s_suppkey IN (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |         Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |           Projection: tpch.tpch.partsupp.ps_suppkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |             Filter: tpch.tpch.partsupp.ps_partkey IN (<subquery>) AND tpch.tpch.partsupp.ps_availqty > (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |               Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |                 Projection: tpch.tpch.part.p_partkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |                   Filter: tpch.tpch.part.p_name LIKE Utf8("forest%")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |                     TableScan: tpch.tpch.part                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |               Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |                 Projection: Float64(0.5) * sum(tpch.tpch.lineitem.l_quantity)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |                   Aggregate: groupBy=[[]], aggr=[[sum(tpch.tpch.lineitem.l_quantity)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |                     Filter: tpch.tpch.lineitem.l_partkey = outer_ref(tpch.tpch.partsupp.ps_partkey) AND tpch.tpch.lineitem.l_suppkey = outer_ref(tpch.tpch.partsupp.ps_suppkey) AND tpch.tpch.lineitem.l_shipdate >= CAST(Utf8("1994-01-01") AS Date32) AND tpch.tpch.lineitem.l_shipdate < CAST(Utf8("1994-01-01") AS Date32) + IntervalMonthDayNano("IntervalMonthDayNano { months: 12, days: 0, nanoseconds: 0 }")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |                       TableScan: tpch.tpch.lineitem                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |               TableScan: tpch.tpch.partsupp                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |         TableScan: tpch.tpch.supplier projection=[s_suppkey, s_name, s_address, s_nationkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |       TableScan: tpch.tpch.nation projection=[n_nationkey], full_filters=[tpch.tpch.nation.n_name = Utf8("CANADA")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT tpch.tpch.supplier.s_name, tpch.tpch.supplier.s_address FROM tpch.tpch.supplier JOIN tpch.tpch.nation ON ((tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey) AND (tpch.tpch.supplier.s_suppkey IN (SELECT tpch.tpch.partsupp.ps_suppkey FROM tpch.tpch.partsupp WHERE (tpch.tpch.partsupp.ps_partkey IN (SELECT tpch.tpch."part".p_partkey FROM tpch.tpch."part" WHERE tpch.tpch."part".p_name LIKE 'forest%') AND (tpch.tpch.partsupp.ps_availqty > (SELECT (0.5 * sum(tpch.tpch.lineitem.l_quantity)) FROM tpch.tpch.lineitem WHERE ((((tpch.tpch.lineitem.l_partkey = tpch.tpch.partsupp.ps_partkey) AND (tpch.tpch.lineitem.l_suppkey = tpch.tpch.partsupp.ps_suppkey)) AND (tpch.tpch.lineitem.l_shipdate >= CAST('1994-01-01' AS DATE))) AND (tpch.tpch.lineitem.l_shipdate < (CAST('1994-01-01' AS DATE) + INTERVAL '12 MONS'))))))) AND (tpch.tpch.nation.n_name = 'CANADA'))) ORDER BY tpch.tpch.supplier.s_name ASC NULLS LAST rewritten_sql=SELECT "spice"."tpch"."supplier"."s_name", "spice"."tpch"."supplier"."s_address" FROM "spice"."tpch"."supplier" JOIN "spice"."tpch"."nation" ON (("spice"."tpch"."supplier"."s_nationkey" = "spice"."tpch"."nation"."n_nationkey") AND ("spice"."tpch"."supplier"."s_suppkey" IN (SELECT "spice"."tpch"."partsupp"."ps_suppkey" FROM "spice"."tpch"."partsupp" WHERE ("spice"."tpch"."partsupp"."ps_partkey" IN (SELECT "spice"."tpch"."part"."p_partkey" FROM "spice"."tpch"."part" WHERE "spice"."tpch"."part"."p_name" LIKE 'forest%') AND ("spice"."tpch"."partsupp"."ps_availqty" > (SELECT (0.5 * sum("spice"."tpch"."lineitem"."l_quantity")) FROM "spice"."tpch"."lineitem" WHERE (((("spice"."tpch"."lineitem"."l_partkey" = "spice"."tpch"."partsupp"."ps_partkey") AND ("spice"."tpch"."lineitem"."l_suppkey" = "spice"."tpch"."partsupp"."ps_suppkey")) AND ("spice"."tpch"."lineitem"."l_shipdate" >= CAST('1994-01-01' AS DATE))) AND ("spice"."tpch"."lineitem"."l_shipdate" < (CAST('1994-01-01' AS DATE) + INTERVAL '12 MONS'))))))) AND ("spice"."tpch"."nation"."n_name" = 'CANADA'))) ORDER BY "spice"."tpch"."supplier"."s_name" ASC NULLS LAST |
