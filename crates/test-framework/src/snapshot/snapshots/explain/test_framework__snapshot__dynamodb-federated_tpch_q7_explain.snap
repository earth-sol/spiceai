|               |                   TableScan: nation projection=[n_name, n_nationkey], full_filters=[nation.n_name = Utf8("FRANCE") OR nation.n_name = Utf8("GERMANY")]                                                                                                                                                                                                                                                                                                                                                                               |
|               |             SubqueryAlias: n2                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
