---
+---------------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
+---------------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |  Projection: sum(tpch.tpch.lineitem.l_extendedprice) / Float64(7) AS avg_yearly                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |   Aggregate: groupBy=[[]], aggr=[[sum(tpch.tpch.lineitem.l_extendedprice)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |     Inner Join:  Filter: tpch.tpch.part.p_partkey = tpch.tpch.lineitem.l_partkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |       Filter: tpch.tpch.lineitem.l_quantity < (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |         Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |           Projection: Float64(0.2) * avg(tpch.tpch.lineitem.l_quantity)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |             Aggregate: groupBy=[[]], aggr=[[avg(tpch.tpch.lineitem.l_quantity)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |               Filter: tpch.tpch.lineitem.l_partkey = outer_ref(tpch.tpch.part.p_partkey)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |                 TableScan: tpch.tpch.lineitem                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |         TableScan: tpch.tpch.lineitem projection=[l_partkey, l_quantity, l_extendedprice]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |       TableScan: tpch.tpch.part projection=[p_partkey], full_filters=[tpch.tpch.part.p_brand = Utf8("Brand#23"), tpch.tpch.part.p_container = Utf8("MED BOX")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT (sum(lineitem.l_extendedprice) / 7.0) AS avg_yearly FROM tpch.tpch.lineitem JOIN tpch.tpch."part" ON (("part".p_partkey = lineitem.l_partkey) AND (((lineitem.l_quantity < (SELECT (0.2 * avg(lineitem.l_quantity)) FROM tpch.tpch.lineitem WHERE (lineitem.l_partkey = "part".p_partkey))) AND ("part".p_brand = 'Brand#23')) AND ("part".p_container = 'MED BOX'))) rewritten_sql=SELECT (sum("lineitem"."l_extendedprice") / 7.0) AS "avg_yearly" FROM "spice"."tpch"."lineitem" JOIN "spice"."tpch"."part" ON (("part"."p_partkey" = "lineitem"."l_partkey") AND ((("lineitem"."l_quantity" < (SELECT (0.2 * avg("lineitem"."l_quantity")) FROM "spice"."tpch"."lineitem" WHERE ("lineitem"."l_partkey" = "part"."p_partkey"))) AND ("part"."p_brand" = 'Brand#23')) AND ("part"."p_container" = 'MED BOX'))) |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
