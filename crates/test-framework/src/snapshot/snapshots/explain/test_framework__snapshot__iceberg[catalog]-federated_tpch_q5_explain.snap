|               |       AggregateExec: mode=FinalPartitioned, gby=[n_name@0 as n_name], aggr=[sum(ice.tpch_sf1.lineitem.l_extendedprice * Int64(1) - ice.tpch_sf1.lineitem.l_discount)]                                                                                                  |
