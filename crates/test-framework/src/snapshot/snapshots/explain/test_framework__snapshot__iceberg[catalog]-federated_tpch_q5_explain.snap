|               |                 Inner Join: ice.tpch_sf1.lineitem.l_suppkey = ice.tpch_sf1.supplier.s_suppkey, ice.tpch_sf1.customer.c_nationkey = ice.tpch_sf1.supplier.s_nationkey                                                                                                   |
|               |                   Projection: ice.tpch_sf1.customer.c_nationkey, ice.tpch_sf1.lineitem.l_suppkey, ice.tpch_sf1.lineitem.l_extendedprice, ice.tpch_sf1.lineitem.l_discount                                                                                              |
|               |                     Inner Join: ice.tpch_sf1.orders.o_orderkey = ice.tpch_sf1.lineitem.l_orderkey                                                                                                                                                                      |
|               |                       Projection: ice.tpch_sf1.customer.c_nationkey, ice.tpch_sf1.orders.o_orderkey                                                                                                                                                                    |
|               |                         Inner Join: ice.tpch_sf1.customer.c_custkey = ice.tpch_sf1.orders.o_custkey                                                                                                                                                                    |
