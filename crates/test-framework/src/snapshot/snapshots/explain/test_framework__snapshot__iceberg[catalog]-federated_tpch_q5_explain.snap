|               |                           Projection: ice.tpch_sf1.orders.o_orderkey, ice.tpch_sf1.orders.o_custkey                                                                                                                                                                    |
|               |                             Filter: ice.tpch_sf1.orders.o_orderdate >= Date32("1994-01-01") AND ice.tpch_sf1.orders.o_orderdate < Date32("1995-01-01")                                                                                                                 |
|               |                               TableScan: ice.tpch_sf1.orders projection=[o_orderkey, o_custkey, o_orderdate], partial_filters=[ice.tpch_sf1.orders.o_orderdate >= Date32("1994-01-01"), ice.tpch_sf1.orders.o_orderdate < Date32("1995-01-01")]                        |
|               |                       TableScan: ice.tpch_sf1.lineitem projection=[l_orderkey, l_suppkey, l_extendedprice, l_discount]                                                                                                                                                 |
|               |                   TableScan: ice.tpch_sf1.supplier projection=[s_suppkey, s_nationkey]                                                                                                                                                                                 |
|               |               TableScan: ice.tpch_sf1.nation projection=[n_nationkey, n_name, n_regionkey]                                                                                                                                                                             |
|               |           Projection: ice.tpch_sf1.region.r_regionkey                                                                                                                                                                                                                  |
|               |             Filter: ice.tpch_sf1.region.r_name = Utf8("ASIA")                                                                                                                                                                                                          |
