| logical_plan  | Sort: revenue DESC NULLS FIRST                                                                                                                                                                                                                                         |
|               |   Projection: ice.tpch_sf1.nation.n_name, sum(ice.tpch_sf1.lineitem.l_extendedprice * Int64(1) - ice.tpch_sf1.lineitem.l_discount) AS revenue                                                                                                                          |
|               |     Aggregate: groupBy=[[ice.tpch_sf1.nation.n_name]], aggr=[[sum(ice.tpch_sf1.lineitem.l_extendedprice * (Decimal128(Some(1),20,0) - ice.tpch_sf1.lineitem.l_discount)) AS sum(ice.tpch_sf1.lineitem.l_extendedprice * Int64(1) - ice.tpch_sf1.lineitem.l_discount)]] |
|               |       Projection: ice.tpch_sf1.lineitem.l_extendedprice, ice.tpch_sf1.lineitem.l_discount, ice.tpch_sf1.nation.n_name                                                                                                                                                  |
|               |         Inner Join: ice.tpch_sf1.nation.n_regionkey = ice.tpch_sf1.region.r_regionkey                                                                                                                                                                                  |
|               |           Projection: ice.tpch_sf1.lineitem.l_extendedprice, ice.tpch_sf1.lineitem.l_discount, ice.tpch_sf1.nation.n_name, ice.tpch_sf1.nation.n_regionkey                                                                                                             |
|               |             Inner Join: ice.tpch_sf1.supplier.s_nationkey = ice.tpch_sf1.nation.n_nationkey                                                                                                                                                                            |
