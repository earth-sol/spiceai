                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |                             TableScan: date_dim projection=[d_date_sk, d_year, d_moy], full_filters=[date_dim.d_year = Int64(2001) OR date_dim.d_year = Int64(2001) - Int64(1) AND date_dim.d_moy = Int64(12) OR date_dim.d_year = Int64(2001) + Int64(1) AND date_dim.d_moy = Int64(1)]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      