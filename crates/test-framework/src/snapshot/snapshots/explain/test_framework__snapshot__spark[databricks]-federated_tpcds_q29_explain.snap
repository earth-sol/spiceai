|               |               Filter: d3.d_year IN ([Int64(1999), Int64(1999) + Int64(1), Int64(1999) + Int64(2)])                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            