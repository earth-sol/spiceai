|               |                 Filter: d2.d_moy BETWEEN Int64(4) AND Int64(4) + Int64(3) AND d2.d_year = Int64(1999)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         