|               |           TableScan: item projection=[i_item_sk, i_item_id, i_item_desc]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |     VirtualExecutionPlan name=SparkConnect compute_context=sc://dbc-f34ee0b7-90f2.cloud.databricks.com:443/;user_id=spice.ai;x-databricks-cluster-id=0711-151224-1rh2uz8m;use_ssl=true sql=SELECT item.i_item_id, item.i_item_desc, store.s_store_id, store.s_store_name, min(store_sales.ss_net_profit) AS store_sales_profit, min(store_returns.sr_net_loss) AS store_returns_loss, min(catalog_sales.cs_net_profit) AS catalog_sales_profit FROM store_sales INNER JOIN store_returns ON (((store_sales.ss_customer_sk = store_returns.sr_customer_sk) AND (store_sales.ss_item_sk = store_returns.sr_item_sk)) AND (store_sales.ss_ticket_number = store_returns.sr_ticket_number)) INNER JOIN catalog_sales ON ((store_returns.sr_customer_sk = catalog_sales.cs_bill_customer_sk) AND (store_returns.sr_item_sk = catalog_sales.cs_item_sk)) INNER JOIN date_dim AS d1 ON ((d1.d_date_sk = store_sales.ss_sold_date_sk) AND ((d1.d_moy = 4) AND (d1.d_year = 2002))) INNER JOIN date_dim AS d2 ON ((store_returns.sr_returned_date_sk = d2.d_date_sk) AND ((d2.d_moy BETWEEN 4 AND 10) AND (d2.d_year = 2002))) INNER JOIN date_dim AS d3 ON ((catalog_sales.cs_sold_date_sk = d3.d_date_sk) AND ((d3.d_moy BETWEEN 4 AND 10) AND (d3.d_year = 2002))) INNER JOIN store ON (store.s_store_sk = store_sales.ss_store_sk) INNER JOIN item ON (item.i_item_sk = store_sales.ss_item_sk) GROUP BY item.i_item_id, item.i_item_desc, store.s_store_id, store.s_store_name ORDER BY item.i_item_id ASC NULLS LAST, item.i_item_desc ASC NULLS LAST, store.s_store_id ASC NULLS LAST, store.s_store_name ASC NULLS LAST LIMIT 100 rewritten_sql=SELECT `i_item_id`, `i_item_desc`, `s_store_id`, `s_store_name`, min(`store_sales`.`ss_net_profit`) AS `store_sales_profit`, min(`store_returns`.`sr_net_loss`) AS `store_returns_loss`, min(`catalog_sales`.`cs_net_profit`) AS `catalog_sales_profit` FROM `spiceai_sandbox`.`tpcds`.`store_sales` INNER JOIN `spiceai_sandbox`.`tpcds`.`store_returns` ON (((`store_sales`.`ss_customer_sk` = `store_returns`.`sr_customer_sk`) AND (`store_sales`.`ss_item_sk` = `store_returns`.`sr_item_sk`)) AND (`store_sales`.`ss_ticket_number` = `store_returns`.`sr_ticket_number`)) INNER JOIN `spiceai_sandbox`.`tpcds`.`catalog_sales` ON ((`store_returns`.`sr_customer_sk` = `catalog_sales`.`cs_bill_customer_sk`) AND (`store_returns`.`sr_item_sk` = `catalog_sales`.`cs_item_sk`)) INNER JOIN `spiceai_sandbox`.`tpcds`.`date_dim` AS `d1` ON ((`d1`.`d_date_sk` = `store_sales`.`ss_sold_date_sk`) AND ((`d1`.`d_moy` = 4) AND (`d1`.`d_year` = 2002))) INNER JOIN `spiceai_sandbox`.`tpcds`.`date_dim` AS `d2` ON ((`store_returns`.`sr_returned_date_sk` = `d2`.`d_date_sk`) AND ((`d2`.`d_moy` BETWEEN 4 AND 10) AND (`d2`.`d_year` = 2002))) INNER JOIN `spiceai_sandbox`.`tpcds`.`date_dim` AS `d3` ON ((`catalog_sales`.`cs_sold_date_sk` = `d3`.`d_date_sk`) AND ((`d3`.`d_moy` BETWEEN 4 AND 10) AND (`d3`.`d_year` = 2002))) INNER JOIN `spiceai_sandbox`.`tpcds`.`store` ON (`store`.`s_store_sk` = `store_sales`.`ss_store_sk`) INNER JOIN `spiceai_sandbox`.`tpcds`.`item` ON (`item`.`i_item_sk` = `store_sales`.`ss_item_sk`) GROUP BY `item`.`i_item_id`, `item`.`i_item_desc`, `store`.`s_store_id`, `store`.`s_store_name` ORDER BY `i_item_id` ASC NULLS LAST, `i_item_desc` ASC NULLS LAST, `s_store_id` ASC NULLS LAST, `s_store_name` ASC NULLS LAST LIMIT 100 |
