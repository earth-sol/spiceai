|               |                                   Inner Join: part.p_partkey = lineitem.l_partkey                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |                                     Projection: part.p_partkey                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |                                       BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |                                         Filter: part.p_type = Utf8("ECONOMY ANODIZED STEEL")                                                                                                                                                                                                                                                                                                                                                                                            |
