                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |                   FilterExec: (p_brand@1 = Brand#12 AND Use p_container@3 IN (SET) ([Literal { value: LargeUtf8("SM CASE"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("SM BOX"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("SM PACK"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("SM PKG"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND p_size@2 <= 5 OR p_brand@1 = Brand#23 AND Use p_container@3 IN (SET) ([Literal { value: LargeUtf8("MED BAG"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("MED BOX"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("MED PKG"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("MED PACK"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND p_size@2 <= 10 OR p_brand@1 = Brand#34 AND Use p_container@3 IN (SET) ([Literal { value: LargeUtf8("LG CASE"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("LG BOX"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("LG PACK"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("LG PKG"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND p_size@2 <= 15) AND p_size@2 >= 1                                                                                                                                                                                                                                                                                                                                                          |
