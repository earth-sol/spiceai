|               |                           DuckSqlExec sql= SELECT "l_partkey", "l_quantity", "l_extendedprice", "l_discount" FROM "expression=1995/lineitem" WHERE (((("l_shipmode" = 'AIR') OR ("l_shipmode" = 'AIR REG')) AND ("l_shipinstruct" = 'DELIVER IN PERSON')) AND (((("l_quantity" >= 1.00) AND ("l_quantity" <= 11.00)) OR (("l_quantity" >= 10.00) AND ("l_quantity" <= 20.00))) OR (("l_quantity" >= 20.00) AND ("l_quantity" <= 30.00)))) AND (("l_shipmode" = 'AIR') OR ("l_shipmode" = 'AIR REG')) AND ("l_shipinstruct" = 'DELIVER IN PERSON') AND (((("l_quantity" >= 1.00) AND ("l_quantity" <= 11.00)) OR (("l_quantity" >= 10.00) AND ("l_quantity" <= 20.00))) OR (("l_quantity" >= 20.00) AND ("l_quantity" <= 30.00)))                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              