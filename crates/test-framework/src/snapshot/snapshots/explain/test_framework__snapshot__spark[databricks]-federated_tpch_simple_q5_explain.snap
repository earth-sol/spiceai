|               |     VirtualExecutionPlan name=SparkConnect compute_context=sc://dbc-f34ee0b7-90f2.cloud.databricks.com:443/;user_id=spice.ai;x-databricks-cluster-id=0711-151224-1rh2uz8m;use_ssl=true sql=SELECT sum(o.o_totalprice) AS total_price, l.l_linestatus FROM orders AS o INNER JOIN lineitem AS l ON (o.o_orderkey = l.l_orderkey) GROUP BY l.l_linestatus ORDER BY total_price DESC NULLS FIRST rewritten_sql=SELECT sum(`o`.`o_totalprice`) AS `total_price`, `l`.`l_linestatus` FROM `spiceai_sandbox`.`tpch`.`orders` AS `o` INNER JOIN `spiceai_sandbox`.`tpch`.`lineitem` AS `l` ON (`o`.`o_orderkey` = `l`.`l_orderkey`) GROUP BY `l`.`l_linestatus` ORDER BY `total_price` DESC NULLS FIRST |
