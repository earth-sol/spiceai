source: crates/test-framework/src/snapshot/mod.rs
description: "Query: clickbench_q43"
---
+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |  Limit: skip=1000, fetch=10                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |   Sort: date_trunc(Utf8("minute"), M) ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     Projection: date_trunc(Utf8("minute"),to_timestamp(hits.EventTime)) AS M, count(Int64(1)) AS PageViews                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |       Aggregate: groupBy=[[date_trunc(Utf8("minute"), CAST(to_timestamp(hits.EventTime) AS Timestamp(Nanosecond, None)))]], aggr=[[count(Int64(1))]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |         TableScan: hits projection=[EventTime], full_filters=[hits.CounterID = Int64(62), to_timestamp(hits.EventDate * Int64(86400)) >= Utf8("2013-07-14"), to_timestamp(hits.EventDate * Int64(86400)) <= Utf8("2013-07-15"), hits.IsRefresh = Int64(0), hits.DontCountHits = Int64(0)]                                                                                                                                                                                                                                                                                                                                                         |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     VirtualExecutionPlan name=duckdb compute_context=//data/accelerated_duckdb.db initial_sql=SELECT date_trunc('minute', CAST(to_timestamp("hits"."EventTime") AS TIMESTAMP)) AS "M", count(1) AS "PageViews" FROM "hits" WHERE ((((("hits"."CounterID" = 62) AND (to_timestamp(("hits"."EventDate" * 86400)) >= '2013-07-14')) AND (to_timestamp(("hits"."EventDate" * 86400)) <= '2013-07-15')) AND ("hits"."IsRefresh" = 0)) AND ("hits"."DontCountHits" = 0)) GROUP BY date_trunc('minute', CAST(to_timestamp("hits"."EventTime") AS TIMESTAMP)) ORDER BY date_trunc('minute', "M") ASC NULLS LAST LIMIT 10 OFFSET 1000 |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
