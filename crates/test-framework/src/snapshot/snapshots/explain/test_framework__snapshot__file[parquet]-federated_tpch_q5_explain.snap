|               |               Filter: region.r_name = LargeUtf8("ASIA")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |                 TableScan: region projection=[r_regionkey, r_name], partial_filters=[region.r_name = LargeUtf8("ASIA")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
| physical_plan | SortPreservingMergeExec: [revenue@1 DESC]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
