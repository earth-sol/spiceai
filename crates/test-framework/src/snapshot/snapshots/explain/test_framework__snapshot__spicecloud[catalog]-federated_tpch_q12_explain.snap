---
+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |  Sort: tpch.tpch.lineitem.l_shipmode ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |   Projection: tpch.tpch.lineitem.l_shipmode, sum(CASE WHEN tpch.tpch.orders.o_orderpriority = Utf8("1-URGENT") OR tpch.tpch.orders.o_orderpriority = Utf8("2-HIGH") THEN Int64(1) ELSE Int64(0) END) AS high_line_count, sum(CASE WHEN tpch.tpch.orders.o_orderpriority != Utf8("1-URGENT") AND tpch.tpch.orders.o_orderpriority != Utf8("2-HIGH") THEN Int64(1) ELSE Int64(0) END) AS low_line_count                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |     Aggregate: groupBy=[[tpch.tpch.lineitem.l_shipmode]], aggr=[[sum(CASE WHEN tpch.tpch.orders.o_orderpriority = Utf8("1-URGENT") OR tpch.tpch.orders.o_orderpriority = Utf8("2-HIGH") THEN Int64(1) ELSE Int64(0) END), sum(CASE WHEN tpch.tpch.orders.o_orderpriority != Utf8("1-URGENT") AND tpch.tpch.orders.o_orderpriority != Utf8("2-HIGH") THEN Int64(1) ELSE Int64(0) END)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |       Inner Join:  Filter: tpch.tpch.lineitem.l_orderkey = tpch.tpch.orders.o_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |         Filter: tpch.tpch.lineitem.l_receiptdate >= CAST(Utf8("1994-01-01") AS Date32) AND tpch.tpch.lineitem.l_receiptdate < CAST(Utf8("1995-01-01") AS Date32)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |           TableScan: tpch.tpch.lineitem projection=[l_orderkey, l_receiptdate, l_shipmode], full_filters=[tpch.tpch.lineitem.l_shipmode IN ([Utf8("MAIL"), Utf8("SHIP")]), tpch.tpch.lineitem.l_commitdate < tpch.tpch.lineitem.l_receiptdate, tpch.tpch.lineitem.l_shipdate < tpch.tpch.lineitem.l_commitdate]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |         TableScan: tpch.tpch.orders projection=[o_orderkey, o_orderpriority]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |   CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |       VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch initial_sql=SELECT "l_shipmode", sum(CASE WHEN (("orders"."o_orderpriority" = '1-URGENT') OR ("orders"."o_orderpriority" = '2-HIGH')) THEN 1 ELSE 0 END) AS "high_line_count", sum(CASE WHEN (("orders"."o_orderpriority" <> '1-URGENT') AND ("orders"."o_orderpriority" <> '2-HIGH')) THEN 1 ELSE 0 END) AS "low_line_count" FROM "tpch"."tpch"."lineitem" INNER JOIN "tpch"."tpch"."orders" ON (("lineitem"."l_orderkey" = "orders"."o_orderkey") AND ((((("lineitem"."l_receiptdate" >= CAST('1994-01-01' AS DATE)) AND ("lineitem"."l_receiptdate" < CAST('1995-01-01' AS DATE))) AND "lineitem"."l_shipmode" IN ('MAIL', 'SHIP')) AND ("lineitem"."l_commitdate" < "lineitem"."l_receiptdate")) AND ("lineitem"."l_shipdate" < "lineitem"."l_commitdate"))) GROUP BY "lineitem"."l_shipmode" ORDER BY "l_shipmode" ASC NULLS LAST rewritten_sql=SELECT "l_shipmode", sum(CASE WHEN (("orders"."o_orderpriority" = '1-URGENT') OR ("orders"."o_orderpriority" = '2-HIGH')) THEN 1 ELSE 0 END) AS "high_line_count", sum(CASE WHEN (("orders"."o_orderpriority" <> '1-URGENT') AND ("orders"."o_orderpriority" <> '2-HIGH')) THEN 1 ELSE 0 END) AS "low_line_count" FROM "spice"."tpch"."lineitem" INNER JOIN "spice"."tpch"."orders" ON (("lineitem"."l_orderkey" = "orders"."o_orderkey") AND ((((("lineitem"."l_receiptdate" >= CAST('1994-01-01' AS DATE)) AND ("lineitem"."l_receiptdate" < CAST('1995-01-01' AS DATE))) AND "lineitem"."l_shipmode" IN ('MAIL', 'SHIP')) AND ("lineitem"."l_commitdate" < "lineitem"."l_receiptdate")) AND ("lineitem"."l_shipdate" < "lineitem"."l_commitdate"))) GROUP BY "lineitem"."l_shipmode" ORDER BY "l_shipmode" ASC NULLS LAST |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
