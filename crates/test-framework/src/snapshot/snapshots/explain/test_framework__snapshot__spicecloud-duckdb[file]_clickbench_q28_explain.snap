+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                    |
+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                      |
|               |   Federated                                                                                                                                                                                                                                                                                                                                             |
|               |  Limit: skip=0, fetch=25                                                                                                                                                                                                                                                                                                                                |
|               |   Sort: l DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                              |
|               |     Projection: hits.CounterID, avg(character_length(hits.URL)) AS l, count(Int64(1)) AS c                                                                                                                                                                                                                                                              |
|               |       Filter: count(Int64(1)) > Int64(100000)                                                                                                                                                                                                                                                                                                           |
|               |         Aggregate: groupBy=[[hits.CounterID]], aggr=[[avg(character_length(hits.URL)), count(Int64(1))]]                                                                                                                                                                                                                                                |
|               |           Filter: CAST(hits.URL AS Utf8View) != Utf8("")                                                                                                                                                                                                                                                                                                |
|               |             TableScan: hits projection=[CounterID, URL]                                                                                                                                                                                                                                                                                                 |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                      |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                    |
|               |     CooperativeExec                                                                                                                                                                                                                                                                                                                                     |
|               |       VirtualExecutionPlan name=duckdb compute_context=//data/accelerated_duckdb.db initial_sql=SELECT "hits"."CounterID", avg(length("hits"."URL")) AS "l", count(1) AS "c" FROM "hits" WHERE (CAST("hits"."URL" AS VARCHAR) <> '') GROUP BY "hits"."CounterID" HAVING (count(1) > 100000) ORDER BY "l" DESC NULLS FIRST LIMIT 25 |
|               |                                                                                                                                                                                                                                                                                                                                                         |
