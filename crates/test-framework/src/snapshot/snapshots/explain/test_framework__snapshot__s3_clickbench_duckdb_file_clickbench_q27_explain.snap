|               |     VirtualExecutionPlan name=duckdb compute_context=/tmp/.tmptNBFik/.spice/data/accelerated_duckdb.db sql=SELECT SearchPhrase FROM (SELECT hits.SearchPhrase, hits.EventTime FROM hits WHERE (hits.SearchPhrase <> '') ORDER BY to_timestamp(hits.EventTime) ASC NULLS LAST, hits.SearchPhrase ASC NULLS LAST) LIMIT 10 rewritten_sql=SELECT "SearchPhrase" FROM (SELECT "hits"."SearchPhrase", "hits"."EventTime" FROM "hits" WHERE ("hits"."SearchPhrase" <> '') ORDER BY to_timestamp("hits"."EventTime") ASC NULLS LAST, "hits"."SearchPhrase" ASC NULLS LAST) LIMIT 10 |
