| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
+---------------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |  Sort: tpch.tpch.orders.o_orderpriority ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |   Projection: tpch.tpch.orders.o_orderpriority, count(Int64(1)) AS order_count                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |     Aggregate: groupBy=[[tpch.tpch.orders.o_orderpriority]], aggr=[[count(Int64(1))]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |       Filter: tpch.tpch.orders.o_orderdate < CAST(Utf8("1993-07-01") AS Date32) + IntervalMonthDayNano("IntervalMonthDayNano { months: 3, days: 0, nanoseconds: 0 }") AND EXISTS (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |         Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |           Projection: tpch.tpch.lineitem.l_orderkey, tpch.tpch.lineitem.l_partkey, tpch.tpch.lineitem.l_suppkey, tpch.tpch.lineitem.l_linenumber, tpch.tpch.lineitem.l_quantity, tpch.tpch.lineitem.l_extendedprice, tpch.tpch.lineitem.l_discount, tpch.tpch.lineitem.l_tax, tpch.tpch.lineitem.l_returnflag, tpch.tpch.lineitem.l_linestatus, tpch.tpch.lineitem.l_shipdate, tpch.tpch.lineitem.l_commitdate, tpch.tpch.lineitem.l_receiptdate, tpch.tpch.lineitem.l_shipinstruct, tpch.tpch.lineitem.l_shipmode, tpch.tpch.lineitem.l_comment                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |             Filter: tpch.tpch.lineitem.l_orderkey = outer_ref(tpch.tpch.orders.o_orderkey) AND tpch.tpch.lineitem.l_commitdate < tpch.tpch.lineitem.l_receiptdate                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |               TableScan: tpch.tpch.lineitem                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |         TableScan: tpch.tpch.orders projection=[o_orderkey, o_orderdate, o_orderpriority], full_filters=[tpch.tpch.orders.o_orderdate >= Utf8("1993-07-01")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT o_orderpriority, count(1) AS order_count FROM tpch.tpch.orders WHERE ((orders.o_orderdate < (CAST('1993-07-01' AS DATE) + INTERVAL '3 MONS')) AND EXISTS (SELECT l_orderkey, l_partkey, l_suppkey, l_linenumber, l_quantity, l_extendedprice, l_discount, l_tax, l_returnflag, l_linestatus, l_shipdate, l_commitdate, l_receiptdate, l_shipinstruct, l_shipmode, l_comment FROM tpch.tpch.lineitem WHERE ((lineitem.l_orderkey = orders.o_orderkey) AND (lineitem.l_commitdate < lineitem.l_receiptdate)))) AND (orders.o_orderdate >= '1993-07-01') GROUP BY orders.o_orderpriority ORDER BY o_orderpriority ASC NULLS LAST rewritten_sql=SELECT "o_orderpriority", count(1) AS "order_count" FROM "spice"."tpch"."orders" WHERE (("orders"."o_orderdate" < (CAST('1993-07-01' AS DATE) + INTERVAL '3 MONS')) AND EXISTS (SELECT "l_orderkey", "l_partkey", "l_suppkey", "l_linenumber", "l_quantity", "l_extendedprice", "l_discount", "l_tax", "l_returnflag", "l_linestatus", "l_shipdate", "l_commitdate", "l_receiptdate", "l_shipinstruct", "l_shipmode", "l_comment" FROM "spice"."tpch"."lineitem" WHERE (("lineitem"."l_orderkey" = "orders"."o_orderkey") AND ("lineitem"."l_commitdate" < "lineitem"."l_receiptdate")))) AND ("orders"."o_orderdate" >= '1993-07-01') GROUP BY "orders"."o_orderpriority" ORDER BY "o_orderpriority" ASC NULLS LAST |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
