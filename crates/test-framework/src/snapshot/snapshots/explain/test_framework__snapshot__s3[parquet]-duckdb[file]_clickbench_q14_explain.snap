+---------------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                           |
+---------------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                             |
|               |   Federated                                                                                                                                                                                                                                                                                                                    |
|               |  Limit: skip=0, fetch=10                                                                                                                                                                                                                                                                                                       |
|               |   Sort: u DESC NULLS FIRST                                                                                                                                                                                                                                                                                                     |
|               |     Projection: hits.SearchPhrase, count(DISTINCT hits.UserID) AS u                                                                                                                                                                                                                                                            |
|               |       Aggregate: groupBy=[[hits.SearchPhrase]], aggr=[[count(DISTINCT hits.UserID)]]                                                                                                                                                                                                                                           |
|               |         Filter: CAST(hits.SearchPhrase AS Utf8) != Utf8("")                                                                                                                                                                                                                                                                    |
|               |           TableScan: hits projection=[UserID, SearchPhrase]                                                                                                                                                                                                                                                                    |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                             |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                           |
|               |     VirtualExecutionPlan name=duckdb compute_context=//data/accelerated_duckdb.db initial_sql=SELECT "hits"."SearchPhrase", count(DISTINCT "hits"."UserID") AS "u" FROM "hits" WHERE (CAST("hits"."SearchPhrase" AS VARCHAR) <> '') GROUP BY "hits"."SearchPhrase" ORDER BY "u" DESC NULLS FIRST LIMIT 10 |
|               |                                                                                                                                                                                                                                                                                                                                |
