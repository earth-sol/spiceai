|               |       VirtualExecutionPlan name=duckdb compute_context=:memory: initial_sql=SELECT "SearchPhrase" FROM (SELECT "hits"."SearchPhrase", "hits"."EventTime" FROM "hits" WHERE (CAST("hits"."SearchPhrase" AS VARCHAR) <> '') ORDER BY to_timestamp("hits"."EventTime") ASC NULLS LAST, "hits"."SearchPhrase" ASC NULLS LAST) LIMIT 10 |
