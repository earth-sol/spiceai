|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=benchmarks-clickbench sql=SELECT hits.UserID, hits.SearchPhrase, count(1) AS "count(*)" FROM hits GROUP BY hits.UserID, hits.SearchPhrase ORDER BY "count(*)" DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT "UserID", "SearchPhrase", count(1) AS "count(*)" FROM "clickbench"."hits" GROUP BY "hits"."UserID", "hits"."SearchPhrase" ORDER BY "count(*)" DESC NULLS FIRST LIMIT 10 |
