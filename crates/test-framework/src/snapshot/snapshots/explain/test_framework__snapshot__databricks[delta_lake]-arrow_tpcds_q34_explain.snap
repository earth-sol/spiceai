|               |                     Filter: (household_demographics.hd_buy_potential = Utf8("501-1000") OR household_demographics.hd_buy_potential = Utf8("Unknown")) AND household_demographics.hd_vehicle_count > Int32(0) AND CAST(CASE WHEN household_demographics.hd_vehicle_count > Int32(0) THEN household_demographics.hd_dep_count / household_demographics.hd_vehicle_count ELSE Int32(NULL) END AS Float64) > Float64(1.2)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
