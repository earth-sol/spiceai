|               |                             Filter: (date_dim.d_dom >= Int32(1) AND date_dim.d_dom <= Int32(3) OR date_dim.d_dom >= Int32(25) AND date_dim.d_dom <= Int32(28)) AND (date_dim.d_year = Int32(2000) OR date_dim.d_year = Int32(2001) OR date_dim.d_year = Int32(2002))                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
