|               |     VirtualExecutionPlan name=sqlite compute_context=/tmp/.tmpcHLWhJ/.spice/data/accelerated_sqlite.db sql=SELECT hits.SearchEngineID, hits.SearchPhrase, count(*) AS c FROM hits WHERE (hits.SearchPhrase <> '') GROUP BY hits.SearchEngineID, hits.SearchPhrase ORDER BY c DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT `hits`.`SearchEngineID`, `hits`.`SearchPhrase`, count(*) AS `c` FROM `hits` WHERE (`hits`.`SearchPhrase` <> '') GROUP BY `hits`.`SearchEngineID`, `hits`.`SearchPhrase` ORDER BY `c` DESC NULLS FIRST LIMIT 10 |
