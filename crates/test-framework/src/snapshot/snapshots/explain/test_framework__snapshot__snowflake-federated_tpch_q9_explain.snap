| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
+---------------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |  Sort: PROFIT.NATION ASC NULLS LAST, PROFIT.O_YEAR DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |   Projection: PROFIT.NATION, PROFIT.O_YEAR, sum(PROFIT.AMOUNT) AS SUM_PROFIT                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |     Aggregate: groupBy=[[PROFIT.NATION, PROFIT.O_YEAR]], aggr=[[sum(PROFIT.AMOUNT)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |       SubqueryAlias: PROFIT                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |         Projection: nation.N_NAME AS NATION, date_part(Utf8("YEAR"), orders.O_ORDERDATE) AS O_YEAR, lineitem.L_EXTENDEDPRICE * (Int64(1) - lineitem.L_DISCOUNT) - partsupp.PS_SUPPLYCOST * lineitem.L_QUANTITY AS AMOUNT                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |           Inner Join:  Filter: supplier.S_NATIONKEY = nation.N_NATIONKEY                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |             Inner Join:  Filter: orders.O_ORDERKEY = lineitem.L_ORDERKEY                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |               Inner Join:  Filter: partsupp.PS_SUPPKEY = lineitem.L_SUPPKEY AND partsupp.PS_PARTKEY = lineitem.L_PARTKEY                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |                 Inner Join:  Filter: supplier.S_SUPPKEY = lineitem.L_SUPPKEY AND part.P_PARTKEY = lineitem.L_PARTKEY                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |                   Cross Join:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |                     Filter: part.P_NAME LIKE Utf8("%green%")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |                       TableScan: part projection=[P_PARTKEY, P_NAME]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |                     TableScan: supplier projection=[S_SUPPKEY, S_NATIONKEY]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |                   TableScan: lineitem projection=[L_ORDERKEY, L_PARTKEY, L_SUPPKEY, L_QUANTITY, L_EXTENDEDPRICE, L_DISCOUNT]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |                 TableScan: partsupp projection=[PS_PARTKEY, PS_SUPPKEY, PS_SUPPLYCOST]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |               TableScan: orders projection=[O_ORDERKEY, O_ORDERDATE]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |             TableScan: nation projection=[N_NATIONKEY, N_NAME]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     VirtualExecutionPlan name=snowflake compute_context=username=sergei,account=CDQYZFU-SH58225 sql=SELECT PROFIT.NATION, PROFIT.O_YEAR, sum(PROFIT.AMOUNT) AS SUM_PROFIT FROM (SELECT nation.N_NAME AS NATION, date_part('YEAR', orders.O_ORDERDATE) AS O_YEAR, ((lineitem.L_EXTENDEDPRICE * (1 - lineitem.L_DISCOUNT)) - (partsupp.PS_SUPPLYCOST * lineitem.L_QUANTITY)) AS AMOUNT FROM "part" JOIN supplier ON "part".P_NAME LIKE '%green%' JOIN lineitem ON ((supplier.S_SUPPKEY = lineitem.L_SUPPKEY) AND ("part".P_PARTKEY = lineitem.L_PARTKEY)) JOIN partsupp ON ((partsupp.PS_SUPPKEY = lineitem.L_SUPPKEY) AND (partsupp.PS_PARTKEY = lineitem.L_PARTKEY)) JOIN orders ON (orders.O_ORDERKEY = lineitem.L_ORDERKEY) JOIN nation ON (supplier.S_NATIONKEY = nation.N_NATIONKEY)) AS PROFIT GROUP BY PROFIT.NATION, PROFIT.O_YEAR ORDER BY PROFIT.NATION ASC NULLS LAST, PROFIT.O_YEAR DESC NULLS FIRST rewritten_sql=SELECT "PROFIT"."NATION", "PROFIT"."O_YEAR", sum("PROFIT"."AMOUNT") AS "SUM_PROFIT" FROM (SELECT "NATION"."N_NAME" AS "NATION", date_part('YEAR', "ORDERS"."O_ORDERDATE") AS "O_YEAR", (("LINEITEM"."L_EXTENDEDPRICE" * (1 - "LINEITEM"."L_DISCOUNT")) - ("PARTSUPP"."PS_SUPPLYCOST" * "LINEITEM"."L_QUANTITY")) AS "AMOUNT" FROM "BENCHMARKS"."TPCH_SF1"."PART" JOIN "BENCHMARKS"."TPCH_SF1"."SUPPLIER" ON "PART"."P_NAME" LIKE '%green%' JOIN "BENCHMARKS"."TPCH_SF1"."LINEITEM" ON (("SUPPLIER"."S_SUPPKEY" = "LINEITEM"."L_SUPPKEY") AND ("PART"."P_PARTKEY" = "LINEITEM"."L_PARTKEY")) JOIN "BENCHMARKS"."TPCH_SF1"."PARTSUPP" ON (("PARTSUPP"."PS_SUPPKEY" = "LINEITEM"."L_SUPPKEY") AND ("PARTSUPP"."PS_PARTKEY" = "LINEITEM"."L_PARTKEY")) JOIN "BENCHMARKS"."TPCH_SF1"."ORDERS" ON ("ORDERS"."O_ORDERKEY" = "LINEITEM"."L_ORDERKEY") JOIN "BENCHMARKS"."TPCH_SF1"."NATION" ON ("SUPPLIER"."S_NATIONKEY" = "NATION"."N_NATIONKEY")) AS "PROFIT" GROUP BY "PROFIT"."NATION", "PROFIT"."O_YEAR" ORDER BY "PROFIT"."NATION" ASC NULLS LAST, "PROFIT"."O_YEAR" DESC NULLS FIRST |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
