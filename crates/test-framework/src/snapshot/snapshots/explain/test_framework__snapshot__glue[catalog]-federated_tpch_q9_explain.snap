| logical_plan  | Sort: profit.nation ASC NULLS LAST, profit.o_year DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |   Projection: profit.nation, profit.o_year, sum(profit.amount) AS sum_profit                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     Aggregate: groupBy=[[profit.nation, profit.o_year]], aggr=[[sum(profit.amount)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |       SubqueryAlias: profit                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |         Projection: glue.tpch.nation.n_name AS nation, date_part(Utf8("YEAR"), glue.tpch.orders.o_orderdate) AS o_year, glue.tpch.lineitem.l_extendedprice * (Decimal128(Some(1),20,0) - glue.tpch.lineitem.l_discount) - glue.tpch.partsupp.ps_supplycost * glue.tpch.lineitem.l_quantity AS amount                                                                                                                                                                                                                                                                       |
|               |           Inner Join: glue.tpch.supplier.s_nationkey = glue.tpch.nation.n_nationkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |             Projection: glue.tpch.lineitem.l_quantity, glue.tpch.lineitem.l_extendedprice, glue.tpch.lineitem.l_discount, glue.tpch.supplier.s_nationkey, glue.tpch.partsupp.ps_supplycost, glue.tpch.orders.o_orderdate                                                                                                                                                                                                                                                                                                                                                   |
|               |               Inner Join: glue.tpch.lineitem.l_orderkey = glue.tpch.orders.o_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |                 Projection: glue.tpch.lineitem.l_orderkey, glue.tpch.lineitem.l_quantity, glue.tpch.lineitem.l_extendedprice, glue.tpch.lineitem.l_discount, glue.tpch.supplier.s_nationkey, glue.tpch.partsupp.ps_supplycost                                                                                                                                                                                                                                                                                                                                              |
|               |                   Inner Join: glue.tpch.lineitem.l_suppkey = glue.tpch.partsupp.ps_suppkey, glue.tpch.lineitem.l_partkey = glue.tpch.partsupp.ps_partkey                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |                     Projection: glue.tpch.lineitem.l_orderkey, glue.tpch.lineitem.l_partkey, glue.tpch.lineitem.l_suppkey, glue.tpch.lineitem.l_quantity, glue.tpch.lineitem.l_extendedprice, glue.tpch.lineitem.l_discount, glue.tpch.supplier.s_nationkey                                                                                                                                                                                                                                                                                                                |
|               |                       Inner Join: glue.tpch.lineitem.l_suppkey = glue.tpch.supplier.s_suppkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |                         Projection: glue.tpch.lineitem.l_orderkey, glue.tpch.lineitem.l_partkey, glue.tpch.lineitem.l_suppkey, glue.tpch.lineitem.l_quantity, glue.tpch.lineitem.l_extendedprice, glue.tpch.lineitem.l_discount                                                                                                                                                                                                                                                                                                                                            |
|               |                           Inner Join: glue.tpch.part.p_partkey = glue.tpch.lineitem.l_partkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |                             Projection: glue.tpch.part.p_partkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |                               Filter: glue.tpch.part.p_name LIKE LargeUtf8("%green%")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |                                 TableScan: glue.tpch.part projection=[p_partkey, p_name], partial_filters=[glue.tpch.part.p_name LIKE LargeUtf8("%green%")]                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |                             TableScan: glue.tpch.lineitem projection=[l_orderkey, l_partkey, l_suppkey, l_quantity, l_extendedprice, l_discount]                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |                         TableScan: glue.tpch.supplier projection=[s_suppkey, s_nationkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
