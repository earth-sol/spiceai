|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=benchmarks-clickbench initial_sql=SELECT "hits"."MobilePhoneModel", count(DISTINCT "hits"."UserID") AS "u" FROM "hits" WHERE ("hits"."MobilePhoneModel" <> '') GROUP BY "hits"."MobilePhoneModel" ORDER BY "u" DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT "MobilePhoneModel", count(DISTINCT "hits"."UserID") AS "u" FROM "clickbench"."hits" WHERE ("hits"."MobilePhoneModel" <> '') GROUP BY "hits"."MobilePhoneModel" ORDER BY "u" DESC NULLS FIRST LIMIT 10 |
