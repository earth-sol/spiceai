|               |         TableScan: hits projection=[URL], full_filters=[hits.CounterID = Int64(62), to_timestamp(hits.EventDate * Int64(86400)) >= Utf8("2013-07-01"), to_timestamp(hits.EventDate * Int64(86400)) <= Utf8("2013-07-31"), hits.DontCountHits = Int64(0), hits.IsRefresh = Int64(0), hits.URL != Utf8("")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |     VirtualExecutionPlan name=duckdb compute_context=/tmp/.tmptNBFik/.spice/data/accelerated_duckdb.db sql=SELECT hits."URL", count(*) AS PageViews FROM hits WHERE ((((((hits.CounterID = 62) AND (to_timestamp((hits.EventDate * 86400)) >= '2013-07-01')) AND (to_timestamp((hits.EventDate * 86400)) <= '2013-07-31')) AND (hits.DontCountHits = 0)) AND (hits.IsRefresh = 0)) AND (hits."URL" <> '')) GROUP BY hits."URL" ORDER BY PageViews DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT "hits"."URL", count(*) AS "PageViews" FROM "hits" WHERE (((((("hits"."CounterID" = 62) AND (to_timestamp(("hits"."EventDate" * 86400)) >= '2013-07-01')) AND (to_timestamp(("hits"."EventDate" * 86400)) <= '2013-07-31')) AND ("hits"."DontCountHits" = 0)) AND ("hits"."IsRefresh" = 0)) AND ("hits"."URL" <> '')) GROUP BY "hits"."URL" ORDER BY "PageViews" DESC NULLS FIRST LIMIT 10 |
