|               |     VirtualExecutionPlan name=odbc compute_context=1a8146b4d5cb2fb49248bc1d023f10464a26c759193a65f9a00bccd72f2a2080 sql=SELECT sum(o.o_totalprice) AS total_price, l.l_linestatus FROM orders AS o INNER JOIN lineitem AS l ON (o.o_orderkey = l.l_orderkey) GROUP BY l.l_linestatus ORDER BY total_price DESC NULLS FIRST rewritten_sql=SELECT sum(`o`.`o_totalprice`) AS `total_price`, `l`.`l_linestatus` FROM `spiceai_sandbox`.`tpch`.`orders` AS `o` INNER JOIN `spiceai_sandbox`.`tpch`.`lineitem` AS `l` ON (`o`.`o_orderkey` = `l`.`l_orderkey`) GROUP BY `l`.`l_linestatus` ORDER BY `total_price` DESC NULLS FIRST |
