|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=benchmarks-clickbench sql=SELECT hits.RegionID, sum(hits.AdvEngineID), count(*) AS c, avg(hits.ResolutionWidth), count(DISTINCT hits.UserID) FROM hits GROUP BY hits.RegionID ORDER BY c DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT "RegionID", sum("hits"."AdvEngineID"), count(*) AS "c", avg("hits"."ResolutionWidth"), count(DISTINCT "hits"."UserID") FROM "clickbench"."hits" GROUP BY "hits"."RegionID" ORDER BY "c" DESC NULLS FIRST LIMIT 10 |
