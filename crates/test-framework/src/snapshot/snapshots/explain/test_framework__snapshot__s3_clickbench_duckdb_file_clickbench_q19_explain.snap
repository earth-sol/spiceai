|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     VirtualExecutionPlan name=duckdb compute_context=/tmp/.tmptNBFik/.spice/data/accelerated_duckdb.db sql=SELECT hits.UserID, date_part('MINUTE', CAST(to_timestamp(hits.EventTime) AS TIMESTAMP)) AS m, hits.SearchPhrase, count(*) FROM hits GROUP BY hits.UserID, date_part('MINUTE', CAST(to_timestamp(hits.EventTime) AS TIMESTAMP)), hits.SearchPhrase ORDER BY count(*) DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT "hits"."UserID", date_part('MINUTE', CAST(to_timestamp("hits"."EventTime") AS TIMESTAMP)) AS "m", "hits"."SearchPhrase", count(*) FROM "hits" GROUP BY "hits"."UserID", date_part('MINUTE', CAST(to_timestamp("hits"."EventTime") AS TIMESTAMP)), "hits"."SearchPhrase" ORDER BY count(*) DESC NULLS FIRST LIMIT 10 |
