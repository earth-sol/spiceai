---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |  Sort: custsale.cntrycode ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |   Projection: custsale.cntrycode, count(*) AS numcust, sum(custsale.c_acctbal) AS totacctbal                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |     Aggregate: groupBy=[[custsale.cntrycode]], aggr=[[count(*), sum(custsale.c_acctbal)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |       SubqueryAlias: custsale                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |         Projection: substr(tpch.tpch.customer.c_phone, Int64(1), Int64(2)) AS cntrycode, tpch.tpch.customer.c_acctbal                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |           Filter: tpch.tpch.customer.c_acctbal > (<subquery>) AND NOT EXISTS (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |             Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |               Projection: avg(tpch.tpch.customer.c_acctbal)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |                 Aggregate: groupBy=[[]], aggr=[[avg(tpch.tpch.customer.c_acctbal)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |                   Filter: tpch.tpch.customer.c_acctbal > Float64(0) AND substr(tpch.tpch.customer.c_phone, Int64(1), Int64(2)) IN ([Utf8("13"), Utf8("31"), Utf8("23"), Utf8("29"), Utf8("30"), Utf8("18"), Utf8("17")])                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |                     TableScan: tpch.tpch.customer                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |             Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |               Projection: tpch.tpch.orders.o_orderkey, tpch.tpch.orders.o_custkey, tpch.tpch.orders.o_orderstatus, tpch.tpch.orders.o_totalprice, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_orderpriority, tpch.tpch.orders.o_clerk, tpch.tpch.orders.o_shippriority, tpch.tpch.orders.o_comment                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |                 Filter: tpch.tpch.orders.o_custkey = outer_ref(tpch.tpch.customer.c_custkey)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |                   TableScan: tpch.tpch.orders                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |             TableScan: tpch.tpch.customer projection=[c_custkey, c_phone, c_acctbal], full_filters=[substr(tpch.tpch.customer.c_phone, Int64(1), Int64(2)) IN ([Utf8("13"), Utf8("31"), Utf8("23"), Utf8("29"), Utf8("30"), Utf8("18"), Utf8("17")])]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT custsale.cntrycode, count(*) AS numcust, sum(custsale.c_acctbal) AS totacctbal FROM (SELECT substr(tpch.tpch.customer.c_phone, 1, 2) AS cntrycode, tpch.tpch.customer.c_acctbal FROM tpch.tpch.customer WHERE ((tpch.tpch.customer.c_acctbal > (SELECT avg(tpch.tpch.customer.c_acctbal) FROM tpch.tpch.customer WHERE ((tpch.tpch.customer.c_acctbal > 0.0) AND substr(tpch.tpch.customer.c_phone, 1, 2) IN ('13', '31', '23', '29', '30', '18', '17')))) AND NOT EXISTS (SELECT tpch.tpch.orders.o_orderkey, tpch.tpch.orders.o_custkey, tpch.tpch.orders.o_orderstatus, tpch.tpch.orders.o_totalprice, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_orderpriority, tpch.tpch.orders.o_clerk, tpch.tpch.orders.o_shippriority, tpch.tpch.orders.o_comment FROM tpch.tpch.orders WHERE (tpch.tpch.orders.o_custkey = tpch.tpch.customer.c_custkey))) AND substr(tpch.tpch.customer.c_phone, 1, 2) IN ('13', '31', '23', '29', '30', '18', '17')) AS custsale GROUP BY custsale.cntrycode ORDER BY custsale.cntrycode ASC NULLS LAST rewritten_sql=SELECT "custsale"."cntrycode", count(*) AS "numcust", sum("custsale"."c_acctbal") AS "totacctbal" FROM (SELECT substr("spice"."tpch"."customer"."c_phone", 1, 2) AS "cntrycode", "spice"."tpch"."customer"."c_acctbal" FROM "spice"."tpch"."customer" WHERE (("spice"."tpch"."customer"."c_acctbal" > (SELECT avg("spice"."tpch"."customer"."c_acctbal") FROM "spice"."tpch"."customer" WHERE (("spice"."tpch"."customer"."c_acctbal" > 0.0) AND substr("spice"."tpch"."customer"."c_phone", 1, 2) IN ('13', '31', '23', '29', '30', '18', '17')))) AND NOT EXISTS (SELECT "spice"."tpch"."orders"."o_orderkey", "spice"."tpch"."orders"."o_custkey", "spice"."tpch"."orders"."o_orderstatus", "spice"."tpch"."orders"."o_totalprice", "spice"."tpch"."orders"."o_orderdate", "spice"."tpch"."orders"."o_orderpriority", "spice"."tpch"."orders"."o_clerk", "spice"."tpch"."orders"."o_shippriority", "spice"."tpch"."orders"."o_comment" FROM "spice"."tpch"."orders" WHERE ("spice"."tpch"."orders"."o_custkey" = "spice"."tpch"."customer"."c_custkey"))) AND substr("spice"."tpch"."customer"."c_phone", 1, 2) IN ('13', '31', '23', '29', '30', '18', '17')) AS "custsale" GROUP BY "custsale"."cntrycode" ORDER BY "custsale"."cntrycode" ASC NULLS LAST |
