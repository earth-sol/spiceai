---
source: crates/test-framework/src/snapshot/mod.rs
description: "Query: clickbench_q29"
---
+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |  Limit: skip=0, fetch=25                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |   Sort: l DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |     Projection: regexp_replace(hits.Referer,Utf8("^https?://(?:www\.)?([^/]+)/.*$"),Utf8("\1")) AS k, avg(character_length(hits.Referer)) AS l, count(Int64(1)) AS c, min(hits.Referer)                                                                                                                                                                                                                                                                                                                                                                                     |
|               |       Filter: count(Int64(1)) > Int64(100000)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |         Aggregate: groupBy=[[regexp_replace(hits.Referer, Utf8("^https?://(?:www\.)?([^/]+)/.*$"), Utf8("\1"))]], aggr=[[avg(character_length(hits.Referer)), count(Int64(1)), min(hits.Referer)]]                                                                                                                                                                                                                                                                                                                                                                          |
|               |           TableScan: hits projection=[Referer], full_filters=[hits.Referer != Utf8("")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |     CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |       VirtualExecutionPlan name=postgres compute_context=host=Tcp("benchmarking-postgres-rw.dataplatform.svc.cluster.local"),port=5432,db=clickbench_accelerated,user=postgres, initial_sql=SELECT regexp_replace("hits"."Referer", '^https?://(?:www\.)?([^/]+)/.*$', '\1') AS "k", avg(character_length("hits"."Referer")) AS "l", count(1) AS "c", min("hits"."Referer") FROM "hits" WHERE ("hits"."Referer" <> '') GROUP BY regexp_replace("hits"."Referer", '^https?://(?:www\.)?([^/]+)/.*$', '\1') HAVING (count(1) > 100000) ORDER BY "l" DESC NULLS FIRST LIMIT 25 |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
