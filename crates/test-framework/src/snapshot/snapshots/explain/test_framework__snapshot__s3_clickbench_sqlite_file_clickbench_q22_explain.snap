|               |     VirtualExecutionPlan name=sqlite compute_context=/tmp/.tmpcHLWhJ/.spice/data/accelerated_sqlite.db sql=SELECT hits.SearchPhrase, min(hits."URL"), count(*) AS c FROM hits WHERE (hits."URL" LIKE '%google%' AND (hits.SearchPhrase <> '')) GROUP BY hits.SearchPhrase ORDER BY c DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT `hits`.`SearchPhrase`, min(`hits`.`URL`), count(*) AS `c` FROM `hits` WHERE (`hits`.`URL` LIKE '%google%' AND (`hits`.`SearchPhrase` <> '')) GROUP BY `hits`.`SearchPhrase` ORDER BY `c` DESC NULLS FIRST LIMIT 10 |
