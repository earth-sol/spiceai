|               |                       Inner Join: orders.o_custkey = customer.c_custkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |                         Projection: lineitem.l_discount, lineitem.l_extendedprice, supplier.s_nationkey, orders.o_custkey, orders.o_orderdate                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |                           Inner Join: lineitem.l_orderkey = orders.o_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
