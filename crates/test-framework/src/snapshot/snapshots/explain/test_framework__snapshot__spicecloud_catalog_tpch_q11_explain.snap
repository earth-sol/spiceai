                                                                                                                                    |
+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |  Sort: value DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |   Projection: tpch.tpch.partsupp.ps_partkey, sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty) AS value                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |     Filter: sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty) > (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |       Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |         Projection: sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty) * Float64(0.0001)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |           Aggregate: groupBy=[[]], aggr=[[sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |             Filter: tpch.tpch.partsupp.ps_suppkey = tpch.tpch.supplier.s_suppkey AND tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey AND tpch.tpch.nation.n_name = Utf8("GERMANY")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |               Cross Join:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |                 Cross Join:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |                   TableScan: tpch.tpch.partsupp                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |                   TableScan: tpch.tpch.supplier                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |                 TableScan: tpch.tpch.nation                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |       Aggregate: groupBy=[[tpch.tpch.partsupp.ps_partkey]], aggr=[[sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |         Inner Join:  Filter: tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |           Inner Join:  Filter: tpch.tpch.partsupp.ps_suppkey = tpch.tpch.supplier.s_suppkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |             TableScan: tpch.tpch.partsupp projection=[ps_partkey, ps_suppkey, ps_availqty, ps_supplycost]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |             TableScan: tpch.tpch.supplier projection=[s_suppkey, s_nationkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |           TableScan: tpch.tpch.nation projection=[n_nationkey], full_filters=[tpch.tpch.nation.n_name = Utf8("GERMANY")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT tpch.tpch.partsupp.ps_partkey, sum((tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty)) AS "value" FROM tpch.tpch.partsupp JOIN tpch.tpch.supplier ON (tpch.tpch.partsupp.ps_suppkey = tpch.tpch.supplier.s_suppkey) JOIN tpch.tpch.nation ON ((tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey) AND (tpch.tpch.nation.n_name = 'GERMANY')) GROUP BY tpch.tpch.partsupp.ps_partkey HAVING (sum((tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty)) > (SELECT (sum((tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty)) * 0.0001) FROM tpch.tpch.partsupp JOIN tpch.tpch.supplier ON true JOIN tpch.tpch.nation ON true WHERE (((tpch.tpch.partsupp.ps_suppkey = tpch.tpch.supplier.s_suppkey) AND (tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey)) AND (tpch.tpch.nation.n_name = 'GERMANY')))) ORDER BY "value" DESC NULLS FIRST rewritten_sql=SELECT "spice"."tpch"."partsupp"."ps_partkey", sum(("spice"."tpch"."partsupp"."ps_supplycost" * "spice"."tpch"."partsupp"."ps_availqty")) AS "value" FROM "spice"."tpch"."partsupp" JOIN "spice"."tpch"."supplier" ON ("spice"."tpch"."partsupp"."ps_suppkey" = "spice"."tpch"."supplier"."s_suppkey") JOIN "spice"."tpch"."nation" ON (("spice"."tpch"."supplier"."s_nationkey" = "spice"."tpch"."nation"."n_nationkey") AND ("spice"."tpch"."nation"."n_name" = 'GERMANY')) GROUP BY "spice"."tpch"."partsupp"."ps_partkey" HAVING (sum(("spice"."tpch"."partsupp"."ps_supplycost" * "spice"."tpch"."partsupp"."ps_availqty")) > (SELECT (sum(("spice"."tpch"."partsupp"."ps_supplycost" * "spice"."tpch"."partsupp"."ps_availqty")) * 0.0001) FROM "spice"."tpch"."partsupp" JOIN "spice"."tpch"."supplier" ON true JOIN "spice"."tpch"."nation" ON true WHERE ((("spice"."tpch"."partsupp"."ps_suppkey" = "spice"."tpch"."supplier"."s_suppkey") AND ("spice"."tpch"."supplier"."s_nationkey" = "spice"."tpch"."nation"."n_nationkey")) AND ("spice"."tpch"."nation"."n_name" = 'GERMANY')))) ORDER BY "value" DESC NULLS FIRST |
