|               |             Filter: (lineitem.l_quantity >= Decimal128(Some(1000000),18,6) AND lineitem.l_quantity <= Decimal128(Some(11000000),18,6) OR lineitem.l_quantity >= Decimal128(Some(10000000),18,6) AND lineitem.l_quantity <= Decimal128(Some(20000000),18,6) OR lineitem.l_quantity >= Decimal128(Some(20000000),18,6) AND lineitem.l_quantity <= Decimal128(Some(30000000),18,6)) AND (lineitem.l_shipmode = Utf8("AIR") OR lineitem.l_shipmode = Utf8("AIR REG")) AND lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     