|               |                         BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |                           DataSourceExec: file_groups={32 groups: [[/data/lineitem.parquet:0..8057814], [/data/lineitem.parquet:8057814..16115628], [/data/lineitem.parquet:16115628..24173442], [/data/lineitem.parquet:24173442..32231256], [/data/lineitem.parquet:32231256..40289070], ...]}, projection=[l_orderkey, l_extendedprice, l_discount, l_shipdate], file_type=parquet, predicate=l_shipdate@3 > 1995-03-15, pruning_predicate=l_shipdate_null_count@1 != row_count@2 AND l_shipdate_max@0 > 1995-03-15, required_guarantees=[N]                                  |
