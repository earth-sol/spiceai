|               |   Projection: glue.tpch.nation.n_name, sum(glue.tpch.lineitem.l_extendedprice * Int64(1) - glue.tpch.lineitem.l_discount) AS revenue                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |     Aggregate: groupBy=[[glue.tpch.nation.n_name]], aggr=[[sum(glue.tpch.lineitem.l_extendedprice * (Decimal128(Some(1),20,0) - glue.tpch.lineitem.l_discount)) AS sum(glue.tpch.lineitem.l_extendedprice * Int64(1) - glue.tpch.lineitem.l_discount)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
