|               |                                       DataSourceExec: file_groups={1 group: [[tpch/supplier/supplier.parquet]]}, projection=[s_suppkey, s_nationkey], file_type=parquet, predicate=DynamicFilter [ empty ]                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
