+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                              |
+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |  Limit: skip=0, fetch=10                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |   Sort: count(*) DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |     Projection: hits.UserID, date_part(Utf8("minute"),from_unixtime(hits.EventTime)) AS m, hits.SearchPhrase, count(Int64(1)) AS count(*)                                                                                                                                                                                                                                                                                         |
|               |       Aggregate: groupBy=[[hits.UserID, date_part(Utf8("minute"), from_unixtime(hits.EventTime)), hits.SearchPhrase]], aggr=[[count(Int64(1))]]                                                                                                                                                                                                                                                                                   |
|               |         TableScan: hits projection=[EventTime, UserID, SearchPhrase]                                                                                                                                                                                                                                                                                                                                                              |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |       VirtualExecutionPlan name=sqlite compute_context=//data/accelerated_sqlite.db initial_sql=SELECT `hits`.`UserID`, strftime('%M', datetime(`hits`.`EventTime`, 'unixepoch')) AS `m`, `hits`.`SearchPhrase`, count(1) AS `count(*)` FROM `hits` GROUP BY `hits`.`UserID`, strftime('%M', datetime(`hits`.`EventTime`, 'unixepoch')), `hits`.`SearchPhrase` ORDER BY `count(*)` DESC NULLS FIRST LIMIT 10 |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                   |
