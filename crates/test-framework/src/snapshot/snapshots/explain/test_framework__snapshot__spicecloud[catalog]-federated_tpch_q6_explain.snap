|               |  Projection: sum(tpch.tpch.lineitem.l_extendedprice * tpch.tpch.lineitem.l_discount) AS revenue                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
