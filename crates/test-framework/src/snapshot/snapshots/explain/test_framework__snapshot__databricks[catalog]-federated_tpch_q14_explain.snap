| physical_plan | ProjectionExec: expr=[100 * CAST(sum(CASE WHEN tpch.tpch.part.p_type LIKE Utf8("PROMO%") THEN tpch.tpch.lineitem.l_extendedprice * Int64(1) - tpch.tpch.lineitem.l_discount ELSE Int64(0) END)@0 AS Float64) / CAST(sum(tpch.tpch.lineitem.l_extendedprice * Int64(1) - tpch.tpch.lineitem.l_discount)@1 AS Float64) as promo_revenue]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
