|               |             Filter: tpch.tpch.lineitem.l_shipdate >= Date32("1995-09-01") AND tpch.tpch.lineitem.l_shipdate < Date32("1995-10-01")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |               TableScan: tpch.tpch.lineitem projection=[l_partkey, l_extendedprice, l_discount, l_shipdate], partial_filters=[tpch.tpch.lineitem.l_shipdate >= Date32("1995-09-01"), tpch.tpch.lineitem.l_shipdate < Date32("1995-10-01")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
