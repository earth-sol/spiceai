|               |           Filter: (lineitem.l_quantity >= Float64(1) AND lineitem.l_quantity <= Float64(11) OR lineitem.l_quantity >= Float64(10) AND lineitem.l_quantity <= Float64(20) OR lineitem.l_quantity >= Float64(20) AND lineitem.l_quantity <= Float64(30)) AND (lineitem.l_shipmode = Utf8("AIR") OR lineitem.l_shipmode = Utf8("AIR REG")) AND lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               