| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
+---------------+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |  Projection: sum(lineitem.l_extendedprice * Int64(1) - lineitem.l_discount) AS revenue                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |   Aggregate: groupBy=[[]], aggr=[[sum(lineitem.l_extendedprice * (Int64(1) - lineitem.l_discount))]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |     Inner Join:  Filter: part.p_partkey = lineitem.l_partkey AND part.p_brand = Utf8("Brand#12") AND part.p_container IN ([Utf8("SM CASE"), Utf8("SM BOX"), Utf8("SM PACK"), Utf8("SM PKG")]) AND lineitem.l_quantity >= CAST(Int64(1) AS Int64) AND lineitem.l_quantity <= CAST(Int64(1) AS Int64) + CAST(Int64(10) AS Int64) AND part.p_size BETWEEN CAST(Int64(1) AS Int64) AND CAST(Int64(5) AS Int64) AND lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON") OR part.p_partkey = lineitem.l_partkey AND part.p_brand = Utf8("Brand#23") AND part.p_container IN ([Utf8("MED BAG"), Utf8("MED BOX"), Utf8("MED PKG"), Utf8("MED PACK")]) AND lineitem.l_quantity >= CAST(Int64(10) AS Int64) AND lineitem.l_quantity <= CAST(Int64(10) AS Int64) + CAST(Int64(10) AS Int64) AND part.p_size BETWEEN CAST(Int64(1) AS Int64) AND CAST(Int64(10) AS Int64) AND lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON") OR part.p_partkey = lineitem.l_partkey AND part.p_brand = Utf8("Brand#34") AND part.p_container IN ([Utf8("LG CASE"), Utf8("LG BOX"), Utf8("LG PACK"), Utf8("LG PKG")]) AND lineitem.l_quantity >= CAST(Int64(20) AS Int64) AND lineitem.l_quantity <= CAST(Int64(20) AS Int64) + CAST(Int64(10) AS Int64) AND part.p_size BETWEEN CAST(Int64(1) AS Int64) AND CAST(Int64(15) AS Int64) AND lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |       TableScan: lineitem projection=[l_partkey, l_quantity, l_extendedprice, l_discount, l_shipinstruct, l_shipmode], full_filters=[lineitem.l_quantity >= CAST(Int64(1) AS Int64) AND lineitem.l_quantity <= CAST(Int64(1) AS Int64) + CAST(Int64(10) AS Int64) AND lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON") OR lineitem.l_quantity >= CAST(Int64(10) AS Int64) AND lineitem.l_quantity <= CAST(Int64(10) AS Int64) + CAST(Int64(10) AS Int64) AND lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON") OR lineitem.l_quantity >= CAST(Int64(20) AS Int64) AND lineitem.l_quantity <= CAST(Int64(20) AS Int64) + CAST(Int64(10) AS Int64) AND lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |       Filter: part.p_brand = Utf8("Brand#12") AND part.p_container IN ([Utf8("SM CASE"), Utf8("SM BOX"), Utf8("SM PACK"), Utf8("SM PKG")]) AND part.p_size BETWEEN CAST(Int64(1) AS Int64) AND CAST(Int64(5) AS Int64) OR part.p_brand = Utf8("Brand#23") AND part.p_container IN ([Utf8("MED BAG"), Utf8("MED BOX"), Utf8("MED PKG"), Utf8("MED PACK")]) AND part.p_size BETWEEN CAST(Int64(1) AS Int64) AND CAST(Int64(10) AS Int64) OR part.p_brand = Utf8("Brand#34") AND part.p_container IN ([Utf8("LG CASE"), Utf8("LG BOX"), Utf8("LG PACK"), Utf8("LG PKG")]) AND part.p_size BETWEEN CAST(Int64(1) AS Int64) AND CAST(Int64(15) AS Int64)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |         TableScan: part projection=[p_partkey, p_brand, p_size, p_container]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |   CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |       VirtualExecutionPlan name=duckdb compute_context=./data/tpch.db initial_sql=SELECT sum(("lineitem"."l_extendedprice" * (1 - "lineitem"."l_discount"))) AS "revenue" FROM "lineitem" INNER JOIN "part" ON ((((((((((("part"."p_partkey" = "lineitem"."l_partkey") AND ("part"."p_brand" = 'Brand#12')) AND "part"."p_container" IN ('SM CASE', 'SM BOX', 'SM PACK', 'SM PKG')) AND ("lineitem"."l_quantity" >= CAST(1 AS BIGINT))) AND ("lineitem"."l_quantity" <= (CAST(1 AS BIGINT) + CAST(10 AS BIGINT)))) AND ("part"."p_size" BETWEEN CAST(1 AS BIGINT) AND CAST(5 AS BIGINT))) AND "lineitem"."l_shipmode" IN ('AIR', 'AIR REG')) AND ("lineitem"."l_shipinstruct" = 'DELIVER IN PERSON')) OR (((((((("part"."p_partkey" = "lineitem"."l_partkey") AND ("part"."p_brand" = 'Brand#23')) AND "part"."p_container" IN ('MED BAG', 'MED BOX', 'MED PKG', 'MED PACK')) AND ("lineitem"."l_quantity" >= CAST(10 AS BIGINT))) AND ("lineitem"."l_quantity" <= (CAST(10 AS BIGINT) + CAST(10 AS BIGINT)))) AND ("part"."p_size" BETWEEN CAST(1 AS BIGINT) AND CAST(10 AS BIGINT))) AND "lineitem"."l_shipmode" IN ('AIR', 'AIR REG')) AND ("lineitem"."l_shipinstruct" = 'DELIVER IN PERSON'))) OR (((((((("part"."p_partkey" = "lineitem"."l_partkey") AND ("part"."p_brand" = 'Brand#34')) AND "part"."p_container" IN ('LG CASE', 'LG BOX', 'LG PACK', 'LG PKG')) AND ("lineitem"."l_quantity" >= CAST(20 AS BIGINT))) AND ("lineitem"."l_quantity" <= (CAST(20 AS BIGINT) + CAST(10 AS BIGINT)))) AND ("part"."p_size" BETWEEN CAST(1 AS BIGINT) AND CAST(15 AS BIGINT))) AND "lineitem"."l_shipmode" IN ('AIR', 'AIR REG')) AND ("lineitem"."l_shipinstruct" = 'DELIVER IN PERSON'))) AND ((((((("lineitem"."l_quantity" >= CAST(1 AS BIGINT)) AND ("lineitem"."l_quantity" <= (CAST(1 AS BIGINT) + CAST(10 AS BIGINT)))) AND "lineitem"."l_shipmode" IN ('AIR', 'AIR REG')) AND ("lineitem"."l_shipinstruct" = 'DELIVER IN PERSON')) OR (((("lineitem"."l_quantity" >= CAST(10 AS BIGINT)) AND ("lineitem"."l_quantity" <= (CAST(10 AS BIGINT) + CAST(10 AS BIGINT)))) AND "lineitem"."l_shipmode" IN ('AIR', 'AIR REG')) AND ("lineitem"."l_shipinstruct" = 'DELIVER IN PERSON'))) OR (((("lineitem"."l_quantity" >= CAST(20 AS BIGINT)) AND ("lineitem"."l_quantity" <= (CAST(20 AS BIGINT) + CAST(10 AS BIGINT)))) AND "lineitem"."l_shipmode" IN ('AIR', 'AIR REG')) AND ("lineitem"."l_shipinstruct" = 'DELIVER IN PERSON'))) AND ((((("part"."p_brand" = 'Brand#12') AND "part"."p_container" IN ('SM CASE', 'SM BOX', 'SM PACK', 'SM PKG')) AND ("part"."p_size" BETWEEN CAST(1 AS BIGINT) AND CAST(5 AS BIGINT))) OR ((("part"."p_brand" = 'Brand#23') AND "part"."p_container" IN ('MED BAG', 'MED BOX', 'MED PKG', 'MED PACK')) AND ("part"."p_size" BETWEEN CAST(1 AS BIGINT) AND CAST(10 AS BIGINT)))) OR ((("part"."p_brand" = 'Brand#34') AND "part"."p_container" IN ('LG CASE', 'LG BOX', 'LG PACK', 'LG PKG')) AND ("part"."p_size" BETWEEN CAST(1 AS BIGINT) AND CAST(15 AS BIGINT)))))) |
