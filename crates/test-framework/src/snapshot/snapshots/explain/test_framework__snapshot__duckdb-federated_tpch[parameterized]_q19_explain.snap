|               |     Inner Join:  Filter: part.p_partkey = lineitem.l_partkey AND part.p_brand = $1 AND part.p_container IN ([$2, $3, $4, $5]) AND lineitem.l_quantity >= $6 AND lineitem.l_quantity <= $7 + $8 AND part.p_size BETWEEN $9 AND $10 AND lineitem.l_shipmode IN ([$11, $12]) AND lineitem.l_shipinstruct = $13 OR part.p_partkey = lineitem.l_partkey AND part.p_brand = $14 AND part.p_container IN ([$15, $16, $17, $18]) AND lineitem.l_quantity >= $19 AND lineitem.l_quantity <= $20 + $21 AND part.p_size BETWEEN $22 AND $23 AND lineitem.l_shipmode IN ([$24, $25]) AND lineitem.l_shipinstruct = $26 OR part.p_partkey = lineitem.l_partkey AND part.p_brand = $27 AND part.p_container IN ([$28, $29, $30, $31]) AND lineitem.l_quantity >= $32 AND lineitem.l_quantity <= $33 + $34 AND part.p_size BETWEEN $35 AND $36 AND lineitem.l_shipmode IN ([$37, $38]) AND lineitem.l_shipinstruct = $39                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     