| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
+---------------+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |  Sort: revenue DESC NULLS FIRST, tpch.tpch.orders.o_orderdate ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |   Projection: tpch.tpch.lineitem.l_orderkey, sum(tpch.tpch.lineitem.l_extendedprice * Int64(1) - tpch.tpch.lineitem.l_discount) AS revenue, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_shippriority                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |     Aggregate: groupBy=[[tpch.tpch.lineitem.l_orderkey, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_shippriority]], aggr=[[sum(tpch.tpch.lineitem.l_extendedprice * (Int64(1) - tpch.tpch.lineitem.l_discount))]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |       Inner Join:  Filter: tpch.tpch.lineitem.l_orderkey = tpch.tpch.orders.o_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |         Inner Join:  Filter: tpch.tpch.customer.c_custkey = tpch.tpch.orders.o_custkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |           TableScan: tpch.tpch.customer projection=[c_custkey], full_filters=[tpch.tpch.customer.c_mktsegment = Utf8("BUILDING")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |           Filter: tpch.tpch.orders.o_orderdate < CAST(Utf8("1995-03-15") AS Date32)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |             TableScan: tpch.tpch.orders projection=[o_orderkey, o_custkey, o_orderdate, o_shippriority]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |         Filter: tpch.tpch.lineitem.l_shipdate > CAST(Utf8("1995-03-15") AS Date32)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |           TableScan: tpch.tpch.lineitem projection=[l_orderkey, l_extendedprice, l_discount, l_shipdate]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT tpch.tpch.lineitem.l_orderkey, sum((tpch.tpch.lineitem.l_extendedprice * (1 - tpch.tpch.lineitem.l_discount))) AS revenue, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_shippriority FROM tpch.tpch.customer JOIN tpch.tpch.orders ON ((tpch.tpch.customer.c_custkey = tpch.tpch.orders.o_custkey) AND ((tpch.tpch.customer.c_mktsegment = 'BUILDING') AND (tpch.tpch.orders.o_orderdate < CAST('1995-03-15' AS DATE)))) JOIN tpch.tpch.lineitem ON ((tpch.tpch.lineitem.l_orderkey = tpch.tpch.orders.o_orderkey) AND (tpch.tpch.lineitem.l_shipdate > CAST('1995-03-15' AS DATE))) GROUP BY tpch.tpch.lineitem.l_orderkey, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_shippriority ORDER BY revenue DESC NULLS FIRST, tpch.tpch.orders.o_orderdate ASC NULLS LAST rewritten_sql=SELECT "spice"."tpch"."lineitem"."l_orderkey", sum(("spice"."tpch"."lineitem"."l_extendedprice" * (1 - "spice"."tpch"."lineitem"."l_discount"))) AS "revenue", "spice"."tpch"."orders"."o_orderdate", "spice"."tpch"."orders"."o_shippriority" FROM "spice"."tpch"."customer" JOIN "spice"."tpch"."orders" ON (("spice"."tpch"."customer"."c_custkey" = "spice"."tpch"."orders"."o_custkey") AND (("spice"."tpch"."customer"."c_mktsegment" = 'BUILDING') AND ("spice"."tpch"."orders"."o_orderdate" < CAST('1995-03-15' AS DATE)))) JOIN "spice"."tpch"."lineitem" ON (("spice"."tpch"."lineitem"."l_orderkey" = "spice"."tpch"."orders"."o_orderkey") AND ("spice"."tpch"."lineitem"."l_shipdate" > CAST('1995-03-15' AS DATE))) GROUP BY "spice"."tpch"."lineitem"."l_orderkey", "spice"."tpch"."orders"."o_orderdate", "spice"."tpch"."orders"."o_shippriority" ORDER BY "revenue" DESC NULLS FIRST, "spice"."tpch"."orders"."o_orderdate" ASC NULLS LAST |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
