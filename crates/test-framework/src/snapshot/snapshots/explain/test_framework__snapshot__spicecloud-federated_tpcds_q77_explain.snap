|               |       VirtualExecutionPlan name=spice.ai compute_context=url=https://dev-flight.spiceai.io,username=,org=spiceai,app=benchmarks-tpcds initial_sql=SELECT "x"."channel", "x"."id", sum("x"."sales") AS "sales", sum("x"."returns") AS "returns", sum("x"."profit") AS "profit" FROM (SELECT 'store channel' AS "channel", "ss"."s_store_sk" AS "id", "ss"."sales", coalesce("sr"."returns", 0) AS "returns", ("ss"."profit" - coalesce("sr"."profit_loss", 0)) AS "profit" FROM (SELECT "store"."s_store_sk", sum("store_sales"."ss_ext_sales_price") AS "sales", sum("store_sales"."ss_net_profit") AS "profit" FROM "store_sales" INNER JOIN "date_dim" ON (("store_sales"."ss_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) INNER JOIN "store" ON ("store_sales"."ss_store_sk" = "store"."s_store_sk") GROUP BY "store"."s_store_sk") AS "ss" LEFT OUTER JOIN (SELECT "store"."s_store_sk", sum("store_returns"."sr_return_amt") AS "returns", sum("store_returns"."sr_net_loss") AS "profit_loss" FROM "store_returns" INNER JOIN "date_dim" ON (("store_returns"."sr_returned_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) INNER JOIN "store" ON ("store_returns"."sr_store_sk" = "store"."s_store_sk") GROUP BY "store"."s_store_sk") AS "sr" ON ("ss"."s_store_sk" = "sr"."s_store_sk") UNION ALL SELECT 'catalog channel' AS "channel", "cs"."cs_call_center_sk" AS "id", "cs"."sales", CAST("cr"."returns" AS DECIMAL(22,2)), CAST(("cs"."profit" - "cr"."profit_loss") AS DECIMAL(23,2)) AS "profit" FROM (SELECT "catalog_sales"."cs_call_center_sk", sum("catalog_sales"."cs_ext_sales_price") AS "sales", sum("catalog_sales"."cs_net_profit") AS "profit" FROM "catalog_sales" INNER JOIN "date_dim" ON (("catalog_sales"."cs_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) GROUP BY "catalog_sales"."cs_call_center_sk") AS "cs" CROSS JOIN (SELECT sum("catalog_returns"."cr_return_amount") AS "returns", sum("catalog_returns"."cr_net_loss") AS "profit_loss" FROM "catalog_returns" INNER JOIN "date_dim" ON (("catalog_returns"."cr_returned_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) GROUP BY "catalog_returns"."cr_call_center_sk") AS "cr" UNION ALL SELECT 'web channel' AS "channel", "ws"."wp_web_page_sk" AS "id", "ws"."sales", coalesce("wr"."returns", 0) AS "returns", ("ws"."profit" - coalesce("wr"."profit_loss", 0)) AS "profit" FROM (SELECT "web_page"."wp_web_page_sk", sum("web_sales"."ws_ext_sales_price") AS "sales", sum("web_sales"."ws_net_profit") AS "profit" FROM "web_sales" INNER JOIN "date_dim" ON (("web_sales"."ws_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) INNER JOIN "web_page" ON ("web_sales"."ws_web_page_sk" = "web_page"."wp_web_page_sk") GROUP BY "web_page"."wp_web_page_sk") AS "ws" LEFT OUTER JOIN (SELECT "web_page"."wp_web_page_sk", sum("web_returns"."wr_return_amt") AS "returns", sum("web_returns"."wr_net_loss") AS "profit_loss" FROM "web_returns" INNER JOIN "date_dim" ON (("web_returns"."wr_returned_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) INNER JOIN "web_page" ON ("web_returns"."wr_web_page_sk" = "web_page"."wp_web_page_sk") GROUP BY "web_page"."wp_web_page_sk") AS "wr" ON ("ws"."wp_web_page_sk" = "wr"."wp_web_page_sk")) AS "x" GROUP BY ROLLUP ("x"."channel", "x"."id") ORDER BY "x"."channel" ASC NULLS LAST, "x"."id" ASC NULLS LAST LIMIT 100 rewritten_sql=SELECT "x"."channel", "x"."id", sum("x"."sales") AS "sales", sum("x"."returns") AS "returns", sum("x"."profit") AS "profit" FROM (SELECT 'store channel' AS "channel", "ss"."s_store_sk" AS "id", "ss"."sales", coalesce("sr"."returns", 0) AS "returns", ("ss"."profit" - coalesce("sr"."profit_loss", 0)) AS "profit" FROM (SELECT "s_store_sk", sum("store_sales"."ss_ext_sales_price") AS "sales", sum("store_sales"."ss_net_profit") AS "profit" FROM "tpcds"."store_sales" INNER JOIN "tpcds"."date_dim" ON (("store_sales"."ss_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) INNER JOIN "tpcds"."store" ON ("store_sales"."ss_store_sk" = "store"."s_store_sk") GROUP BY "store"."s_store_sk") AS "ss" LEFT OUTER JOIN (SELECT "s_store_sk", sum("store_returns"."sr_return_amt") AS "returns", sum("store_returns"."sr_net_loss") AS "profit_loss" FROM "tpcds"."store_returns" INNER JOIN "tpcds"."date_dim" ON (("store_returns"."sr_returned_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) INNER JOIN "tpcds"."store" ON ("store_returns"."sr_store_sk" = "store"."s_store_sk") GROUP BY "store"."s_store_sk") AS "sr" ON ("ss"."s_store_sk" = "sr"."s_store_sk") UNION ALL SELECT 'catalog channel' AS "channel", "cs"."cs_call_center_sk" AS "id", "cs"."sales", CAST("cr"."returns" AS DECIMAL(22,2)), CAST(("cs"."profit" - "cr"."profit_loss") AS DECIMAL(23,2)) AS "profit" FROM (SELECT "cs_call_center_sk", sum("catalog_sales"."cs_ext_sales_price") AS "sales", sum("catalog_sales"."cs_net_profit") AS "profit" FROM "tpcds"."catalog_sales" INNER JOIN "tpcds"."date_dim" ON (("catalog_sales"."cs_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_date" BETWEEN CAST('2001-08-11' AS DATE) AND (CAST('2001-08-11' AS DATE) + INTERVAL '30 DAYS'))) GROUP BY "catalog_sales"."cs_call_center_sk") AS "cs" CROSS JOIN (SELECT sum("catalog_returns"."cr_return_amount") AS "returns", sum("catalog_returns"."cr