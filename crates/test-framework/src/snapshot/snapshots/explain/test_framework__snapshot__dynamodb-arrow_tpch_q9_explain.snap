|               |           Inner Join: supplier.s_nationkey = nation.n_nationkey                                                                                                                                                                                                       |
|               |             Projection: lineitem.l_discount, lineitem.l_extendedprice, lineitem.l_quantity, supplier.s_nationkey, partsupp.ps_supplycost, orders.o_orderdate                                                                                                          |
