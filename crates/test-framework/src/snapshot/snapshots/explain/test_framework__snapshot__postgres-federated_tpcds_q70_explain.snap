                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |                     Filter: tmp1.ranking <= Int64(5)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |                       SubqueryAlias: tmp1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |                         Projection: store.s_state, rank() PARTITION BY [store.s_state] ORDER BY [sum(store_sales.ss_net_profit) DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW AS ranking                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |                           WindowAggr: windowExpr=[[rank() PARTITION BY [store.s_state] ORDER BY [sum(store_sales.ss_net_profit) DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |                             Aggregate: groupBy=[[store.s_state]], aggr=[[sum(store_sales.ss_net_profit)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |                               Filter: date_dim.d_month_seq BETWEEN Int64(1180) AND Int64(1180) + Int64(11) AND date_dim.d_date_sk = store_sales.ss_sold_date_sk AND store.s_store_sk = store_sales.ss_store_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |                                 Cross Join:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |                                   Cross Join:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |                                     TableScan: store_sales                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |                                     TableScan: store                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |                                   TableScan: date_dim                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |                 TableScan: store projection=[s_store_sk, s_county, s_state]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |     VirtualExecutionPlan name=postgres compute_context=host=Tcp("benchmarking-postgres-r.dataplatform.svc.cluster.local"),port=5432,db=tpcds,user=postgres, sql=SELECT total_sum, s_state, s_county, lochierarchy, rank_within_parent FROM (SELECT sum(store_sales.ss_net_profit) AS total_sum, store.s_state, store.s_county, (grouping(store.s_state) + grouping(store.s_county)) AS lochierarchy, rank() OVER (PARTITION BY (grouping(store.s_state) + grouping(store.s_county)), CASE WHEN (grouping(store.s_county) = 0) THEN store.s_state END ORDER BY sum(store_sales.ss_net_profit) DESC NULLS FIRST RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS rank_within_parent, grouping(store.s_county), grouping(store.s_state) FROM store_sales JOIN date_dim AS d1 ON ((d1.d_date_sk = store_sales.ss_sold_date_sk) AND (d1.d_month_seq BETWEEN 1180 AND (1180 + 11))) JOIN store ON ((store.s_store_sk = store_sales.ss_store_sk) AND store.s_state IN (SELECT tmp1.s_state FROM (SELECT store.s_state, rank() OVER (PARTITION BY store.s_state ORDER BY sum(store_sales.ss_net_profit) DESC NULLS FIRST RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS ranking FROM store_sales CROSS JOIN store CROSS JOIN date_dim WHERE (((date_dim.d_month_seq BETWEEN 1180 AND (1180 + 11)) AND (date_dim.d_date_sk = store_sales.ss_sold_date_sk)) AND (store.s_store_sk = store_sales.ss_store_sk)) GROUP BY store.s_state) AS tmp1 WHERE (tmp1.ranking <= 5))) GROUP BY ROLLUP (store.s_state, store.s_county) ORDER BY lochierarchy DESC NULLS FIRST, CASE WHEN ((grouping(store.s_state) + grouping(store.s_county)) = 0) THEN store.s_state END ASC NULLS LAST, rank_within_parent ASC NULLS LAST) LIMIT 100 rewritten_sql=SELECT "total_sum", "s_state", "s_county", "lochierarchy", "rank_within_parent" FROM (SELECT sum("store_sales"."ss_net_profit") AS "total_sum", "store"."s_state", "store"."s_county", (grouping("store"."s_state") + grouping("store"."s_county")) AS "lochierarchy", rank() OVER (PARTITION BY (grouping("store"."s_state") + grouping("store"."s_county")), CASE WHEN (grouping("store"."s_county") = 0) THEN "store"."s_state" END ORDER BY sum("store_sales"."ss_net_profit") DESC NULLS FIRST RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS "rank_within_parent", grouping("store"."s_county"), grouping("store"."s_state") FROM "store_sales" JOIN "date_dim" AS "d1" ON (("d1"."d_date_sk" = "store_sales"."ss_sold_date_sk") AND ("d1"."d_month_seq" BETWEEN 1180 AND (1180 + 11))) JOIN "store" ON (("store"."s_store_sk" = "store_sales"."ss_store_sk") AND "store"."s_state" IN (SELECT "tmp1"."s_state" FROM (SELECT "store"."s_state", rank() OVER (PARTITION BY "store"."s_state" ORDER BY sum("store_sales"."ss_net_profit") DESC NULLS FIRST RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS "ranking" FROM "store_sales" CROSS JOIN "store" CROSS JOIN "date_dim" WHERE ((("date_dim"."d_month_seq" BETWEEN 1180 AND (1180 + 11)) AND ("date_dim"."d_date_sk" = "store_sales"."ss_sold_date_sk")) AND ("store"."s_store_sk" = "store_sales"."ss_store_sk")) GROUP BY "store"."s_state") AS "tmp1" WHERE ("tmp1"."ranking" <= 5))) GROUP BY ROLLUP ("store"."s_state", "store"."s_county") ORDER BY "lochierarchy" DESC NULLS FIRST, CASE WHEN ((grouping("store"."s_state") + grouping("store"."s_county")) = 0) THEN "store"."s_state" END ASC NULLS LAST, "rank_within_parent" ASC NULLS LAST) LIMIT 100 |
