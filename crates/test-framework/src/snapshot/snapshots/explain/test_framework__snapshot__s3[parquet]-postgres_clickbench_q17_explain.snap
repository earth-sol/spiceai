|               |       VirtualExecutionPlan name=postgres compute_context=host=Tcp("benchmarking-postgres-rw.dataplatform.svc.cluster.local"),port=5432,db=clickbench_accelerated,user=postgres, initial_sql=SELECT "hits"."UserID", "hits"."SearchPhrase", count(1) AS "count(*)" FROM "hits" GROUP BY "hits"."UserID", "hits"."SearchPhrase" ORDER BY "count(*)" DESC NULLS FIRST LIMIT 10 |
