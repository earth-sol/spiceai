                                                                                                                                                                                                                                                                                                                                               |
|               |                   Aggregate: groupBy=[[item.i_item_id]], aggr=[[sum(web_sales.ws_ext_sales_price)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           