                                                                                                                                                                                                                                                                                                                                               |
|               |                 Projection: item.i_item_id, sum(web_sales.ws_ext_sales_price) AS total_sales                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  