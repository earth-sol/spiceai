|               |         SubqueryAlias: i2                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |           TableScan: item projection=[i_item_sk, i_product_name]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |     CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |       VirtualExecutionPlan name=postgres compute_context=host=Tcp("benchmarking-postgres-rw.dataplatform.svc.cluster.local"),port=5432,db=tpcds_sf1,user=postgres, initial_sql=SELECT "asceding"."rnk", "i1"."i_product_name" AS "best_performing", "i2"."i_product_name" AS "worst_performing" FROM (SELECT "V11"."item_sk", "V11"."rnk" FROM (SELECT "V1"."item_sk", rank() OVER (ORDER BY "V1"."rank_col" ASC NULLS LAST RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS "rnk" FROM (SELECT "ss1"."ss_item_sk" AS "item_sk", avg("ss1"."ss_net_profit") AS "rank_col" FROM "store_sales" AS "ss1" WHERE ("ss1"."ss_store_sk" = 6) GROUP BY "ss1"."ss_item_sk" HAVING (avg("ss1"."ss_net_profit") > (0.9 * (SELECT avg("store_sales"."ss_net_profit") AS "rank_col" FROM "store_sales" WHERE "store_sales"."ss_hdemo_sk" IS NULL AND ("store_sales"."ss_store_sk" = 6) GROUP BY "store_sales"."ss_store_sk")))) AS "V1") AS "V11" WHERE ("V11"."rnk" < 11)) AS "asceding" INNER JOIN (SELECT "V21"."item_sk", "V21"."rnk" FROM (SELECT "V2"."item_sk", rank() OVER (ORDER BY "V2"."rank_col" DESC NULLS FIRST RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS "rnk" FROM (SELECT "ss1"."ss_item_sk" AS "item_sk", avg("ss1"."ss_net_profit") AS "rank_col" FROM "store_sales" AS "ss1" WHERE ("ss1"."ss_store_sk" = 6) GROUP BY "ss1"."ss_item_sk" HAVING (avg("ss1"."ss_net_profit") > (0.9 * (SELECT avg("store_sales"."ss_net_profit") AS "rank_col" FROM "store_sales" WHERE "store_sales"."ss_hdemo_sk" IS NULL AND ("store_sales"."ss_store_sk" = 6) GROUP BY "store_sales"."ss_store_sk")))) AS "V2") AS "V21" WHERE ("V21"."rnk" < 11)) AS "descending" ON ("asceding"."rnk" = "descending"."rnk") INNER JOIN "item" AS "i1" ON ("i1"."i_item_sk" = "asceding"."item_sk") INNER JOIN "item" AS "i2" ON ("i2"."i_item_sk" = "descending"."item_sk") ORDER BY "asceding"."rnk" ASC NULLS LAST LIMIT 100 |
