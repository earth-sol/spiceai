| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |  Limit: skip=0, fetch=10                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |   Sort: count(*) DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     Projection: hits.UserID, date_part(Utf8("MINUTE"),to_timestamp(hits.EventTime)) AS m, hits.SearchPhrase, count(Int64(1)) AS count(*)                                                                                                                                                                                                                                                                                                                        |
|               |       Aggregate: groupBy=[[hits.UserID, date_part(Utf8("MINUTE"), CAST(to_timestamp(hits.EventTime) AS Timestamp(ns))), hits.SearchPhrase]], aggr=[[count(Int64(1))]]                                                                                                                                                                                                                                                                                           |
|               |         TableScan: hits projection=[EventTime, UserID, SearchPhrase]                                                                                                                                                                                                                                                                                                                                                                                            |
| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |   CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |       VirtualExecutionPlan name=duckdb compute_context=//data/accelerated_duckdb.db initial_sql=SELECT "hits"."UserID", date_part('MINUTE', CAST(to_timestamp("hits"."EventTime") AS TIMESTAMP)) AS "m", "hits"."SearchPhrase", count(1) AS "count(*)" FROM "hits" GROUP BY "hits"."UserID", date_part('MINUTE', CAST(to_timestamp("hits"."EventTime") AS TIMESTAMP)), "hits"."SearchPhrase" ORDER BY "count(*)" DESC NULLS FIRST LIMIT 10 |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
