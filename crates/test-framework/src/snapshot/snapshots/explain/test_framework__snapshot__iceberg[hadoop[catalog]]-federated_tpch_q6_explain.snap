|               |         Filter: hadoop.tpch.lineitem.l_shipdate >= Date32("1994-01-01") AND hadoop.tpch.lineitem.l_shipdate < Date32("1995-01-01") AND hadoop.tpch.lineitem.l_discount >= Float64(0.049999999999999996) AND hadoop.tpch.lineitem.l_discount <= Float64(0.06999999999999999) AND hadoop.tpch.lineitem.l_quantity < Float64(24)                                                                                                   |
|               |           TableScan: hadoop.tpch.lineitem projection=[l_quantity, l_extendedprice, l_discount, l_shipdate], partial_filters=[hadoop.tpch.lineitem.l_shipdate >= Date32("1994-01-01"), hadoop.tpch.lineitem.l_shipdate < Date32("1995-01-01"), hadoop.tpch.lineitem.l_discount >= Float64(0.049999999999999996), hadoop.tpch.lineitem.l_discount <= Float64(0.06999999999999999), hadoop.tpch.lineitem.l_quantity < Float64(24)] |
| physical_plan | ProjectionExec: expr=[sum(hadoop.tpch.lineitem.l_extendedprice * hadoop.tpch.lineitem.l_discount)@0 as revenue]                                                                                                                                                                                                                                                                                                                 |
|               |   AggregateExec: mode=Final, gby=[], aggr=[sum(hadoop.tpch.lineitem.l_extendedprice * hadoop.tpch.lineitem.l_discount)]                                                                                                                                                                                                                                                                                                         |
|               |     CoalescePartitionsExec                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |       AggregateExec: mode=Partial, gby=[], aggr=[sum(hadoop.tpch.lineitem.l_extendedprice * hadoop.tpch.lineitem.l_discount)]                                                                                                                                                                                                                                                                                                   |
|               |         ProjectionExec: expr=[l_extendedprice@1 as l_extendedprice, l_discount@2 as l_discount]                                                                                                                                                                                                                                                                                                                                 |
|               |           BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |             CoalesceBatchesExec: target_batch_size=8192                                                                                                                                                                                                                                                                                                                                                                         |
|               |               FilterExec: l_shipdate@3 >= 1994-01-01 AND l_shipdate@3 < 1995-01-01 AND l_discount@2 >= 0.049999999999999996 AND l_discount@2 <= 0.06999999999999999 AND l_quantity@0 < 24                                                                                                                                                                                                                                       |
|               |                 RepartitionExec: partitioning=RoundRobinBatch(16), input_partitions=1                                                                                                                                                                                                                                                                                                                                           |
