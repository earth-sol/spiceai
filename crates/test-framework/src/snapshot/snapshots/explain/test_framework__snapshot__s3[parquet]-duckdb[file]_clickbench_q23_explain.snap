---
+---------------+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
+---------------+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |  Limit: skip=0, fetch=10                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |   Sort: c DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |     Projection: hits.SearchPhrase, min(hits.URL), min(hits.Title), count(Int64(1)) AS c, count(DISTINCT hits.UserID)                                                                                                                                                                                                                                                                                                                                           |
|               |       Aggregate: groupBy=[[hits.SearchPhrase]], aggr=[[min(hits.URL), min(hits.Title), count(Int64(1)), count(DISTINCT hits.UserID)]]                                                                                                                                                                                                                                                                                                                          |
|               |         Filter: CAST(hits.SearchPhrase AS Utf8View) != Utf8("")                                                                                                                                                                                                                                                                                                                                                                                                |
|               |           TableScan: hits projection=[Title, UserID, URL, SearchPhrase], full_filters=[hits.Title LIKE Utf8("%Google%"), hits.URL NOT LIKE Utf8("%.google.%")]                                                                                                                                                                                                                                                                                                 |
| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |   CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |       VirtualExecutionPlan name=duckdb compute_context=//data/accelerated_duckdb.db initial_sql=SELECT "hits"."SearchPhrase", min("hits"."URL"), min("hits"."Title"), count(1) AS "c", count(DISTINCT "hits"."UserID") FROM "hits" WHERE (CAST("hits"."SearchPhrase" AS VARCHAR) <> '') AND ("hits"."Title" LIKE '%Google%' AND "hits"."URL" NOT LIKE '%.google.%') GROUP BY "hits"."SearchPhrase" ORDER BY "c" DESC NULLS FIRST LIMIT 10 |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
+---------------+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
