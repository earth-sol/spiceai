                                                                                                                                                                                                                                                                                                                                                                         |
|               |               TableScan: tpch.tpch.partsupp projection=[ps_partkey, ps_suppkey, ps_supplycost]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |           TableScan: tpch.tpch.nation projection=[n_nationkey, n_name, n_regionkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |         TableScan: tpch.tpch.region projection=[r_regionkey], full_filters=[tpch.tpch.region.r_name = Utf8("EUROPE")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT s_acctbal, s_name, n_name, p_partkey, p_mfgr, s_address, s_phone, s_comment FROM tpch.tpch."part" INNER JOIN tpch.tpch.supplier ON ("part".p_type LIKE '%BRASS' AND ("part".p_size = 15)) INNER JOIN tpch.tpch.partsupp ON ((("part".p_partkey = partsupp.ps_partkey) AND (supplier.s_suppkey = partsupp.ps_suppkey)) AND (partsupp.ps_supplycost = (SELECT min(partsupp.ps_supplycost) FROM tpch.tpch.partsupp CROSS JOIN tpch.tpch.supplier CROSS JOIN tpch.tpch.nation CROSS JOIN tpch.tpch.region WHERE ((((("part".p_partkey = partsupp.ps_partkey) AND (supplier.s_suppkey = partsupp.ps_suppkey)) AND (supplier.s_nationkey = nation.n_nationkey)) AND (nation.n_regionkey = region.r_regionkey)) AND (region.r_name = 'EUROPE'))))) INNER JOIN tpch.tpch.nation ON (supplier.s_nationkey = nation.n_nationkey) INNER JOIN tpch.tpch.region ON ((nation.n_regionkey = region.r_regionkey) AND (region.r_name = 'EUROPE')) ORDER BY s_acctbal DESC NULLS FIRST, n_name ASC NULLS LAST, s_name ASC NULLS LAST, p_partkey ASC NULLS LAST LIMIT 100 rewritten_sql=SELECT "s_acctbal", "s_name", "n_name", "p_partkey", "p_mfgr", "s_address", "s_phone", "s_comment" FROM "spice"."tpch"."part" INNER JOIN "spice"."tpch"."supplier" ON ("part"."p_type" LIKE '%BRASS' AND ("part"."p_size" = 15)) INNER JOIN "spice"."tpch"."partsupp" ON ((("part"."p_partkey" = "partsupp"."ps_partkey") AND ("supplier"."s_suppkey" = "partsupp"."ps_suppkey")) AND ("partsupp"."ps_supplycost" = (SELECT min("partsupp"."ps_supplycost") FROM "spice"."tpch"."partsupp" CROSS JOIN "spice"."tpch"."supplier" CROSS JOIN "spice"."tpch"."nation" CROSS JOIN "spice"."tpch"."region" WHERE ((((("part"."p_partkey" = "partsupp"."ps_partkey") AND ("supplier"."s_suppkey" = "partsupp"."ps_suppkey")) AND ("supplier"."s_nationkey" = "nation"."n_nationkey")) AND ("nation"."n_regionkey" = "region"."r_regionkey")) AND ("region"."r_name" = 'EUROPE'))))) INNER JOIN "spice"."tpch"."nation" ON ("supplier"."s_nationkey" = "nation"."n_nationkey") INNER JOIN "spice"."tpch"."region" ON (("nation"."n_regionkey" = "region"."r_regionkey") AND ("region"."r_name" = 'EUROPE')) ORDER BY "s_acctbal" DESC NULLS FIRST, "n_name" ASC NULLS LAST, "s_name" ASC NULLS LAST, "p_partkey" ASC NULLS LAST LIMIT 100 |
