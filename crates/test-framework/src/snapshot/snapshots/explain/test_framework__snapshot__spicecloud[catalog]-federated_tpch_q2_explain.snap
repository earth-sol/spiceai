                                                                                                                                                                                                                                                                                                                                                                         |
|               |   Sort: tpch.tpch.supplier.s_acctbal DESC NULLS FIRST, tpch.tpch.nation.n_name ASC NULLS LAST, tpch.tpch.supplier.s_name ASC NULLS LAST, tpch.tpch.part.p_partkey ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              