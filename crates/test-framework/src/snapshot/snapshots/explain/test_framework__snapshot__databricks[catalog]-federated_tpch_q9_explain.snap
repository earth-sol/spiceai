|               |         Projection: tpch.tpch.nation.n_name AS nation, date_part(Utf8("YEAR"), tpch.tpch.orders.o_orderdate) AS o_year, tpch.tpch.lineitem.l_extendedprice * (Decimal128(Some(1),20,0) - tpch.tpch.lineitem.l_discount) - tpch.tpch.partsupp.ps_supplycost * tpch.tpch.lineitem.l_quantity AS amount                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |           Inner Join: tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
