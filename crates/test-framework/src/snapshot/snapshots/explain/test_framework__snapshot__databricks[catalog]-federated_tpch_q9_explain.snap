|               |                   Inner Join: tpch.tpch.lineitem.l_suppkey = tpch.tpch.partsupp.ps_suppkey, tpch.tpch.lineitem.l_partkey = tpch.tpch.partsupp.ps_partkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
