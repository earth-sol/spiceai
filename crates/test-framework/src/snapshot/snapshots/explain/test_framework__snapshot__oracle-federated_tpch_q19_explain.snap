|               |           HashJoinExec: mode=Partitioned, join_type=Inner, on=[(L_PARTKEY@0, P_PARTKEY@0)], filter=P_BRAND@1 = Brand#12 AND Use P_CONTAINER@3 IN (SET) ([Literal { value: Utf8("SM CASE"), field: Field { name: "SM CASE", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("SM BOX"), field: Field { name: "SM BOX", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("SM PACK"), field: Field { name: "SM PACK", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("SM PKG"), field: Field { name: "SM PKG", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND L_QUANTITY@0 >= Some(100),12,2 AND L_QUANTITY@0 <= Some(1100),12,2 AND P_SIZE@2 <= 5 OR P_BRAND@1 = Brand#23 AND Use P_CONTAINER@3 IN (SET) ([Literal { value: Utf8("MED BAG"), field: Field { name: "MED BAG", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("MED BOX"), field: Field { name: "MED BOX", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("MED PKG"), field: Field { name: "MED PKG", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("MED PACK"), field: Field { name: "MED PACK", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND L_QUANTITY@0 >= Some(1000),12,2 AND L_QUANTITY@0 <= Some(2000),12,2 AND P_SIZE@2 <= 10 OR P_BRAND@1 = Brand#34 AND Use P_CONTAINER@3 IN (SET) ([Literal { value: Utf8("LG CASE"), field: Field { name: "LG CASE", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("LG BOX"), field: Field { name: "LG BOX", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("LG PACK"), field: Field { name: "LG PACK", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("LG PKG"), field: Field { name: "LG PKG", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND L_QUANTITY@0 >= Some(2000),12,2 AND L_QUANTITY@0 <= Some(3000),12,2 AND P_SIZE@2 <= 15, projection=[L_EXTENDEDPRICE@2, L_DISCOUNT@3] |
