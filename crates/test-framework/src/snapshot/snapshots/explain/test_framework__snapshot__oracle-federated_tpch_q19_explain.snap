|               |       Inner Join: lineitem.L_PARTKEY = part.P_PARTKEY Filter: part.P_BRAND = Utf8("Brand#12") AND part.P_CONTAINER IN ([Utf8("SM CASE"), Utf8("SM BOX"), Utf8("SM PACK"), Utf8("SM PKG")]) AND lineitem.L_QUANTITY >= Decimal128(Some(100),12,2) AND lineitem.L_QUANTITY <= Decimal128(Some(1100),12,2) AND part.P_SIZE <= Int64(5) OR part.P_BRAND = Utf8("Brand#23") AND part.P_CONTAINER IN ([Utf8("MED BAG"), Utf8("MED BOX"), Utf8("MED PKG"), Utf8("MED PACK")]) AND lineitem.L_QUANTITY >= Decimal128(Some(1000),12,2) AND lineitem.L_QUANTITY <= Decimal128(Some(2000),12,2) AND part.P_SIZE <= Int64(10) OR part.P_BRAND = Utf8("Brand#34") AND part.P_CONTAINER IN ([Utf8("LG CASE"), Utf8("LG BOX"), Utf8("LG PACK"), Utf8("LG PKG")]) AND lineitem.L_QUANTITY >= Decimal128(Some(2000),12,2) AND lineitem.L_QUANTITY <= Decimal128(Some(3000),12,2) AND part.P_SIZE <= Int64(15)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
