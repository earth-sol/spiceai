|               |     VirtualExecutionPlan name=postgres compute_context=host=Tcp("benchmarking-postgres-rw.dataplatform.svc.cluster.local"),port=5432,db=clickbench_accelerated,user=postgres, sql=SELECT hits.URLHash, to_timestamp((hits.EventDate * 86400)), count(1) AS PageViews FROM hits WHERE ((((((hits.CounterID = 62) AND (to_timestamp((hits.EventDate * 86400)) >= '2013-07-01')) AND (to_timestamp((hits.EventDate * 86400)) <= '2013-07-31')) AND (hits.IsRefresh = 0)) AND hits.TraficSourceID IN (-1, 6)) AND (hits.RefererHash = 3594120000172545465)) GROUP BY hits.URLHash, to_timestamp((hits.EventDate * 86400)) ORDER BY PageViews DESC NULLS FIRST LIMIT 10 OFFSET 100 rewritten_sql=SELECT "hits"."URLHash", to_timestamp(("hits"."EventDate" * 86400)), count(1) AS "PageViews" FROM "hits" WHERE (((((("hits"."CounterID" = 62) AND (to_timestamp(("hits"."EventDate" * 86400)) >= '2013-07-01')) AND (to_timestamp(("hits"."EventDate" * 86400)) <= '2013-07-31')) AND ("hits"."IsRefresh" = 0)) AND "hits"."TraficSourceID" IN (-1, 6)) AND ("hits"."RefererHash" = 3594120000172545465)) GROUP BY "hits"."URLHash", to_timestamp(("hits"."EventDate" * 86400)) ORDER BY "PageViews" DESC NULLS FIRST LIMIT 10 OFFSET 100 |
