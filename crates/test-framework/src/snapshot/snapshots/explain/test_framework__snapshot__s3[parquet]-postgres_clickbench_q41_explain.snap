|               |         TableScan: hits projection=[EventDate, URLHash], full_filters=[hits.CounterID = Int64(62), to_timestamp(hits.EventDate * Int64(86400)) >= Utf8("2013-07-01"), to_timestamp(hits.EventDate * Int64(86400)) <= Utf8("2013-07-31"), hits.IsRefresh = Int64(0), hits.TraficSourceID IN ([Int64(-1), Int64(6)]), hits.RefererHash = Int64(3594120000172545465)]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
