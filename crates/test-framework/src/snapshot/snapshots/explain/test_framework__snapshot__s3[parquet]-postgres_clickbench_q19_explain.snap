|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |     VirtualExecutionPlan name=postgres compute_context=host=Tcp("benchmarking-postgres-rw.dataplatform.svc.cluster.local"),port=5432,db=clickbench_accelerated,user=postgres, sql=SELECT hits.UserID, date_part('MINUTE', CAST(to_timestamp(hits.EventTime) AS TIMESTAMP)) AS m, hits.SearchPhrase, count(1) AS "count(*)" FROM hits GROUP BY hits.UserID, date_part('MINUTE', CAST(to_timestamp(hits.EventTime) AS TIMESTAMP)), hits.SearchPhrase ORDER BY "count(*)" DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT "hits"."UserID", date_part('MINUTE', CAST(to_timestamp("hits"."EventTime") AS TIMESTAMP)) AS "m", "hits"."SearchPhrase", count(1) AS "count(*)" FROM "hits" GROUP BY "hits"."UserID", date_part('MINUTE', CAST(to_timestamp("hits"."EventTime") AS TIMESTAMP)), "hits"."SearchPhrase" ORDER BY "count(*)" DESC NULLS FIRST LIMIT 10 |
