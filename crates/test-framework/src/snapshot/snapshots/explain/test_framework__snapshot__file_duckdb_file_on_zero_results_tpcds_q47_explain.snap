| logical_plan  | Sort: v2.sum_sales - v2.avg_monthly_sales ASC NULLS LAST, v2.nsum ASC NULLS LAST, fetch=100                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
