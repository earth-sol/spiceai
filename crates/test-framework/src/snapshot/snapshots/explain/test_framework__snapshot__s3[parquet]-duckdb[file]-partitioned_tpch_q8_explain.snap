|               |                         Projection: supplier.s_nationkey, lineitem.l_extendedprice, lineitem.l_discount, orders.o_custkey, orders.o_orderdate                                                                                                                                                                                                        |
|               |                           Inner Join: lineitem.l_orderkey = orders.o_orderkey                                                                                                                                                                                                                                                                        |
