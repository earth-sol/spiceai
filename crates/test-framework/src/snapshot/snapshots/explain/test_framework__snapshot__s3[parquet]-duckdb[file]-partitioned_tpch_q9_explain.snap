|               |                       Inner Join: supplier.s_suppkey = lineitem.l_suppkey, part.p_partkey = lineitem.l_partkey                                                                                                                                                                                                     |
|               |                         Federated                                                                                                                                                                                                                                                                                  |
|               |  Projection: part.p_partkey, supplier.s_suppkey, supplier.s_nationkey                                                                                                                                                                                                                                              |
|               |   Cross Join:                                                                                                                                                                                                                                                                                                      |
|               |     TableScan: part projection=[p_partkey], full_filters=[part.p_name LIKE Utf8("%green%")]                                                                                                                                                                                                                        |
