| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
+---------------+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |  Sort: tpch.tpch.orders.o_totalprice DESC NULLS FIRST, tpch.tpch.orders.o_orderdate ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |   Projection: tpch.tpch.customer.c_name, tpch.tpch.customer.c_custkey, tpch.tpch.orders.o_orderkey, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_totalprice, sum(tpch.tpch.lineitem.l_quantity)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |     Aggregate: groupBy=[[tpch.tpch.customer.c_name, tpch.tpch.customer.c_custkey, tpch.tpch.orders.o_orderkey, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_totalprice]], aggr=[[sum(tpch.tpch.lineitem.l_quantity)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |       Inner Join:  Filter: tpch.tpch.orders.o_orderkey = tpch.tpch.lineitem.l_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |         Inner Join:  Filter: tpch.tpch.customer.c_custkey = tpch.tpch.orders.o_custkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |           TableScan: tpch.tpch.customer projection=[c_custkey, c_name]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |           Filter: tpch.tpch.orders.o_orderkey IN (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |             Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |               Projection: tpch.tpch.lineitem.l_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |                 Filter: sum(tpch.tpch.lineitem.l_quantity) > Int64(300)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |                   Aggregate: groupBy=[[tpch.tpch.lineitem.l_orderkey]], aggr=[[sum(tpch.tpch.lineitem.l_quantity)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |                     TableScan: tpch.tpch.lineitem                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |             TableScan: tpch.tpch.orders projection=[o_orderkey, o_custkey, o_totalprice, o_orderdate]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |         TableScan: tpch.tpch.lineitem projection=[l_orderkey, l_quantity]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT tpch.tpch.customer.c_name, tpch.tpch.customer.c_custkey, tpch.tpch.orders.o_orderkey, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_totalprice, sum(tpch.tpch.lineitem.l_quantity) FROM tpch.tpch.customer JOIN tpch.tpch.orders ON ((tpch.tpch.customer.c_custkey = tpch.tpch.orders.o_custkey) AND tpch.tpch.orders.o_orderkey IN (SELECT tpch.tpch.lineitem.l_orderkey FROM tpch.tpch.lineitem GROUP BY tpch.tpch.lineitem.l_orderkey HAVING (sum(tpch.tpch.lineitem.l_quantity) > 300))) JOIN tpch.tpch.lineitem ON (tpch.tpch.orders.o_orderkey = tpch.tpch.lineitem.l_orderkey) GROUP BY tpch.tpch.customer.c_name, tpch.tpch.customer.c_custkey, tpch.tpch.orders.o_orderkey, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_totalprice ORDER BY tpch.tpch.orders.o_totalprice DESC NULLS FIRST, tpch.tpch.orders.o_orderdate ASC NULLS LAST rewritten_sql=SELECT "spice"."tpch"."customer"."c_name", "spice"."tpch"."customer"."c_custkey", "spice"."tpch"."orders"."o_orderkey", "spice"."tpch"."orders"."o_orderdate", "spice"."tpch"."orders"."o_totalprice", sum("spice"."tpch"."lineitem"."l_quantity") FROM "spice"."tpch"."customer" JOIN "spice"."tpch"."orders" ON (("spice"."tpch"."customer"."c_custkey" = "spice"."tpch"."orders"."o_custkey") AND "spice"."tpch"."orders"."o_orderkey" IN (SELECT "spice"."tpch"."lineitem"."l_orderkey" FROM "spice"."tpch"."lineitem" GROUP BY "spice"."tpch"."lineitem"."l_orderkey" HAVING (sum("spice"."tpch"."lineitem"."l_quantity") > 300))) JOIN "spice"."tpch"."lineitem" ON ("spice"."tpch"."orders"."o_orderkey" = "spice"."tpch"."lineitem"."l_orderkey") GROUP BY "spice"."tpch"."customer"."c_name", "spice"."tpch"."customer"."c_custkey", "spice"."tpch"."orders"."o_orderkey", "spice"."tpch"."orders"."o_orderdate", "spice"."tpch"."orders"."o_totalprice" ORDER BY "spice"."tpch"."orders"."o_totalprice" DESC NULLS FIRST, "spice"."tpch"."orders"."o_orderdate" ASC NULLS LAST |
