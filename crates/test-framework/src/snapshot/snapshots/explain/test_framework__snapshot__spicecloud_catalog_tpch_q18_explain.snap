| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
+---------------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |  Sort: tpch.tpch.orders.o_totalprice DESC NULLS FIRST, tpch.tpch.orders.o_orderdate ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |   Projection: tpch.tpch.customer.c_name, tpch.tpch.customer.c_custkey, tpch.tpch.orders.o_orderkey, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_totalprice, sum(tpch.tpch.lineitem.l_quantity)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |     Aggregate: groupBy=[[tpch.tpch.customer.c_name, tpch.tpch.customer.c_custkey, tpch.tpch.orders.o_orderkey, tpch.tpch.orders.o_orderdate, tpch.tpch.orders.o_totalprice]], aggr=[[sum(tpch.tpch.lineitem.l_quantity)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |       Inner Join:  Filter: tpch.tpch.orders.o_orderkey = tpch.tpch.lineitem.l_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |         Inner Join:  Filter: tpch.tpch.customer.c_custkey = tpch.tpch.orders.o_custkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |           TableScan: tpch.tpch.customer projection=[c_custkey, c_name]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |           Filter: tpch.tpch.orders.o_orderkey IN (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |             Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |               Projection: tpch.tpch.lineitem.l_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |                 Filter: sum(tpch.tpch.lineitem.l_quantity) > Int64(300)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |                   Aggregate: groupBy=[[tpch.tpch.lineitem.l_orderkey]], aggr=[[sum(tpch.tpch.lineitem.l_quantity)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |                     TableScan: tpch.tpch.lineitem                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |             TableScan: tpch.tpch.orders projection=[o_orderkey, o_custkey, o_totalprice, o_orderdate]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |         TableScan: tpch.tpch.lineitem projection=[l_orderkey, l_quantity]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT c_name, c_custkey, o_orderkey, o_orderdate, o_totalprice, sum(lineitem.l_quantity) FROM tpch.tpch.customer JOIN tpch.tpch.orders ON ((customer.c_custkey = orders.o_custkey) AND orders.o_orderkey IN (SELECT l_orderkey FROM tpch.tpch.lineitem GROUP BY lineitem.l_orderkey HAVING (sum(lineitem.l_quantity) > 300))) JOIN tpch.tpch.lineitem ON (orders.o_orderkey = lineitem.l_orderkey) GROUP BY customer.c_name, customer.c_custkey, orders.o_orderkey, orders.o_orderdate, orders.o_totalprice ORDER BY o_totalprice DESC NULLS FIRST, o_orderdate ASC NULLS LAST rewritten_sql=SELECT "c_name", "c_custkey", "o_orderkey", "o_orderdate", "o_totalprice", sum("lineitem"."l_quantity") FROM "spice"."tpch"."customer" JOIN "spice"."tpch"."orders" ON (("customer"."c_custkey" = "orders"."o_custkey") AND "orders"."o_orderkey" IN (SELECT "l_orderkey" FROM "spice"."tpch"."lineitem" GROUP BY "lineitem"."l_orderkey" HAVING (sum("lineitem"."l_quantity") > 300))) JOIN "spice"."tpch"."lineitem" ON ("orders"."o_orderkey" = "lineitem"."l_orderkey") GROUP BY "customer"."c_name", "customer"."c_custkey", "orders"."o_orderkey", "orders"."o_orderdate", "orders"."o_totalprice" ORDER BY "o_totalprice" DESC NULLS FIRST, "o_orderdate" ASC NULLS LAST |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
