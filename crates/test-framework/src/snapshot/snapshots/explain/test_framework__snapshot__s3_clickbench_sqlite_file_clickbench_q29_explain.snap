| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |  Limit: skip=0, fetch=25                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |   Sort: l DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |     Projection: regexp_replace(hits.Referer,Utf8("^https?://(?:www\.)?([^/]+)/.*$"),Utf8("\1")) AS k, avg(character_length(hits.Referer)) AS l, count(*) AS c, min(hits.Referer)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |       Filter: count(*) > Int64(100000)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |         Aggregate: groupBy=[[regexp_replace(hits.Referer, Utf8("^https?://(?:www\.)?([^/]+)/.*$"), Utf8("\1"))]], aggr=[[avg(character_length(hits.Referer)), count(*), min(hits.Referer)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |           TableScan: hits projection=[Referer], full_filters=[hits.Referer != Utf8("")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |     VirtualExecutionPlan name=sqlite compute_context=/tmp/.tmpcHLWhJ/.spice/data/accelerated_sqlite.db sql=SELECT regexp_replace(hits.Referer, '^https?://(?:www\.)?([^/]+)/.*$', '\1') AS k, avg(character_length(hits.Referer)) AS l, count(*) AS c, min(hits.Referer) FROM hits WHERE (hits.Referer <> '') GROUP BY regexp_replace(hits.Referer, '^https?://(?:www\.)?([^/]+)/.*$', '\1') HAVING (count(*) > 100000) ORDER BY l DESC NULLS FIRST LIMIT 25 rewritten_sql=SELECT regexp_replace(`hits`.`Referer`, '^https?://(?:www\.)?([^/]+)/.*$', '\1') AS `k`, avg(length(`hits`.`Referer`)) AS `l`, count(*) AS `c`, min(`hits`.`Referer`) FROM `hits` WHERE (`hits`.`Referer` <> '') GROUP BY regexp_replace(`hits`.`Referer`, '^https?://(?:www\.)?([^/]+)/.*$', '\1') HAVING (count(*) > 100000) ORDER BY `l` DESC NULLS FIRST LIMIT 25 |
