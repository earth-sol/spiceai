                                 |
|               |                     TableScan: lineitem                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |             TableScan: orders projection=[o_orderkey, o_custkey, o_totalprice, o_orderdate]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |         TableScan: lineitem projection=[l_orderkey, l_quantity]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |     VirtualExecutionPlan name=odbc compute_context=484beb2c39d27ee2034e095ba8c4c011c9bae29c475355892b0545aeb910e82e sql=SELECT customer.c_name, customer.c_custkey, orders.o_orderkey, orders.o_orderdate, orders.o_totalprice, sum(lineitem.l_quantity) FROM customer JOIN orders ON ((customer.c_custkey = orders.o_custkey) AND orders.o_orderkey IN (SELECT lineitem.l_orderkey FROM lineitem GROUP BY lineitem.l_orderkey HAVING (sum(lineitem.l_quantity) > 300))) JOIN lineitem ON (orders.o_orderkey = lineitem.l_orderkey) GROUP BY customer.c_name, customer.c_custkey, orders.o_orderkey, orders.o_orderdate, orders.o_totalprice ORDER BY orders.o_totalprice DESC NULLS FIRST, orders.o_orderdate ASC NULLS LAST rewritten_sql=SELECT `spiceai_sandbox`.`tpch`.`customer`.`c_name`, `spiceai_sandbox`.`tpch`.`customer`.`c_custkey`, `spiceai_sandbox`.`tpch`.`orders`.`o_orderkey`, `spiceai_sandbox`.`tpch`.`orders`.`o_orderdate`, `spiceai_sandbox`.`tpch`.`orders`.`o_totalprice`, sum(`spiceai_sandbox`.`tpch`.`lineitem`.`l_quantity`) FROM `spiceai_sandbox`.`tpch`.`customer` JOIN `spiceai_sandbox`.`tpch`.`orders` ON ((`spiceai_sandbox`.`tpch`.`customer`.`c_custkey` = `spiceai_sandbox`.`tpch`.`orders`.`o_custkey`) AND `spiceai_sandbox`.`tpch`.`orders`.`o_orderkey` IN (SELECT `spiceai_sandbox`.`tpch`.`lineitem`.`l_orderkey` FROM `spiceai_sandbox`.`tpch`.`lineitem` GROUP BY `spiceai_sandbox`.`tpch`.`lineitem`.`l_orderkey` HAVING (sum(`spiceai_sandbox`.`tpch`.`lineitem`.`l_quantity`) > 300))) JOIN `spiceai_sandbox`.`tpch`.`lineitem` ON (`spiceai_sandbox`.`tpch`.`orders`.`o_orderkey` = `spiceai_sandbox`.`tpch`.`lineitem`.`l_orderkey`) GROUP BY `spiceai_sandbox`.`tpch`.`customer`.`c_name`, `spiceai_sandbox`.`tpch`.`customer`.`c_custkey`, `spiceai_sandbox`.`tpch`.`orders`.`o_orderkey`, `spiceai_sandbox`.`tpch`.`orders`.`o_orderdate`, `spiceai_sandbox`.`tpch`.`orders`.`o_totalprice` ORDER BY `spiceai_sandbox`.`tpch`.`orders`.`o_totalprice` DESC NULLS FIRST, `spiceai_sandbox`.`tpch`.`orders`.`o_orderdate` ASC NULLS LAST |
