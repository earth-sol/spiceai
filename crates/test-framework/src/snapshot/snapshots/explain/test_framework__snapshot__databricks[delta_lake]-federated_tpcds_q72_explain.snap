| logical_plan  | Sort: total_cnt DESC NULLS FIRST, item.i_item_desc ASC NULLS LAST, warehouse.w_warehouse_name ASC NULLS LAST, d1.d_week_seq ASC NULLS LAST, fetch=100                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
