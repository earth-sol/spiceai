| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
+---------------+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |  Sort: revenue DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |   Projection: tpch.tpch.customer.c_custkey, tpch.tpch.customer.c_name, sum(tpch.tpch.lineitem.l_extendedprice * Int64(1) - tpch.tpch.lineitem.l_discount) AS revenue, tpch.tpch.customer.c_acctbal, tpch.tpch.nation.n_name, tpch.tpch.customer.c_address, tpch.tpch.customer.c_phone, tpch.tpch.customer.c_comment                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |     Aggregate: groupBy=[[tpch.tpch.customer.c_custkey, tpch.tpch.customer.c_name, tpch.tpch.customer.c_acctbal, tpch.tpch.customer.c_phone, tpch.tpch.nation.n_name, tpch.tpch.customer.c_address, tpch.tpch.customer.c_comment]], aggr=[[sum(tpch.tpch.lineitem.l_extendedprice * (Int64(1) - tpch.tpch.lineitem.l_discount))]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |       Inner Join:  Filter: tpch.tpch.customer.c_nationkey = tpch.tpch.nation.n_nationkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |         Inner Join:  Filter: tpch.tpch.lineitem.l_orderkey = tpch.tpch.orders.o_orderkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |           Inner Join:  Filter: tpch.tpch.customer.c_custkey = tpch.tpch.orders.o_custkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |             TableScan: tpch.tpch.customer projection=[c_custkey, c_name, c_address, c_nationkey, c_phone, c_acctbal, c_comment]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |             Filter: tpch.tpch.orders.o_orderdate >= CAST(Utf8("1993-10-01") AS Date32) AND tpch.tpch.orders.o_orderdate < CAST(Utf8("1994-01-01") AS Date32)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |               TableScan: tpch.tpch.orders projection=[o_orderkey, o_custkey, o_orderdate]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |           TableScan: tpch.tpch.lineitem projection=[l_orderkey, l_extendedprice, l_discount], full_filters=[tpch.tpch.lineitem.l_returnflag = Utf8("R")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |         TableScan: tpch.tpch.nation projection=[n_nationkey, n_name]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT tpch.tpch.customer.c_custkey, tpch.tpch.customer.c_name, sum((tpch.tpch.lineitem.l_extendedprice * (1 - tpch.tpch.lineitem.l_discount))) AS revenue, tpch.tpch.customer.c_acctbal, tpch.tpch.nation.n_name, tpch.tpch.customer.c_address, tpch.tpch.customer.c_phone, tpch.tpch.customer.c_comment FROM tpch.tpch.customer JOIN tpch.tpch.orders ON ((tpch.tpch.customer.c_custkey = tpch.tpch.orders.o_custkey) AND ((tpch.tpch.orders.o_orderdate >= CAST('1993-10-01' AS DATE)) AND (tpch.tpch.orders.o_orderdate < CAST('1994-01-01' AS DATE)))) JOIN tpch.tpch.lineitem ON ((tpch.tpch.lineitem.l_orderkey = tpch.tpch.orders.o_orderkey) AND (tpch.tpch.lineitem.l_returnflag = 'R')) JOIN tpch.tpch.nation ON (tpch.tpch.customer.c_nationkey = tpch.tpch.nation.n_nationkey) GROUP BY tpch.tpch.customer.c_custkey, tpch.tpch.customer.c_name, tpch.tpch.customer.c_acctbal, tpch.tpch.customer.c_phone, tpch.tpch.nation.n_name, tpch.tpch.customer.c_address, tpch.tpch.customer.c_comment ORDER BY revenue DESC NULLS FIRST rewritten_sql=SELECT "spice"."tpch"."customer"."c_custkey", "spice"."tpch"."customer"."c_name", sum(("spice"."tpch"."lineitem"."l_extendedprice" * (1 - "spice"."tpch"."lineitem"."l_discount"))) AS "revenue", "spice"."tpch"."customer"."c_acctbal", "spice"."tpch"."nation"."n_name", "spice"."tpch"."customer"."c_address", "spice"."tpch"."customer"."c_phone", "spice"."tpch"."customer"."c_comment" FROM "spice"."tpch"."customer" JOIN "spice"."tpch"."orders" ON (("spice"."tpch"."customer"."c_custkey" = "spice"."tpch"."orders"."o_custkey") AND (("spice"."tpch"."orders"."o_orderdate" >= CAST('1993-10-01' AS DATE)) AND ("spice"."tpch"."orders"."o_orderdate" < CAST('1994-01-01' AS DATE)))) JOIN "spice"."tpch"."lineitem" ON (("spice"."tpch"."lineitem"."l_orderkey" = "spice"."tpch"."orders"."o_orderkey") AND ("spice"."tpch"."lineitem"."l_returnflag" = 'R')) JOIN "spice"."tpch"."nation" ON ("spice"."tpch"."customer"."c_nationkey" = "spice"."tpch"."nation"."n_nationkey") GROUP BY "spice"."tpch"."customer"."c_custkey", "spice"."tpch"."customer"."c_name", "spice"."tpch"."customer"."c_acctbal", "spice"."tpch"."customer"."c_phone", "spice"."tpch"."nation"."n_name", "spice"."tpch"."customer"."c_address", "spice"."tpch"."customer"."c_comment" ORDER BY "revenue" DESC NULLS FIRST |
