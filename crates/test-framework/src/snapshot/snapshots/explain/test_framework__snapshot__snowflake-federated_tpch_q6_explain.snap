|               |     VirtualExecutionPlan name=snowflake compute_context=username=sergei,account=CDQYZFU-SH58225 sql=SELECT sum((lineitem.L_EXTENDEDPRICE * lineitem.L_DISCOUNT)) AS REVENUE FROM lineitem WHERE (((lineitem.L_SHIPDATE >= CAST('1994-01-01' AS DATE)) AND (lineitem.L_SHIPDATE < CAST('1995-01-01' AS DATE))) AND (lineitem.L_DISCOUNT BETWEEN (0.06 - 0.01) AND (0.06 + 0.01))) AND (lineitem.L_QUANTITY < 24) rewritten_sql=SELECT sum(("LINEITEM"."L_EXTENDEDPRICE" * "LINEITEM"."L_DISCOUNT")) AS "REVENUE" FROM "BENCHMARKS"."TPCH_SF1"."LINEITEM" WHERE ((("LINEITEM"."L_SHIPDATE" >= CAST('1994-01-01' AS DATE)) AND ("LINEITEM"."L_SHIPDATE" < CAST('1995-01-01' AS DATE))) AND ("LINEITEM"."L_DISCOUNT" BETWEEN (0.06 - 0.01) AND (0.06 + 0.01))) AND ("LINEITEM"."L_QUANTITY" < 24) |
