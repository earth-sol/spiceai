|               |     VirtualExecutionPlan name=postgres compute_context=host=Tcp("benchmarking-postgres-rw.dataplatform.svc.cluster.local"),port=5432,db=clickbench_accelerated,user=postgres, initial_sql=SELECT "hits"."RegionID", count(DISTINCT "hits"."UserID") AS "u" FROM "hits" GROUP BY "hits"."RegionID" ORDER BY "u" DESC NULLS FIRST LIMIT 10 |
