|               |   Projection: hadoop.tpch.lineitem.l_returnflag, hadoop.tpch.lineitem.l_linestatus, sum(hadoop.tpch.lineitem.l_quantity) AS sum_qty, sum(hadoop.tpch.lineitem.l_extendedprice) AS sum_base_price, sum(hadoop.tpch.lineitem.l_extendedprice * Int64(1) - hadoop.tpch.lineitem.l_discount) AS sum_disc_price, sum(hadoop.tpch.lineitem.l_extendedprice * Int64(1) - hadoop.tpch.lineitem.l_discount * Int64(1) + hadoop.tpch.lineitem.l_tax) AS sum_charge, avg(hadoop.tpch.lineitem.l_quantity) AS avg_qty, avg(hadoop.tpch.lineitem.l_extendedprice) AS avg_price, avg(hadoop.tpch.lineitem.l_discount) AS avg_disc, count(Int64(1)) AS count_order                        |
