|               |     ProjectionExec: expr=[l_returnflag@0 as l_returnflag, l_linestatus@1 as l_linestatus, sum(hadoop.tpch.lineitem.l_quantity)@2 as sum_qty, sum(hadoop.tpch.lineitem.l_extendedprice)@3 as sum_base_price, sum(hadoop.tpch.lineitem.l_extendedprice * Int64(1) - hadoop.tpch.lineitem.l_discount)@4 as sum_disc_price, sum(hadoop.tpch.lineitem.l_extendedprice * Int64(1) - hadoop.tpch.lineitem.l_discount * Int64(1) + hadoop.tpch.lineitem.l_tax)@5 as sum_charge, avg(hadoop.tpch.lineitem.l_quantity)@6 as avg_qty, avg(hadoop.tpch.lineitem.l_extendedprice)@7 as avg_price, avg(hadoop.tpch.lineitem.l_discount)@8 as avg_disc, count(Int64(1))@9 as count_order] |
