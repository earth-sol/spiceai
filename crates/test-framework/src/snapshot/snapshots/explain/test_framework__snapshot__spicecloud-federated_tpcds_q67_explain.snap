|               |  Limit: skip=0, fetch=100                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |   Sort: dw2.i_category ASC NULLS LAST, dw2.i_class ASC NULLS LAST, dw2.i_brand ASC NULLS LAST, dw2.i_product_name ASC NULLS LAST, dw2.d_year ASC NULLS LAST, dw2.d_qoy ASC NULLS LAST, dw2.d_moy ASC NULLS LAST, dw2.s_store_id ASC NULLS LAST, dw2.sumsales ASC NULLS LAST, dw2.rk ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |     Projection: dw2.i_category, dw2.i_class, dw2.i_brand, dw2.i_product_name, dw2.d_year, dw2.d_qoy, dw2.d_moy, dw2.s_store_id, dw2.sumsales, dw2.rk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |       Filter: dw2.rk <= Int64(100)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |         SubqueryAlias: dw2                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |           Projection: dw1.i_category, dw1.i_class, dw1.i_brand, dw1.i_product_name, dw1.d_year, dw1.d_qoy, dw1.d_moy, dw1.s_store_id, dw1.sumsales, rank() PARTITION BY [dw1.i_category] ORDER BY [dw1.sumsales DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW AS rk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |             WindowAggr: windowExpr=[[rank() PARTITION BY [dw1.i_category] ORDER BY [dw1.sumsales DESC NULLS FIRST] RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |               SubqueryAlias: dw1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |                 Projection: item.i_category, item.i_class, item.i_brand, item.i_product_name, date_dim.d_year, date_dim.d_qoy, date_dim.d_moy, store.s_store_id, sum(coalesce(store_sales.ss_sales_price * store_sales.ss_quantity,Int64(0))) AS sumsales                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |                   Aggregate: groupBy=[[ROLLUP (item.i_category, item.i_class, item.i_brand, item.i_product_name, date_dim.d_year, date_dim.d_qoy, date_dim.d_moy, store.s_store_id)]], aggr=[[sum(coalesce(store_sales.ss_sales_price * store_sales.ss_quantity, Int64(0)))]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |                     Inner Join:  Filter: store_sales.ss_item_sk = item.i_item_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |                       Inner Join:  Filter: store_sales.ss_store_sk = store.s_store_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |                         Inner Join:  Filter: store_sales.ss_sold_date_sk = date_dim.d_date_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |                           TableScan: store_sales projection=[ss_sold_date_sk, ss_item_sk, ss_store_sk, ss_quantity, ss_sales_price]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |                           Filter: date_dim.d_month_seq BETWEEN Int64(1194) AND Int64(1194) + Int64(11)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |                             TableScan: date_dim projection=[d_date_sk, d_month_seq, d_year, d_moy, d_qoy]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |                         TableScan: store projection=[s_store_sk, s_store_id]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |                       TableScan: item projection=[i_item_sk, i_brand, i_class, i_category, i_product_name]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |   CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |       VirtualExecutionPlan name=spice.ai compute_context=url=https://dev-flight.spiceai.io,username=,org=spiceai,app=benchmarks-tpcds initial_sql=SELECT "dw2"."i_category", "dw2"."i_class", "dw2"."i_brand", "dw2"."i_product_name", "dw2"."d_year", "dw2"."d_qoy", "dw2"."d_moy", "dw2"."s_store_id", "dw2"."sumsales", "dw2"."rk" FROM (SELECT "dw1"."i_category", "dw1"."i_class", "dw1"."i_brand", "dw1"."i_product_name", "dw1"."d_year", "dw1"."d_qoy", "dw1"."d_moy", "dw1"."s_store_id", "dw1"."sumsales", rank() OVER (PARTITION BY "dw1"."i_category" ORDER BY "dw1"."sumsales" DESC NULLS FIRST RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS "rk" FROM (SELECT "item"."i_category", "item"."i_class", "item"."i_brand", "item"."i_product_name", "date_dim"."d_year", "date_dim"."d_qoy", "date_dim"."d_moy", "store"."s_store_id", sum(coalesce(("store_sales"."ss_sales_price" * "store_sales"."ss_quantity"), 0)) AS "sumsales" FROM "store_sales" INNER JOIN "date_dim" ON (("store_sales"."ss_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_month_seq" BETWEEN 1194 AND (1194 + 11))) INNER JOIN "store" ON ("store_sales"."ss_store_sk" = "store"."s_store_sk") INNER JOIN "item" ON ("store_sales"."ss_item_sk" = "item"."i_item_sk") GROUP BY ROLLUP ("item"."i_category", "item"."i_class", "item"."i_brand", "item"."i_product_name", "date_dim"."d_year", "date_dim"."d_qoy", "date_dim"."d_moy", "store"."s_store_id")) AS "dw1") AS "dw2" WHERE ("dw2"."rk" <= 100) ORDER BY "dw2"."i_category" ASC NULLS LAST, "dw2"."i_class" ASC NULLS LAST, "dw2"."i_brand" ASC NULLS LAST, "dw2"."i_product_name" ASC NULLS LAST, "dw2"."d_year" ASC NULLS LAST, "dw2"."d_qoy" ASC NULLS LAST, "dw2"."d_moy" ASC NULLS LAST, "dw2"."s_store_id" ASC NULLS LAST, "dw2"."sumsales" ASC NULLS LAST, "dw2"."rk" ASC NULLS LAST LIMIT 100 rewritten_sql=SELECT "dw2"."i_category", "dw2"."i_class", "dw2"."i_brand", "dw2"."i_product_name", "dw2"."d_year", "dw2"."d_qoy", "dw2"."d_moy", "dw2"."s_store_id", "dw2"."sumsales", "dw2"."rk" FROM (SELECT "dw1"."i_category", "dw1"."i_class", "dw1"."i_brand", "dw1"."i_product_name", "dw1"."d_year", "dw1"."d_qoy", "dw1"."d_moy", "dw1"."s_store_id", "dw1"."sumsales", rank() OVER (PARTITION BY "dw1"."i_category" ORDER BY "dw1"."sumsales" DESC NULLS FIRST RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS "rk" FROM (SELECT "i_category", "i_class", "i_brand", "i_product_name", "d_year", "d_qoy", "d_moy", "s_store_id", sum(coalesce(("store_sales"."ss_sales_price" * "store_sales"."ss_quantity"), 0)) AS "sumsales" FROM "tpcds"."store_sales" INNER JOIN "tpcds"."date_dim" ON (("store_sales"."ss_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_month_seq" BETWEEN 1194 AND (1194 + 11))) INNER JOIN "tpcds"."store" ON ("store_sales"."ss_store_sk" = "store"."s_store_sk") INNER JOIN "tpcds"."item" ON ("store_sales"."ss_item_sk" = "item"."i_item_sk") GROUP BY ROLLUP ("item"."i_category", "item"."i_class", "item"."i_brand", "item"."i_product_name", "date_dim"."d_year", "date_dim"."d_qoy", "date_dim"."d_moy", "store"."s_store_id")) AS "dw1") AS "dw2" WHERE ("dw2"."rk" <= 100) ORDER BY "dw2"."i_category" ASC NULLS LAST, "dw2"."i_class" ASC NULLS LAST, "dw2"."i_brand" ASC NULLS LAST, "dw2"."i_product_name" ASC NULLS LAST, "dw2"."d_year" ASC NULLS LAST, "dw2"."d_qoy" ASC NULLS LAST, "dw2"."d_moy" ASC NULLS LAST, "dw2"."s_store_id" ASC NULLS LAST, "dw2"."sumsales" ASC NULLS LAST, "dw2"."rk" ASC NULLS LAST LIMIT 100 |
