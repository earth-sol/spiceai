|               |                     Projection: lineitem.l_discount, lineitem.l_extendedprice, lineitem.l_orderkey, lineitem.l_partkey, lineitem.l_quantity, lineitem.l_suppkey, supplier.s_nationkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |                       Inner Join: lineitem.l_suppkey = supplier.s_suppkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
