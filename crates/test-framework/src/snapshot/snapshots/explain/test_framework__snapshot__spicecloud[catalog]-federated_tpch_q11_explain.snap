+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |  Sort: value DESC NULLS FIRST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |   Projection: tpch.tpch.partsupp.ps_partkey, sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty) AS value                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |     Filter: sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty) > (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |       Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |         Projection: sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty) * Float64(0.0001)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |           Aggregate: groupBy=[[]], aggr=[[sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |             Inner Join:  Filter: tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |               Inner Join:  Filter: tpch.tpch.partsupp.ps_suppkey = tpch.tpch.supplier.s_suppkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |                 TableScan: tpch.tpch.partsupp                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |                 TableScan: tpch.tpch.supplier                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |               TableScan: tpch.tpch.nation, full_filters=[tpch.tpch.nation.n_name = Utf8("GERMANY")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |       Aggregate: groupBy=[[tpch.tpch.partsupp.ps_partkey]], aggr=[[sum(tpch.tpch.partsupp.ps_supplycost * tpch.tpch.partsupp.ps_availqty)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |         Inner Join:  Filter: tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |           Inner Join:  Filter: tpch.tpch.partsupp.ps_suppkey = tpch.tpch.supplier.s_suppkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |             TableScan: tpch.tpch.partsupp projection=[ps_partkey, ps_suppkey, ps_availqty, ps_supplycost]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |             TableScan: tpch.tpch.supplier projection=[s_suppkey, s_nationkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |           TableScan: tpch.tpch.nation projection=[n_nationkey], full_filters=[tpch.tpch.nation.n_name = Utf8("GERMANY")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch initial_sql=SELECT "ps_partkey", sum(("partsupp"."ps_supplycost" * "partsupp"."ps_availqty")) AS "value" FROM "tpch"."tpch"."partsupp" INNER JOIN "tpch"."tpch"."supplier" ON ("partsupp"."ps_suppkey" = "supplier"."s_suppkey") INNER JOIN "tpch"."tpch"."nation" ON (("supplier"."s_nationkey" = "nation"."n_nationkey") AND ("nation"."n_name" = 'GERMANY')) GROUP BY "partsupp"."ps_partkey" HAVING (sum(("partsupp"."ps_supplycost" * "partsupp"."ps_availqty")) > (SELECT (sum(("partsupp"."ps_supplycost" * "partsupp"."ps_availqty")) * 0.0001) FROM "tpch"."tpch"."partsupp" INNER JOIN "tpch"."tpch"."supplier" ON ("partsupp"."ps_suppkey" = "supplier"."s_suppkey") INNER JOIN "tpch"."tpch"."nation" ON (("supplier"."s_nationkey" = "nation"."n_nationkey") AND ("nation"."n_name" = 'GERMANY')))) ORDER BY "value" DESC NULLS FIRST rewritten_sql=SELECT "ps_partkey", sum(("partsupp"."ps_supplycost" * "partsupp"."ps_availqty")) AS "value" FROM "spice"."tpch"."partsupp" INNER JOIN "spice"."tpch"."supplier" ON ("partsupp"."ps_suppkey" = "supplier"."s_suppkey") INNER JOIN "spice"."tpch"."nation" ON (("supplier"."s_nationkey" = "nation"."n_nationkey") AND ("nation"."n_name" = 'GERMANY')) GROUP BY "partsupp"."ps_partkey" HAVING (sum(("partsupp"."ps_supplycost" * "partsupp"."ps_availqty")) > (SELECT (sum(("partsupp"."ps_supplycost" * "partsupp"."ps_availqty")) * 0.0001) FROM "spice"."tpch"."partsupp" INNER JOIN "spice"."tpch"."supplier" ON ("partsupp"."ps_suppkey" = "supplier"."s_suppkey") INNER JOIN "spice"."tpch"."nation" ON (("supplier"."s_nationkey" = "nation"."n_nationkey") AND ("nation"."n_name" = 'GERMANY')))) ORDER BY "value" DESC NULLS FIRST |
