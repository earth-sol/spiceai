|               |                   Filter: outer_ref(tpch.tpch.part.p_partkey) = tpch.tpch.partsupp.ps_partkey AND tpch.tpch.supplier.s_suppkey = tpch.tpch.partsupp.ps_suppkey AND tpch.tpch.supplier.s_nationkey = tpch.tpch.nation.n_nationkey AND tpch.tpch.nation.n_regionkey = tpch.tpch.region.r_regionkey AND tpch.tpch.region.r_name = Utf8("EUROPE")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 