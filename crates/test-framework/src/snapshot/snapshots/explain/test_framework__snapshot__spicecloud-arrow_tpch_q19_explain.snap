le: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("LG PACK"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: LargeUtf8("LG PKG"), field: Field { name: "lit", data_type: LargeUtf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND l_quantity@0 >= Some(2000),15,2 AND l_quantity@0 <= Some(3000),15,2 AND p_size@2 <= 15, projection=[l_extendedprice@2, l_discount@3] |
