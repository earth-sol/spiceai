|               |                                                 BytesProcessedExec                                                                                                                                            |
|               |                                                   OracleExec sql=SELECT "L_ORDERKEY", "L_SUPPKEY", "L_EXTENDEDPRICE", "L_DISCOUNT" FROM "TPCH_SF1"."LINEITEM"                                                 |
|               |                                   CoalesceBatchesExec: target_batch_size=8192                                                                                                                                 |
|               |                                     RepartitionExec: partitioning=Hash([S_SUPPKEY@0, S_NATIONKEY@1], 16), input_partitions=16                                                                                 |
