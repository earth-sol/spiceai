|               |                                         BytesProcessedExec                                                                                                                                                    |
|               |                                           OracleExec sql=SELECT "S_SUPPKEY", "S_NATIONKEY" FROM "TPCH_SF1"."SUPPLIER"                                                                                         |
|               |                           CoalesceBatchesExec: target_batch_size=8192                                                                                                                                         |
|               |                             RepartitionExec: partitioning=Hash([N_NATIONKEY@0], 16), input_partitions=16                                                                                                      |
