| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
+---------------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |  Sort: tpch.tpch.lineitem.l_returnflag ASC NULLS LAST, tpch.tpch.lineitem.l_linestatus ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |   Projection: tpch.tpch.lineitem.l_returnflag, tpch.tpch.lineitem.l_linestatus, sum(tpch.tpch.lineitem.l_quantity) AS sum_qty, sum(tpch.tpch.lineitem.l_extendedprice) AS sum_base_price, sum(tpch.tpch.lineitem.l_extendedprice * Int64(1) - tpch.tpch.lineitem.l_discount) AS sum_disc_price, sum(tpch.tpch.lineitem.l_extendedprice * Int64(1) - tpch.tpch.lineitem.l_discount * Int64(1) + tpch.tpch.lineitem.l_tax) AS sum_charge, avg(tpch.tpch.lineitem.l_quantity) AS avg_qty, avg(tpch.tpch.lineitem.l_extendedprice) AS avg_price, avg(tpch.tpch.lineitem.l_discount) AS avg_disc, count(*) AS count_order                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     Aggregate: groupBy=[[tpch.tpch.lineitem.l_returnflag, tpch.tpch.lineitem.l_linestatus]], aggr=[[sum(tpch.tpch.lineitem.l_quantity), sum(tpch.tpch.lineitem.l_extendedprice), sum(tpch.tpch.lineitem.l_extendedprice * (Int64(1) - tpch.tpch.lineitem.l_discount)), sum(tpch.tpch.lineitem.l_extendedprice * (Int64(1) - tpch.tpch.lineitem.l_discount) * (Int64(1) + tpch.tpch.lineitem.l_tax)), avg(tpch.tpch.lineitem.l_quantity), avg(tpch.tpch.lineitem.l_extendedprice), avg(tpch.tpch.lineitem.l_discount), count(*)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |       Filter: tpch.tpch.lineitem.l_shipdate <= CAST(Utf8("1998-09-02") AS Date32)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |         TableScan: tpch.tpch.lineitem projection=[l_quantity, l_extendedprice, l_discount, l_tax, l_returnflag, l_linestatus, l_shipdate]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT l_returnflag, l_linestatus, sum(lineitem.l_quantity) AS sum_qty, sum(lineitem.l_extendedprice) AS sum_base_price, sum((lineitem.l_extendedprice * (1 - lineitem.l_discount))) AS sum_disc_price, sum(((lineitem.l_extendedprice * (1 - lineitem.l_discount)) * (1 + lineitem.l_tax))) AS sum_charge, avg(lineitem.l_quantity) AS avg_qty, avg(lineitem.l_extendedprice) AS avg_price, avg(lineitem.l_discount) AS avg_disc, count(*) AS count_order FROM tpch.tpch.lineitem WHERE (lineitem.l_shipdate <= CAST('1998-09-02' AS DATE)) GROUP BY lineitem.l_returnflag, lineitem.l_linestatus ORDER BY l_returnflag ASC NULLS LAST, l_linestatus ASC NULLS LAST rewritten_sql=SELECT "l_returnflag", "l_linestatus", sum("lineitem"."l_quantity") AS "sum_qty", sum("lineitem"."l_extendedprice") AS "sum_base_price", sum(("lineitem"."l_extendedprice" * (1 - "lineitem"."l_discount"))) AS "sum_disc_price", sum((("lineitem"."l_extendedprice" * (1 - "lineitem"."l_discount")) * (1 + "lineitem"."l_tax"))) AS "sum_charge", avg("lineitem"."l_quantity") AS "avg_qty", avg("lineitem"."l_extendedprice") AS "avg_price", avg("lineitem"."l_discount") AS "avg_disc", count(*) AS "count_order" FROM "spice"."tpch"."lineitem" WHERE ("lineitem"."l_shipdate" <= CAST('1998-09-02' AS DATE)) GROUP BY "lineitem"."l_returnflag", "lineitem"."l_linestatus" ORDER BY "l_returnflag" ASC NULLS LAST, "l_linestatus" ASC NULLS LAST |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
