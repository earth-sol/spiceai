|               |                                       ProjectionExec: expr=[o_custkey@0 as o_custkey, o_orderkey@2 as o_orderkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
