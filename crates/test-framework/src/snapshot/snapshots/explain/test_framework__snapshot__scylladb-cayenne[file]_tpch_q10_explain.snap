|               |                             ProjectionExec: expr=[l_discount@0 as l_discount, l_extendedprice@1 as l_extendedprice, l_orderkey@2 as l_orderkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
