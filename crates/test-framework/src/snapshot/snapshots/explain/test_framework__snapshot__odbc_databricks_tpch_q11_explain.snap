                                                                                                                                    |
|               |             TableScan: partsupp projection=[ps_partkey, ps_suppkey, ps_availqty, ps_supplycost]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |             TableScan: supplier projection=[s_suppkey, s_nationkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |           TableScan: nation projection=[n_nationkey], full_filters=[nation.n_name = Utf8("GERMANY")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     VirtualExecutionPlan name=odbc compute_context=484beb2c39d27ee2034e095ba8c4c011c9bae29c475355892b0545aeb910e82e sql=SELECT partsupp.ps_partkey, sum((partsupp.ps_supplycost * partsupp.ps_availqty)) AS "value" FROM partsupp JOIN supplier ON (partsupp.ps_suppkey = supplier.s_suppkey) JOIN nation ON ((supplier.s_nationkey = nation.n_nationkey) AND (nation.n_name = 'GERMANY')) GROUP BY partsupp.ps_partkey HAVING (sum((partsupp.ps_supplycost * partsupp.ps_availqty)) > (SELECT (sum((partsupp.ps_supplycost * partsupp.ps_availqty)) * 0.0001) FROM partsupp JOIN supplier ON true JOIN nation ON true WHERE (((partsupp.ps_suppkey = supplier.s_suppkey) AND (supplier.s_nationkey = nation.n_nationkey)) AND (nation.n_name = 'GERMANY')))) ORDER BY "value" DESC NULLS FIRST rewritten_sql=SELECT `spiceai_sandbox`.`tpch`.`partsupp`.`ps_partkey`, sum((`spiceai_sandbox`.`tpch`.`partsupp`.`ps_supplycost` * `spiceai_sandbox`.`tpch`.`partsupp`.`ps_availqty`)) AS `value` FROM `spiceai_sandbox`.`tpch`.`partsupp` JOIN `spiceai_sandbox`.`tpch`.`supplier` ON (`spiceai_sandbox`.`tpch`.`partsupp`.`ps_suppkey` = `spiceai_sandbox`.`tpch`.`supplier`.`s_suppkey`) JOIN `spiceai_sandbox`.`tpch`.`nation` ON ((`spiceai_sandbox`.`tpch`.`supplier`.`s_nationkey` = `spiceai_sandbox`.`tpch`.`nation`.`n_nationkey`) AND (`spiceai_sandbox`.`tpch`.`nation`.`n_name` = 'GERMANY')) GROUP BY `spiceai_sandbox`.`tpch`.`partsupp`.`ps_partkey` HAVING (sum((`spiceai_sandbox`.`tpch`.`partsupp`.`ps_supplycost` * `spiceai_sandbox`.`tpch`.`partsupp`.`ps_availqty`)) > (SELECT (sum((`spiceai_sandbox`.`tpch`.`partsupp`.`ps_supplycost` * `spiceai_sandbox`.`tpch`.`partsupp`.`ps_availqty`)) * 0.0001) FROM `spiceai_sandbox`.`tpch`.`partsupp` JOIN `spiceai_sandbox`.`tpch`.`supplier` ON true JOIN `spiceai_sandbox`.`tpch`.`nation` ON true WHERE (((`spiceai_sandbox`.`tpch`.`partsupp`.`ps_suppkey` = `spiceai_sandbox`.`tpch`.`supplier`.`s_suppkey`) AND (`spiceai_sandbox`.`tpch`.`supplier`.`s_nationkey` = `spiceai_sandbox`.`tpch`.`nation`.`n_nationkey`)) AND (`spiceai_sandbox`.`tpch`.`nation`.`n_name` = 'GERMANY')))) ORDER BY `value` DESC NULLS FIRST |
