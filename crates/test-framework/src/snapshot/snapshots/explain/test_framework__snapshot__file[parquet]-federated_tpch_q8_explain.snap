|               |               ProjectionExec: expr=[date_part(YEAR, o_orderdate@2) as o_year, l_extendedprice@0 * (Some(1),20,0 - l_discount@1) as volume, n_name@3 as nation]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
