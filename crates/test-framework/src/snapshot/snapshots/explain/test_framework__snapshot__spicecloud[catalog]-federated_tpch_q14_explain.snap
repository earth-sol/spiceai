+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
+---------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |  Projection: Float64(100) * sum(CASE WHEN tpch.tpch.part.p_type LIKE Utf8("PROMO%") THEN tpch.tpch.lineitem.l_extendedprice * Int64(1) - tpch.tpch.lineitem.l_discount ELSE Int64(0) END) / sum(tpch.tpch.lineitem.l_extendedprice * Int64(1) - tpch.tpch.lineitem.l_discount) AS promo_revenue                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |   Aggregate: groupBy=[[]], aggr=[[sum(CASE WHEN tpch.tpch.part.p_type LIKE Utf8("PROMO%") THEN tpch.tpch.lineitem.l_extendedprice * (Int64(1) - tpch.tpch.lineitem.l_discount) ELSE Int64(0) END), sum(tpch.tpch.lineitem.l_extendedprice * (Int64(1) - tpch.tpch.lineitem.l_discount))]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |     Inner Join:  Filter: tpch.tpch.lineitem.l_partkey = tpch.tpch.part.p_partkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |       Filter: tpch.tpch.lineitem.l_shipdate >= CAST(Utf8("1995-09-01") AS Date32) AND tpch.tpch.lineitem.l_shipdate < CAST(Utf8("1995-10-01") AS Date32)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |         TableScan: tpch.tpch.lineitem projection=[l_partkey, l_extendedprice, l_discount, l_shipdate]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |       TableScan: tpch.tpch.part projection=[p_partkey, p_type]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |   CooperativeExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |       VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch initial_sql=SELECT ((100.0 * sum(CASE WHEN "part"."p_type" LIKE 'PROMO%' THEN ("lineitem"."l_extendedprice" * (1 - "lineitem"."l_discount")) ELSE 0 END)) / sum(("lineitem"."l_extendedprice" * (1 - "lineitem"."l_discount")))) AS "promo_revenue" FROM "tpch"."tpch"."lineitem" INNER JOIN "tpch"."tpch"."part" ON (("lineitem"."l_partkey" = "part"."p_partkey") AND (("lineitem"."l_shipdate" >= CAST('1995-09-01' AS DATE)) AND ("lineitem"."l_shipdate" < CAST('1995-10-01' AS DATE)))) rewritten_sql=SELECT ((100.0 * sum(CASE WHEN "part"."p_type" LIKE 'PROMO%' THEN ("lineitem"."l_extendedprice" * (1 - "lineitem"."l_discount")) ELSE 0 END)) / sum(("lineitem"."l_extendedprice" * (1 - "lineitem"."l_discount")))) AS "promo_revenue" FROM "spice"."tpch"."lineitem" INNER JOIN "spice"."tpch"."part" ON (("lineitem"."l_partkey" = "part"."p_partkey") AND (("lineitem"."l_shipdate" >= CAST('1995-09-01' AS DATE)) AND ("lineitem"."l_shipdate" < CAST('1995-10-01' AS DATE)))) |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
