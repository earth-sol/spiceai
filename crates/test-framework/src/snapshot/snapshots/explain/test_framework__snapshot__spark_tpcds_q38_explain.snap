|               |     VirtualExecutionPlan name=SparkConnect compute_context=sc://dbc-f34ee0b7-90f2.cloud.databricks.com:443/;user_id=spice.ai;x-databricks-cluster-id=0711-151224-1rh2uz8m;use_ssl=true sql=SELECT count(*) FROM (SELECT DISTINCT customer.c_last_name, customer.c_first_name, date_dim.d_date FROM store_sales JOIN date_dim ON ((store_sales.ss_sold_date_sk = date_dim.d_date_sk) AND (date_dim.d_month_seq BETWEEN 1190 AND (1190 + 11))) JOIN customer ON (store_sales.ss_customer_sk = customer.c_customer_sk) LEFT SEMI JOIN (SELECT DISTINCT customer.c_last_name, customer.c_first_name, date_dim.d_date FROM catalog_sales JOIN date_dim ON ((catalog_sales.cs_sold_date_sk = date_dim.d_date_sk) AND (date_dim.d_month_seq BETWEEN 1190 AND (1190 + 11))) JOIN customer ON (catalog_sales.cs_bill_customer_sk = customer.c_customer_sk)) ON customer.c_last_name = customer.c_last_name AND customer.c_first_name = customer.c_first_name AND date_dim.d_date = date_dim.d_date) AS hot_cust LEFT SEMI JOIN (SELECT DISTINCT customer.c_last_name, customer.c_first_name, date_dim.d_date FROM web_sales JOIN date_dim ON ((web_sales.ws_sold_date_sk = date_dim.d_date_sk) AND (date_dim.d_month_seq BETWEEN 1190 AND (1190 + 11))) JOIN customer ON (web_sales.ws_bill_customer_sk = customer.c_customer_sk)) ON customer.c_last_name = customer.c_last_name AND customer.c_first_name = customer.c_first_name AND date_dim.d_date = date_dim.d_date LIMIT 100 rewritten_sql=SELECT count(*) FROM (SELECT DISTINCT `spiceai_sandbox`.`tpcds`.`customer`.`c_last_name`, `spiceai_sandbox`.`tpcds`.`customer`.`c_first_name`, `spiceai_sandbox`.`tpcds`.`date_dim`.`d_date` FROM `spiceai_sandbox`.`tpcds`.`store_sales` JOIN `spiceai_sandbox`.`tpcds`.`date_dim` ON ((`spiceai_sandbox`.`tpcds`.`store_sales`.`ss_sold_date_sk` = `spiceai_sandbox`.`tpcds`.`date_dim`.`d_date_sk`) AND (`spiceai_sandbox`.`tpcds`.`date_dim`.`d_month_seq` BETWEEN 1190 AND (1190 + 11))) JOIN `spiceai_sandbox`.`tpcds`.`customer` ON (`spiceai_sandbox`.`tpcds`