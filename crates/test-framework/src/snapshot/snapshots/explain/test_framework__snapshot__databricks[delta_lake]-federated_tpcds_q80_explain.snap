|               |           Projection: Utf8("web channel") AS channel, Utf8("web_site") || wsr.web_site_id AS id, wsr.sales, wsr.returns, wsr.profit                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
