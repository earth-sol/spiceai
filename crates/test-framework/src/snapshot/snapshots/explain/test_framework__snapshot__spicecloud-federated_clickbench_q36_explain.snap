|               |       VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=benchmarks-clickbench initial_sql=SELECT "hits"."ClientIP", ("hits"."ClientIP" - 1), ("hits"."ClientIP" - 2), ("hits"."ClientIP" - 3), count(1) AS "c" FROM "hits" GROUP BY "hits"."ClientIP", ("hits"."ClientIP" - 1), ("hits"."ClientIP" - 2), ("hits"."ClientIP" - 3) ORDER BY "c" DESC NULLS FIRST LIMIT 10 rewritten_sql=SELECT "ClientIP", ("hits"."ClientIP" - 1), ("hits"."ClientIP" - 2), ("hits"."ClientIP" - 3), count(1) AS "c" FROM "clickbench"."hits" GROUP BY "hits"."ClientIP", ("hits"."ClientIP" - 1), ("hits"."ClientIP" - 2), ("hits"."ClientIP" - 3) ORDER BY "c" DESC NULLS FIRST LIMIT 10 |
