| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                        |
|               |   CooperativeExec                                                                                                                                                                                                                                                                         |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                    |
|               |       VirtualExecutionPlan name=sqlite compute_context=//data/accelerated_sqlite.db initial_sql=SELECT `hits`.`AdvEngineID`, count(1) AS `count(*)` FROM `hits` WHERE (`hits`.`AdvEngineID` <> 0) GROUP BY `hits`.`AdvEngineID` ORDER BY `count(*)` DESC NULLS FIRST |
