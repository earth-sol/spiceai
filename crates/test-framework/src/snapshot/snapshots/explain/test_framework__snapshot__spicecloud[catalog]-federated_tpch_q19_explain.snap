|               |       Filter: tpch.tpch.part.p_brand = Utf8("Brand#12") AND tpch.tpch.part.p_container IN ([Utf8("SM CASE"), Utf8("SM BOX"), Utf8("SM PACK"), Utf8("SM PKG")]) AND tpch.tpch.part.p_size BETWEEN Int64(1) AND Int64(5) OR tpch.tpch.part.p_brand = Utf8("Brand#23") AND tpch.tpch.part.p_container IN ([Utf8("MED BAG"), Utf8("MED BOX"), Utf8("MED PKG"), Utf8("MED PACK")]) AND tpch.tpch.part.p_size BETWEEN Int64(1) AND Int64(10) OR tpch.tpch.part.p_brand = Utf8("Brand#34") AND tpch.tpch.part.p_container IN ([Utf8("LG CASE"), Utf8("LG BOX"), Utf8("LG PACK"), Utf8("LG PKG")]) AND tpch.tpch.part.p_size BETWEEN Int64(1) AND Int64(15)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           