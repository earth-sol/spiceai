                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |     Inner Join:  Filter: tpch.tpch.part.p_partkey = tpch.tpch.lineitem.l_partkey AND tpch.tpch.part.p_brand = Utf8("Brand#12") AND tpch.tpch.part.p_container IN ([Utf8("SM CASE"), Utf8("SM BOX"), Utf8("SM PACK"), Utf8("SM PKG")]) AND tpch.tpch.lineitem.l_quantity >= Int64(1) AND tpch.tpch.lineitem.l_quantity <= Int64(1) + Int64(10) AND tpch.tpch.part.p_size BETWEEN Int64(1) AND Int64(5) AND tpch.tpch.lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND tpch.tpch.lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON") OR tpch.tpch.part.p_partkey = tpch.tpch.lineitem.l_partkey AND tpch.tpch.part.p_brand = Utf8("Brand#23") AND tpch.tpch.part.p_container IN ([Utf8("MED BAG"), Utf8("MED BOX"), Utf8("MED PKG"), Utf8("MED PACK")]) AND tpch.tpch.lineitem.l_quantity >= Int64(10) AND tpch.tpch.lineitem.l_quantity <= Int64(10) + Int64(10) AND tpch.tpch.part.p_size BETWEEN Int64(1) AND Int64(10) AND tpch.tpch.lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND tpch.tpch.lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON") OR tpch.tpch.part.p_partkey = tpch.tpch.lineitem.l_partkey AND tpch.tpch.part.p_brand = Utf8("Brand#34") AND tpch.tpch.part.p_container IN ([Utf8("LG CASE"), Utf8("LG BOX"), Utf8("LG PACK"), Utf8("LG PKG")]) AND tpch.tpch.lineitem.l_quantity >= Int64(20) AND tpch.tpch.lineitem.l_quantity <= Int64(20) + Int64(10) AND tpch.tpch.part.p_size BETWEEN Int64(1) AND Int64(15) AND tpch.tpch.lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND tpch.tpch.lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |       TableScan: tpch.tpch.lineitem projection=[l_partkey, l_quantity, l_extendedprice, l_discount, l_shipinstruct, l_shipmode], full_filters=[tpch.tpch.lineitem.l_quantity >= Int64(1) AND tpch.tpch.lineitem.l_quantity <= Int64(1) + Int64(10) AND tpch.tpch.lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND tpch.tpch.lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON") OR tpch.tpch.lineitem.l_quantity >= Int64(10) AND tpch.tpch.lineitem.l_quantity <= Int64(10) + Int64(10) AND tpch.tpch.lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND tpch.tpch.lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON") OR tpch.tpch.lineitem.l_quantity >= Int64(20) AND tpch.tpch.lineitem.l_quantity <= Int64(20) + Int64(10) AND tpch.tpch.lineitem.l_shipmode IN ([Utf8("AIR"), Utf8("AIR REG")]) AND tpch.tpch.lineitem.l_shipinstruct = Utf8("DELIVER IN PERSON")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 