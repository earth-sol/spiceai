| physical_plan | SortPreservingMergeExec: [customer_id@0 ASC NULLS LAST, customer_first_name@1 ASC NULLS LAST, customer_last_name@2 ASC NULLS LAST, customer_email_address@3 ASC NULLS LAST], fetch=100                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
