|               |               Filter: (tpch.tpch.lineitem.l_shipmode = Utf8("MAIL") OR tpch.tpch.lineitem.l_shipmode = Utf8("SHIP")) AND tpch.tpch.lineitem.l_receiptdate > tpch.tpch.lineitem.l_commitdate AND tpch.tpch.lineitem.l_shipdate < tpch.tpch.lineitem.l_commitdate AND tpch.tpch.lineitem.l_receiptdate >= Date32("1994-01-01") AND tpch.tpch.lineitem.l_receiptdate < Date32("1995-01-01")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      