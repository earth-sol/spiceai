| physical_plan | SortPreservingMergeExec: [sum_sales@4 - avg_monthly_sales@3 ASC NULLS LAST, psum@5 ASC NULLS LAST], fetch=100                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
