source: crates/test-framework/src/snapshot/mod.rs
description: "Query: tpch_q16"
---
+---------------+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| plan_type     | plan                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
+---------------+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |  Sort: supplier_cnt DESC NULLS FIRST, tpch.tpch.part.p_brand ASC NULLS LAST, tpch.tpch.part.p_type ASC NULLS LAST, tpch.tpch.part.p_size ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |   Projection: tpch.tpch.part.p_brand, tpch.tpch.part.p_type, tpch.tpch.part.p_size, count(DISTINCT tpch.tpch.partsupp.ps_suppkey) AS supplier_cnt                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |     Aggregate: groupBy=[[tpch.tpch.part.p_brand, tpch.tpch.part.p_type, tpch.tpch.part.p_size]], aggr=[[count(DISTINCT tpch.tpch.partsupp.ps_suppkey)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |       Inner Join:  Filter: tpch.tpch.part.p_partkey = tpch.tpch.partsupp.ps_partkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |         Filter: tpch.tpch.partsupp.ps_suppkey NOT IN (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |           Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |             Projection: tpch.tpch.supplier.s_suppkey                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |               Filter: tpch.tpch.supplier.s_comment LIKE Utf8("%Customer%Complaints%")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |                 TableScan: tpch.tpch.supplier                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |           TableScan: tpch.tpch.partsupp projection=[ps_partkey, ps_suppkey]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |         Filter: tpch.tpch.part.p_type NOT LIKE Utf8("MEDIUM POLISHED%")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  |
|               |           TableScan: tpch.tpch.part projection=[p_partkey, p_brand, p_type, p_size], full_filters=[tpch.tpch.part.p_brand != Utf8("Brand#45"), tpch.tpch.part.p_size IN ([Int64(49), Int64(14), Int64(23), Int64(45), Int64(19), Int64(3), Int64(36), Int64(9)])]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch initial_sql=SELECT "p_brand", "p_type", "p_size", count(DISTINCT "partsupp"."ps_suppkey") AS "supplier_cnt" FROM "tpch"."tpch"."partsupp" INNER JOIN "tpch"."tpch"."part" ON (("part"."p_partkey" = "partsupp"."ps_partkey") AND ((("partsupp"."ps_suppkey" NOT IN (SELECT "s_suppkey" FROM "tpch"."tpch"."supplier" WHERE "supplier"."s_comment" LIKE '%Customer%Complaints%') AND "part"."p_type" NOT LIKE 'MEDIUM POLISHED%') AND ("part"."p_brand" <> 'Brand#45')) AND "part"."p_size" IN (49, 14, 23, 45, 19, 3, 36, 9))) GROUP BY "part"."p_brand", "part"."p_type", "part"."p_size" ORDER BY "supplier_cnt" DESC NULLS FIRST, "p_brand" ASC NULLS LAST, "p_type" ASC NULLS LAST, "p_size" ASC NULLS LAST rewritten_sql=SELECT "p_brand", "p_type", "p_size", count(DISTINCT "partsupp"."ps_suppkey") AS "supplier_cnt" FROM "spice"."tpch"."partsupp" INNER JOIN "spice"."tpch"."part" ON (("part"."p_partkey" = "partsupp"."ps_partkey") AND ((("partsupp"."ps_suppkey" NOT IN (SELECT "s_suppkey" FROM "spice"."tpch"."supplier" WHERE "supplier"."s_comment" LIKE '%Customer%Complaints%') AND "part"."p_type" NOT LIKE 'MEDIUM POLISHED%') AND ("part"."p_brand" <> 'Brand#45')) AND "part"."p_size" IN (49, 14, 23, 45, 19, 3, 36, 9))) GROUP BY "part"."p_brand", "part"."p_type", "part"."p_size" ORDER BY "supplier_cnt" DESC NULLS FIRST, "p_brand" ASC NULLS LAST, "p_type" ASC NULLS LAST, "p_size" ASC NULLS LAST |
|               |                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
