| physical_plan | SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                       |
|               |   CooperativeExec                                                                                                                                                                                                                                                                                                                                                                        |
|               |     BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                   |
|               |       VirtualExecutionPlan name=duckdb compute_context=//data/accelerated_duckdb.db initial_sql=SELECT "hits"."MobilePhone", "hits"."MobilePhoneModel", count(DISTINCT "hits"."UserID") AS "u" FROM "hits" WHERE (CAST("hits"."MobilePhoneModel" AS VARCHAR) <> '') GROUP BY "hits"."MobilePhone", "hits"."MobilePhoneModel" ORDER BY "u" DESC NULLS FIRST LIMIT 10 |
