Y "ca"."ca_state", "customer_demographics"."cd_gender", "customer_demographics"."cd_marital_status", "customer_demographics"."cd_dep_count", "customer_demographics"."cd_dep_employed_count", "customer_demographics"."cd_dep_college_count" ORDER BY "ca"."ca_state" ASC NULLS LAST, "customer_demographics"."cd_gender" ASC NULLS LAST, "customer_demographics"."cd_marital_status" ASC NULLS LAST, "customer_demographics"."cd_dep_count" ASC NULLS LAST, "customer_demographics"."cd_dep_employed_count" ASC NULLS LAST, "customer_demographics"."cd_dep_college_count" ASC NULLS LAST LIMIT 100 |
