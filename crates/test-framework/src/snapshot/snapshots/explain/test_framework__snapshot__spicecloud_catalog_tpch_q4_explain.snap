| logical_plan  | BytesProcessedNode                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |  Sort: tpch.tpch.orders.o_orderpriority ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           |
|               |   Projection: tpch.tpch.orders.o_orderpriority, count(*) AS order_count                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |     Aggregate: groupBy=[[tpch.tpch.orders.o_orderpriority]], aggr=[[count(*)]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   |
|               |       Filter: tpch.tpch.orders.o_orderdate < CAST(Utf8("1993-07-01") AS Date32) + IntervalMonthDayNano("IntervalMonthDayNano { months: 3, days: 0, nanoseconds: 0 }") AND EXISTS (<subquery>)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |         Subquery:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |           Projection: tpch.tpch.lineitem.l_orderkey, tpch.tpch.lineitem.l_partkey, tpch.tpch.lineitem.l_suppkey, tpch.tpch.lineitem.l_linenumber, tpch.tpch.lineitem.l_quantity, tpch.tpch.lineitem.l_extendedprice, tpch.tpch.lineitem.l_discount, tpch.tpch.lineitem.l_tax, tpch.tpch.lineitem.l_returnflag, tpch.tpch.lineitem.l_linestatus, tpch.tpch.lineitem.l_shipdate, tpch.tpch.lineitem.l_commitdate, tpch.tpch.lineitem.l_receiptdate, tpch.tpch.lineitem.l_shipinstruct, tpch.tpch.lineitem.l_shipmode, tpch.tpch.lineitem.l_comment                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |             Filter: tpch.tpch.lineitem.l_orderkey = outer_ref(tpch.tpch.orders.o_orderkey) AND tpch.tpch.lineitem.l_commitdate < tpch.tpch.lineitem.l_receiptdate                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |               TableScan: tpch.tpch.lineitem                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |         TableScan: tpch.tpch.orders projection=[o_orderkey, o_orderdate, o_orderpriority], full_filters=[tpch.tpch.orders.o_orderdate >= Utf8("1993-07-01")]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=tpch sql=SELECT tpch.tpch.orders.o_orderpriority, count(*) AS order_count FROM tpch.tpch.orders WHERE ((tpch.tpch.orders.o_orderdate < (CAST('1993-07-01' AS DATE) + INTERVAL '3 MONS')) AND EXISTS (SELECT tpch.tpch.lineitem.l_orderkey, tpch.tpch.lineitem.l_partkey, tpch.tpch.lineitem.l_suppkey, tpch.tpch.lineitem.l_linenumber, tpch.tpch.lineitem.l_quantity, tpch.tpch.lineitem.l_extendedprice, tpch.tpch.lineitem.l_discount, tpch.tpch.lineitem.l_tax, tpch.tpch.lineitem.l_returnflag, tpch.tpch.lineitem.l_linestatus, tpch.tpch.lineitem.l_shipdate, tpch.tpch.lineitem.l_commitdate, tpch.tpch.lineitem.l_receiptdate, tpch.tpch.lineitem.l_shipinstruct, tpch.tpch.lineitem.l_shipmode, tpch.tpch.lineitem.l_comment FROM tpch.tpch.lineitem WHERE ((tpch.tpch.lineitem.l_orderkey = tpch.tpch.orders.o_orderkey) AND (tpch.tpch.lineitem.l_commitdate < tpch.tpch.lineitem.l_receiptdate)))) AND (tpch.tpch.orders.o_orderdate >= '1993-07-01') GROUP BY tpch.tpch.orders.o_orderpriority ORDER BY tpch.tpch.orders.o_orderpriority ASC NULLS LAST rewritten_sql=SELECT "spice"."tpch"."orders"."o_orderpriority", count(*) AS "order_count" FROM "spice"."tpch"."orders" WHERE (("spice"."tpch"."orders"."o_orderdate" < (CAST('1993-07-01' AS DATE) + INTERVAL '3 MONS')) AND EXISTS (SELECT "spice"."tpch"."lineitem"."l_orderkey", "spice"."tpch"."lineitem"."l_partkey", "spice"."tpch"."lineitem"."l_suppkey", "spice"."tpch"."lineitem"."l_linenumber", "spice"."tpch"."lineitem"."l_quantity", "spice"."tpch"."lineitem"."l_extendedprice", "spice"."tpch"."lineitem"."l_discount", "spice"."tpch"."lineitem"."l_tax", "spice"."tpch"."lineitem"."l_returnflag", "spice"."tpch"."lineitem"."l_linestatus", "spice"."tpch"."lineitem"."l_shipdate", "spice"."tpch"."lineitem"."l_commitdate", "spice"."tpch"."lineitem"."l_receiptdate", "spice"."tpch"."lineitem"."l_shipinstruct", "spice"."tpch"."lineitem"."l_shipmode", "spice"."tpch"."lineitem"."l_comment" FROM "spice"."tpch"."lineitem" WHERE (("spice"."tpch"."lineitem"."l_orderkey" = "spice"."tpch"."orders"."o_orderkey") AND ("spice"."tpch"."lineitem"."l_commitdate" < "spice"."tpch"."lineitem"."l_receiptdate")))) AND ("spice"."tpch"."orders"."o_orderdate" >= '1993-07-01') GROUP BY "spice"."tpch"."orders"."o_orderpriority" ORDER BY "spice"."tpch"."orders"."o_orderpriority" ASC NULLS LAST |
