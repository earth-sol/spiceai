|               |   Federated                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |  Limit: skip=0, fetch=100                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |   Sort: customer_address.ca_country ASC NULLS LAST, customer_address.ca_state ASC NULLS LAST, customer_address.ca_county ASC NULLS LAST, item.i_item_id ASC NULLS LAST                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |     Projection: item.i_item_id, customer_address.ca_country, customer_address.ca_state, customer_address.ca_county, avg(catalog_sales.cs_quantity) AS agg1, avg(catalog_sales.cs_list_price) AS agg2, avg(catalog_sales.cs_coupon_amt) AS agg3, avg(catalog_sales.cs_sales_price) AS agg4, avg(catalog_sales.cs_net_profit) AS agg5, avg(customer.c_birth_year) AS agg6, avg(cd1.cd_dep_count) AS agg7                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |       Aggregate: groupBy=[[ROLLUP (item.i_item_id, customer_address.ca_country, customer_address.ca_state, customer_address.ca_county)]], aggr=[[avg(CAST(catalog_sales.cs_quantity AS Decimal128(12, 2))), avg(CAST(catalog_sales.cs_list_price AS Decimal128(12, 2))), avg(CAST(catalog_sales.cs_coupon_amt AS Decimal128(12, 2))), avg(CAST(catalog_sales.cs_sales_price AS Decimal128(12, 2))), avg(CAST(catalog_sales.cs_net_profit AS Decimal128(12, 2))), avg(CAST(customer.c_birth_year AS Decimal128(12, 2))), avg(CAST(cd1.cd_dep_count AS Decimal128(12, 2)))]]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        |
|               |         Inner Join:  Filter: catalog_sales.cs_item_sk = item.i_item_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |           Inner Join:  Filter: catalog_sales.cs_sold_date_sk = date_dim.d_date_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 |
|               |             Inner Join:  Filter: customer.c_current_addr_sk = customer_address.ca_address_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |               Inner Join:  Filter: catalog_sales.cs_bill_customer_sk = customer.c_customer_sk AND customer.c_current_cdemo_sk = cd2.cd_demo_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |                 Cross Join:                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
|               |                   Inner Join:  Filter: catalog_sales.cs_bill_cdemo_sk = cd1.cd_demo_sk                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |                     TableScan: catalog_sales projection=[cs_sold_date_sk, cs_bill_customer_sk, cs_bill_cdemo_sk, cs_item_sk, cs_quantity, cs_list_price, cs_sales_price, cs_coupon_amt, cs_net_profit]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            |
|               |                     Filter: cd1.cd_gender = Utf8("M") AND cd1.cd_education_status = Utf8("Primary")                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               |
|               |                       SubqueryAlias: cd1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          |
|               |                         TableScan: customer_demographics projection=[cd_demo_sk, cd_gender, cd_education_status, cd_dep_count]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
|               |                   SubqueryAlias: cd2                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |                     TableScan: customer_demographics projection=[cd_demo_sk]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      |
|               |                 TableScan: customer projection=[c_customer_sk, c_current_cdemo_sk, c_current_addr_sk, c_birth_year], full_filters=[customer.c_birth_month IN ([Int64(1), Int64(2), Int64(9), Int64(5), Int64(11), Int64(3)])]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     |
|               |               TableScan: customer_address projection=[ca_address_sk, ca_county, ca_state, ca_country], full_filters=[customer_address.ca_state IN ([Utf8("MS"), Utf8("NE"), Utf8("IA"), Utf8("MI"), Utf8("GA"), Utf8("NY"), Utf8("CO")])]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         |
|               |             TableScan: date_dim projection=[d_date_sk], full_filters=[date_dim.d_year = Int64(1998)]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |           TableScan: item projection=[i_item_sk, i_item_id]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       |
| physical_plan | BytesProcessedExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                |
|               |   SchemaCastScanExec                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              |
|               |     VirtualExecutionPlan name=spice.ai compute_context=url=https://flight.spiceai.io,username=,org=spiceai,app=benchmarks-tpcds initial_sql=SELECT "item"."i_item_id", "customer_address"."ca_country", "customer_address"."ca_state", "customer_address"."ca_county", avg(CAST("catalog_sales"."cs_quantity" AS DECIMAL(12,2))) AS "agg1", avg(CAST("catalog_sales"."cs_list_price" AS DECIMAL(12,2))) AS "agg2", avg(CAST("catalog_sales"."cs_coupon_amt" AS DECIMAL(12,2))) AS "agg3", avg(CAST("catalog_sales"."cs_sales_price" AS DECIMAL(12,2))) AS "agg4", avg(CAST("catalog_sales"."cs_net_profit" AS DECIMAL(12,2))) AS "agg5", avg(CAST("customer"."c_birth_year" AS DECIMAL(12,2))) AS "agg6", avg(CAST("cd1"."cd_dep_count" AS DECIMAL(12,2))) AS "agg7" FROM "catalog_sales" INNER JOIN "customer_demographics" AS "cd1" ON (("catalog_sales"."cs_bill_cdemo_sk" = "cd1"."cd_demo_sk") AND (("cd1"."cd_gender" = 'M') AND ("cd1"."cd_education_status" = 'Primary'))) CROSS JOIN "customer_demographics" AS "cd2" INNER JOIN "customer" ON ((("catalog_sales"."cs_bill_customer_sk" = "customer"."c_customer_sk") AND ("customer"."c_current_cdemo_sk" = "cd2"."cd_demo_sk")) AND "customer"."c_birth_month" IN (1, 2, 9, 5, 11, 3)) INNER JOIN "customer_address" ON (("customer"."c_current_addr_sk" = "customer_address"."ca_address_sk") AND "customer_address"."ca_state" IN ('MS', 'NE', 'IA', 'MI', 'GA', 'NY', 'CO')) INNER JOIN "date_dim" ON (("catalog_sales"."cs_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_year" = 1998)) INNER JOIN "item" ON ("catalog_sales"."cs_item_sk" = "item"."i_item_sk") GROUP BY ROLLUP ("item"."i_item_id", "customer_address"."ca_country", "customer_address"."ca_state", "customer_address"."ca_county") ORDER BY "customer_address"."ca_country" ASC NULLS LAST, "customer_address"."ca_state" ASC NULLS LAST, "customer_address"."ca_county" ASC NULLS LAST, "item"."i_item_id" ASC NULLS LAST LIMIT 100 rewritten_sql=SELECT "i_item_id", "ca_country", "ca_state", "ca_county", avg(CAST("catalog_sales"."cs_quantity" AS DECIMAL(12,2))) AS "agg1", avg(CAST("catalog_sales"."cs_list_price" AS DECIMAL(12,2))) AS "agg2", avg(CAST("catalog_sales"."cs_coupon_amt" AS DECIMAL(12,2))) AS "agg3", avg(CAST("catalog_sales"."cs_sales_price" AS DECIMAL(12,2))) AS "agg4", avg(CAST("catalog_sales"."cs_net_profit" AS DECIMAL(12,2))) AS "agg5", avg(CAST("customer"."c_birth_year" AS DECIMAL(12,2))) AS "agg6", avg(CAST("cd1"."cd_dep_count" AS DECIMAL(12,2))) AS "agg7" FROM "tpcds"."catalog_sales" INNER JOIN "tpcds"."customer_demographics" AS "cd1" ON (("catalog_sales"."cs_bill_cdemo_sk" = "cd1"."cd_demo_sk") AND (("cd1"."cd_gender" = 'M') AND ("cd1"."cd_education_status" = 'Primary'))) CROSS JOIN "tpcds"."customer_demographics" AS "cd2" INNER JOIN "tpcds"."customer" ON ((("catalog_sales"."cs_bill_customer_sk" = "customer"."c_customer_sk") AND ("customer"."c_current_cdemo_sk" = "cd2"."cd_demo_sk")) AND "customer"."c_birth_month" IN (1, 2, 9, 5, 11, 3)) INNER JOIN "tpcds"."customer_address" ON (("customer"."c_current_addr_sk" = "customer_address"."ca_address_sk") AND "customer_address"."ca_state" IN ('MS', 'NE', 'IA', 'MI', 'GA', 'NY', 'CO')) INNER JOIN "tpcds"."date_dim" ON (("catalog_sales"."cs_sold_date_sk" = "date_dim"."d_date_sk") AND ("date_dim"."d_year" = 1998)) INNER JOIN "tpcds"."item" ON ("catalog_sales"."cs_item_sk" = "item"."i_item_sk") GROUP BY ROLLUP ("item"."i_item_id", "customer_address"."ca_country", "customer_address"."ca_state", "customer_address"."ca_county") ORDER BY "ca_country" ASC NULLS LAST, "ca_state" ASC NULLS LAST, "ca_county" ASC NULLS LAST, "i_item_id" ASC NULLS LAST LIMIT 100 |
