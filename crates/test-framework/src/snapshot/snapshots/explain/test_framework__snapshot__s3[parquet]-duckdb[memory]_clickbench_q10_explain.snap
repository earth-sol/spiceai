|               |       VirtualExecutionPlan name=duckdb compute_context=:memory: initial_sql=SELECT "hits"."RegionID", sum("hits"."AdvEngineID"), count(1) AS "c", avg("hits"."ResolutionWidth"), count(DISTINCT "hits"."UserID") FROM "hits" GROUP BY "hits"."RegionID" ORDER BY "c" DESC NULLS FIRST LIMIT 10 |
