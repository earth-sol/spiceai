tadata: {} } }, Literal { value: Utf8("LG PACK"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }, Literal { value: Utf8("LG PKG"), field: Field { name: "lit", data_type: Utf8, nullable: false, dict_id: 0, dict_is_ordered: false, metadata: {} } }]) AND l_quantity@0 >= Some(20000000),18,6 AND l_quantity@0 <= Some(30000000),18,6 AND p_size@3 <= 15, projection=[l_discount@0, l_extendedprice@1] |
