---
source: crates/search/src/aggregation/reciprocal_rank.rs
expression: "reciprocal_rank_fusion_sql(vec![\"bm25\".to_string(),\n\"vector\".to_string()].as_slice(), [\"doc_id\".to_string()].as_slice(), &[], 5,\n3)"
snapshot_kind: text
---
WITH bm25 AS (
    SELECT
    *,
    ROW_NUMBER() OVER (ORDER BY score) AS rank
    FROM bm25
),
vector AS (
    SELECT
    *,
    ROW_NUMBER() OVER (ORDER BY score) AS rank
    FROM vector
)
SELECT
    TRUNC(coalesce(1.0/(bm25.rank + 5), 0) + coalesce(1.0/(vector.rank + 5), 0), 6) AS score,
    bm25.value AS value_0,
    vector.value AS value_1,
    coalesce(bm25.doc_id, vector.doc_id) as doc_id
FROM bm25
FULL OUTER JOIN vector ON 
    bm25.doc_id = vector.doc_id
ORDER BY score DESC
LIMIT 3;
